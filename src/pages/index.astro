<script>
  const contactForm = document.getElementById('contact-form') as HTMLFormElement;
  const contactSubmit = document.getElementById('contact-submit') as HTMLButtonElement;

  contactForm?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const name = (document.getElementById('contact-name') as HTMLInputElement).value;
    const phone = (document.getElementById('contact-phone') as HTMLInputElement).value;
    const city = (document.getElementById('contact-city') as HTMLSelectElement).value;
    const problem = (document.getElementById('contact-problem') as HTMLTextAreaElement).value;

    contactSubmit.disabled = true;
    contactSubmit.innerHTML = 'Отправка...';

    try {
      const response = await fetch('https://ujoxaraxvppnxulxjfwg.supabase.co/functions/v1/send-telegram', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': 'Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InVqb3hhcmF4dnBwbnh1bHhqZndnIiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzc3MDQ1OTMsImV4cCI6MjA5MzI4MDU5M30.UVegLPhJINlt9fm2drUkmnAJoT7mSlMgH5YVHgxfW7E',
        },
        body: JSON.stringify({ name, phone, city, problem, type: 'request' }),
      });

      if (response.ok) {
        contactSubmit.innerHTML = 'Спасибо! Мастер свяжется с вами в течение 10 минут';
        contactSubmit.style.background = '#16a34a';
        contactSubmit.style.boxShadow = '0 4px 14px rgba(22, 163, 74, 0.35)';
        contactForm.reset();
      } else {
        throw new Error('Ошибка отправки');
      }
    } catch {
      contactSubmit.innerHTML = 'Ошибка. Попробуйте позже';
      contactSubmit.style.background = '#dc2626';
    }

    setTimeout(() => {
      contactSubmit.innerHTML = 'Отправить заявку <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>';
      contactSubmit.style.background = '';
      contactSubmit.style.boxShadow = '';
      contactSubmit.disabled = false;
    }, 4000);
  });
</script>
