---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import FloatingButton from '../components/FloatingButton.astro';
import TelegramButtons from '../components/TelegramButtons.astro';
import Reviews from '../components/Reviews.astro';
import MasterTips from '../components/MasterTips.astro';
import RetentionBlock from '../components/RetentionBlock.astro';
import { SITE, CITIES, SERVICES } from '../data/services';

const title = 'Ремонт бытовой техники в Миассе, Златоусте, Чебаркуле | Центр восстановления бытовой техники';
const description = 'Профессиональный ремонт холодильников, стиральных машин, электроплит, микроволновок и пылесосов. Выезд мастера на дом, доступные цены, гарантия до 12 месяцев. Звоните: 8 (951) 257-77-57';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Центр восстановления бытовой техники",
  "description": "Ремонт бытовой техники в Миассе, Златоусте и Чебаркуле",
  "telephone": SITE.phone,
  "url": SITE.url,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "ул. Победы, д. 18, цоколь",
    "addressLocality": "Миасс",
    "addressRegion": "Челябинская область",
    "postalCode": "456300",
    "addressCountry": "RU",
  },
  "openingHours": "Mo-Su 09:00-20:00",
  "areaServed": [
    { "@type": "City", "name": "Миасс" },
    { "@type": "City", "name": "Златоуст" },
    { "@type": "City", "name": "Чебаркуль" },
  ],
  "priceRange": "$$",
  "image": `${SITE.url}/favicon.svg`,
});

const cityKeys = Object.keys(CITIES);
const serviceKeys = Object.keys(SERVICES);
---

<Layout title={title} description={description} schema={schema}>
  <SiteHeader />
  <FloatingButton />

  <main>
    <section class="hero">
      <div class="hero-bg">
        <div class="hero-pattern"></div>
      </div>
      <div class="container hero-content">
        <div class="hero-text">
          <span class="hero-badge">Работаем по Южному Уралу</span>
          <h1>Ремонт бытовой техники<br />с выездом на дом</h1>
          <p class="hero-subtitle">
            Холодильники, стиральные машины, электроплиты, микроволновки, пылесосы &mdash; починим быстро и с гарантией.
            Обслуживаем Миасс, Златоуст и Чебаркуль.
          </p>
          <TelegramButtons context="Здравствуйте! Нужен ремонт бытовой техники." />
          <div class="hero-cities">
            {cityKeys.map(key => {
              const city = CITIES[key as keyof typeof CITIES];
              return <a href={`/${city.slug}/`} class="city-tag">{city.name}</a>;
            })}
          </div>
        </div>
        <div class="hero-visual">
          <div class="hero-master-card">
            <div class="master-photo-wrap">
              <div class="master-photo-container">
                <img src="/master-dmitriy.png" alt="Мастер Дмитрий — ремонт бытовой техники" class="master-photo" loading="eager" />
                <!-- Перекрываем старый номер на фото новым -->
                <div class="phone-overlay">8-951-257-75-57</div>
              </div>
              <div class="master-badge-online">
                <span class="online-dot"></span>
                На связи
              </div>
            </div>
            <div class="master-info">
              <div class="master-name">Дмитрий</div>
              <div class="master-role">Ведущий мастер · 14 лет опыта</div>
              <div class="master-stats">
                <div class="mstat">
                  <span class="mstat-val">500+</span>
                  <span class="mstat-lbl">ремонтов</span>
                </div>
                <div class="mstat-sep"></div>
                <div class="mstat">
                  <span class="mstat-val">12 мес</span>
                  <span class="mstat-lbl">гарантия</span>
                </div>
                <div class="mstat-sep"></div>
                <div class="mstat">
                  <span class="mstat-val">1 день</span>
                  <span class="mstat-lbl">срок</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="services" id="services">
      <div class="container">
        <div class="section-header">
          <span class="section-label">Наши услуги</span>
          <h2>Что мы ремонтируем</h2>
          <p class="section-desc">Выполняем ремонт большинства видов бытовой техники. Работаем с популярными брендами и предоставляем гарантию на все виды работ.</p>
        </div>

        <div class="services-grid">
          {serviceKeys.map(key => {
            const service = SERVICES[key as keyof typeof SERVICES];
            return (
              <a href={`/miass/${service.slug}/`} class="service-card">
                <div class="service-icon" set:html={service.icon} />
                <h3>{service.name}</h3>
                <p>{service.commonProblems[0].price}</p>
                <span class="card-link">Подробнее &rarr;</span>
              </a>
            );
          })}
          <a href="/zapchasti/" class="service-card">
            <div class="service-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
              </svg>
            </div>
            <h3>Запчасти</h3>
            <p>по запросу</p>
            <span class="card-link">Каталог &rarr;</span>
          </a>
        </div>
      </div>
    </section>

    <section class="cities-section" id="cities">
      <div class="container">
        <div class="section-header">
          <span class="section-label">Города обслуживания</span>
          <h2>Работаем в трёх городах</h2>
          <p class="section-desc">Наша мастерская находится в Миассе. Выезд мастера — по всему городу и соседним населённым пунктам.</p>
        </div>

        <div class="cities-grid">
          {cityKeys.map(key => {
            const city = CITIES[key as keyof typeof CITIES];
            return (
              <a href={`/${city.slug}/`} class="city-card">
                <div class="city-marker">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                    <circle cx="12" cy="10" r="3" />
                  </svg>
                </div>
                <div class="city-info">
                  <h3>{city.name}</h3>
                  <p>{city.address}</p>
                  <div class="city-services">
                    {serviceKeys.slice(0, 3).map(sKey => {
                      const s = SERVICES[sKey as keyof typeof SERVICES];
                      return <a href={`/${city.slug}/${s.slug}/`}>{s.name}</a>;
                    })}
                  </div>
                </div>
                {city.hasWorkshop && <span class="badge-workshop">Мастерская</span>}
              </a>
            );
          })}
        </div>
      </div>
    </section>

    <section class="why-us" id="why-us">
      <div class="container">
        <div class="why-us-layout">
          <div class="why-us-text">
            <span class="section-label">Почему мы</span>
            <h2>Надёжный ремонт<br />от команды профессионалов</h2>
            <p class="why-us-desc">
              Мы — трое мастеров с собственной мастерской в Миассе. Не агентство и не посредники.
              Работаем руками, отвечаем за качество.
            </p>
            <TelegramButtons context="Здравствуйте! Хочу заказать ремонт." />
          </div>

          <div class="why-us-grid">
            <div class="reason-card">
              <div class="reason-icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              </div>
              <div>
                <h3>Команда из трёх мастеров</h3>
                <p>Каждый специалист с опытом более 10 лет. Знаем свою технику досконально.</p>
              </div>
            </div>
            <div class="reason-card">
              <div class="reason-icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
              </div>
              <div>
                <h3>Своя мастерская</h3>
                <p>Собственная мастерская в Миассе. Сложный ремонт выполняем на месте с полным оснащением.</p>
              </div>
            </div>
            <div class="reason-card">
              <div class="reason-icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              </div>
              <div>
                <h3>Быстрый выезд</h3>
                <p>Выезд в день обращения. Среднее время ремонта — 1 день. Ценим ваше время.</p>
              </div>
            </div>
            <div class="reason-card">
              <div class="reason-icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </div>
              <div>
                <h3>Гарантия на работы</h3>
                <p>Даём гарантию до 12 месяцев на все виды ремонта. Ответственность за результат.</p>
              </div>
            </div>
            <div class="reason-card">
              <div class="reason-icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
              </div>
              <div>
                <h3>Честные цены</h3>
                <p>Стоимость озвучиваем до начала работ. Никаких скрытых доплат и накруток.</p>
              </div>
            </div>
            <div class="reason-card">
              <div class="reason-icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
              </div>
              <div>
                <h3>Оригинальные запчасти</h3>
                <p>Используем оригинальные детали и качественные аналоги. Всё есть в наличии или под заказ.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <MasterTips />
    <RetentionBlock />
    <Reviews />
    <section class="contact" id="contact">
      <div class="container">
        <div class="contact-layout">
          <div class="contact-info">
            <span class="section-label">Свяжитесь с нами</span>
            <h2>Закажите ремонт</h2>
            <p class="contact-desc">
              Напишите нам в Telegram или WhatsApp — мастер ответит в течение 15 минут и согласует удобное время выезда.
            </p>

            <div class="contact-details">
              <div class="detail-item">
                <div class="detail-icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
                  </svg>
                </div>
                <div>
                  <span class="detail-label">Телефон</span>
                  <a href={`tel:+${SITE.phoneRaw}`} class="detail-value link">{SITE.phone}</a>
                </div>
              </div>

              <div class="detail-item">
                <div class="detail-icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                    <circle cx="12" cy="10" r="3" />
                  </svg>
                </div>
                <div>
                  <span class="detail-label">Адрес мастерской</span>
                  <span class="detail-value">{SITE.address}</span>
                </div>
              </div>

              <div class="detail-item">
                <div class="detail-icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10" />
                    <polyline points="12 6 12 12 16 14" />
                  </svg>
                </div>
                <div>
                  <span class="detail-label">Время работы</span>
                  <span class="detail-value">{SITE.workHours}</span>
                </div>
              </div>
            </div>
          </div>

          <div class="contact-actions">
            <h3>Оставьте заявку на ремонт</h3>
            <p>Заполните форму — мастер свяжется в течение 10 минут</p>
            <form class="contact-form" id="contact-form">
              <div class="form-group">
                <label for="contact-name">Ваше имя</label>
                <input type="text" id="contact-name" name="name" placeholder="Иван Иванов" required />
              </div>
              <div class="form-group">
                <label for="contact-phone">Телефон</label>
                <input type="tel" id="contact-phone" name="phone" placeholder="+7 (___) ___-__-__" required />
              </div>
              <div class="form-group">
                <label for="contact-city">Город</label>
                <select id="contact-city" name="city" required>
                  <option value="" disabled selected>Выберите город</option>
                  <option value="Миасс">Миасс</option>
                  <option value="Златоуст">Златоуст</option>
                  <option value="Чебаркуль">Чебаркуль</option>
                </select>
              </div>
              <div class="form-group">
                <label for="contact-problem">Опишите проблему</label>
                <textarea id="contact-problem" name="problem" rows="3" placeholder="Например: холодильник не морозит, компрессор гудит..."></textarea>
              </div>
              <button type="submit" class="submit-btn" id="contact-submit">
                Отправить заявку
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="5" y1="12" x2="19" y2="12" />
                  <polyline points="12 5 19 12 12 19" />
                </svg>
              </button>
              <p class="form-note">Нажимая кнопку, вы соглашаетесь с обработкой персональных данных</p>
            </form>
            <div class="contact-phone-block">
              <span>Или позвоните:</span>
              <a href={`tel:+${SITE.phoneRaw}`} class="phone-big">{SITE.phone}</a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />
</Layout>

<style>
  .hero {
    position: relative;
    padding: 120px 0 80px;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 50%, #bfdbfe 100%);
  }

  .hero-pattern {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle at 1px 1px, #93c5fd 1px, transparent 0);
    background-size: 40px 40px;
    opacity: 0.3;
  }

  .hero-content {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
  }

  .hero-text {
    max-width: 560px;
  }

  .hero-badge {
    display: inline-block;
    padding: 6px 16px;
    background: rgba(29, 78, 216, 0.1);
    color: #1d4ed8;
    border-radius: 100px;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 24px;
  }

  .hero h1 {
    font-size: 3rem;
    font-weight: 700;
    line-height: 1.15;
    color: #0f172a;
    margin-bottom: 20px;
  }

  .hero-subtitle {
    font-size: 1.15rem;
    color: #475569;
    line-height: 1.7;
    margin-bottom: 32px;
  }

  .hero-cities {
    display: flex;
    gap: 10px;
    margin-top: 24px;
  }

  .city-tag {
    padding: 6px 14px;
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    font-size: 0.85rem;
    font-weight: 500;
    color: #475569;
    transition: all 0.2s;
  }

  .city-tag:hover {
    border-color: #1d4ed8;
    color: #1d4ed8;
  }

  .hero-visual {
    display: flex;
    justify-content: center;
  }

  .hero-master-card {
    background: #fff;
    border-radius: 24px;
    box-shadow: 0 20px 60px rgba(29, 78, 216, 0.12), 0 4px 16px rgba(0, 0, 0, 0.05);
    width: 100%;
    max-width: 380px;
    overflow: hidden;
  }

  .master-photo-wrap {
    position: relative;
    background: linear-gradient(160deg, #dbeafe 0%, #eff6ff 100%);
    overflow: hidden;
  }

  .master-photo-container {
    position: relative;
    display: block;
  }

  .master-photo {
    display: block;
    width: 100%;
    height: auto;
  }

  .phone-overlay {
    position: absolute;
    bottom: 10%;
    left: 3%;
    width: 42%;
    background: #1a1a1a;
    color: #fff;
    font-size: clamp(0.55rem, 1.4vw, 0.85rem);
    font-weight: 700;
    letter-spacing: 0.03em;
    padding: 2px 6px 3px;
    border-radius: 3px;
    line-height: 1.4;
    pointer-events: none;
    user-select: none;
  }

  @media (min-width: 900px) {
    .phone-overlay {
      bottom: 22%;
    }
  }

  .master-badge-online {
    position: absolute;
    top: 16px;
    right: 16px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: #fff;
    border: 1px solid #bbf7d0;
    color: #166534;
    font-size: 0.78rem;
    font-weight: 700;
    padding: 6px 12px;
    border-radius: 100px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  }

  .online-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #16a34a;
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { box-shadow: 0 0 0 0 rgba(22,163,74,0.5); }
    50% { box-shadow: 0 0 0 5px rgba(22,163,74,0); }
  }

  .master-info {
    padding: 20px 24px 24px;
  }

  .master-name {
    font-size: 1.3rem;
    font-weight: 800;
    color: #0f172a;
    margin-bottom: 2px;
  }

  .master-role {
    font-size: 0.82rem;
    color: #64748b;
    margin-bottom: 16px;
  }

  .master-stats {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .mstat {
    display: flex;
    flex-direction: column;
  }

  .mstat-val {
    font-size: 1.1rem;
    font-weight: 700;
    color: #1d4ed8;
  }

  .mstat-lbl {
    font-size: 0.72rem;
    color: #94a3b8;
  }

  .mstat-sep {
    width: 1px;
    height: 32px;
    background: #e2e8f0;
    flex-shrink: 0;
  }

  .services {
    padding: 96px 0;
    background: #fff;
  }

  .section-header {
    text-align: center;
    max-width: 600px;
    margin: 0 auto 56px;
  }

  .section-label {
    display: inline-block;
    padding: 4px 14px;
    background: #eff6ff;
    color: #1d4ed8;
    border-radius: 100px;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 16px;
  }

  .section-header h2 {
    font-size: 2.25rem;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 16px;
  }

  .section-desc {
    font-size: 1.05rem;
    color: #64748b;
    line-height: 1.7;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .service-card {
    display: block;
    padding: 32px;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 16px;
    transition: all 0.3s;
  }

  .service-card:hover {
    background: #fff;
    border-color: #bfdbfe;
    box-shadow: 0 8px 32px rgba(29, 78, 216, 0.08);
    transform: translateY(-2px);
  }

  .service-icon {
    width: 56px;
