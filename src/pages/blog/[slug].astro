---
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import FloatingButton from '../../components/FloatingButton.astro';
import TelegramButtons from '../../components/TelegramButtons.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import FAQ from '../../components/FAQ.astro';
import { BLOG_ARTICLES } from '../../data/blog';
import { SITE, SERVICES } from '../../data/services';

export function getStaticPaths() {
  return BLOG_ARTICLES.map(article => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.props;

const formatDate = (dateStr: string) => {
  const d = new Date(dateStr);
  return d.toLocaleDateString('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' });
};

const siteUrl = 'https://master-tehniki74.store';

const articleSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": article.title,
  "description": article.description,
  "datePublished": article.date,
  "dateModified": article.date,
  "author": { "@type": "Organization", "name": "Master-Tehniki74", "url": siteUrl },
  "publisher": { "@type": "Organization", "name": "Master-Tehniki74", "url": siteUrl },
  "image": article.image,
  "keywords": article.keywords.join(', '),
});

const faqSchema = article.faq && article.faq.length > 0 ? JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": article.faq.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": { "@type": "Answer", "text": item.answer },
  })),
}) : null;

const schemas = [articleSchema, ...(faqSchema ? [faqSchema] : [])];

const relatedArticles = [
  ...BLOG_ARTICLES.filter(a => a.slug !== article.slug && a.categorySlug === article.categorySlug),
  ...BLOG_ARTICLES.filter(a => a.slug !== article.slug && a.categorySlug !== article.categorySlug),
].slice(0, 3);
---

<Layout
  title={`${article.title} | Master-Tehniki74`}
  description={article.description}
  keywords={article.keywords.join(', ')}
  canonical={`/blog/${article.slug}/`}
  schema={`[${schemas.join(',')}]`}
  ogImage={article.image}
>
  <SiteHeader />
  <FloatingButton />

  <main>
    <article class="article-page">
      <div class="container">
        <Breadcrumbs items={[
          { label: 'Главная', href: '/' },
          { label: 'Блог', href: '/blog/' },
          { label: article.title },
        ]} />

        <div class="article-layout">
          <div class="article-main">
            <header class="article-header">
              <span class="article-category-badge">{article.category}</span>
              <h1>{article.title}</h1>
              <div class="article-meta">
                <time datetime={article.date}>{formatDate(article.date)}</time>
                <span class="meta-dot"></span>
                <span>{article.readTime} мин чтения</span>
              </div>
            </header>

            <div class="article-image">
              <img src={article.image} alt={article.title} loading="lazy" />
            </div>

            <div class="article-body">
              <p class="article-intro">{article.intro}</p>

              {article.sections.map(section => (
                <section class="article-section">
                  <h2>{section.heading}</h2>
                  {section.content.split('\n\n').map(p => <p>{p}</p>)}
                </section>
              ))}

              {article.faq && article.faq.length > 0 && (
                <section class="article-faq">
                  <h2>Частые вопросы</h2>
                  {article.faq.map(item => (
                    <div class="faq-item">
                      <h3>{item.question}</h3>
                      <p>{item.answer}</p>
                    </div>
                  ))}
                </section>
              )}

              <section class="article-conclusion">
                <h2>Итог</h2>
                <p>{article.conclusion}</p>
              </section>
            </div>

            <div class="article-cta">
              <h3>Нужен ремонт? Звоните!</h3>
              <p>Мастер приедет в день обращения, проведёт бесплатную диагностику и назовёт точную стоимость.</p>
              <TelegramButtons context={`Здравствуйте! Прочитал статью "${article.title}", нужен ремонт.`} />
            </div>
          </div>

          <aside class="article-sidebar">
            <div class="sidebar-block">
              <h4>Категории</h4>
              <div class="sidebar-links">
                <a href="/blog/">Все статьи</a>
                <a href="/blog/#holodilniki">Холодильники</a>
                <a href="/blog/#stiralnye-mashiny">Стиральные машины</a>
                <a href="/blog/#mikrovolnovki">Микроволновки</a>
                <a href="/blog/#elektroplity">Электроплиты</a>
                <a href="/blog/#pylesosy">Пылесосы</a>
                <a href="/blog/#sovety">Полезные советы</a>
                <a href="/blog/#biznes">Для бизнеса</a>
              </div>
            </div>
            <div class="sidebar-block">
              <h4>Заказать ремонт</h4>
              <div class="sidebar-links">
                {Object.values(SERVICES).map(s => (
                  <a href={`/miass/${s.slug}/`}>{s.name}</a>
                ))}
                <a href="/b2b/">Для бизнеса</a>
              </div>
            </div>
            <div class="sidebar-block sidebar-cta">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#1d4ed8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              <h4>Нужна помощь?</h4>
              <p>Звоните прямо сейчас</p>
              <a href={`tel:+${SITE.phoneRaw}`} class="sidebar-phone">{SITE.phone}</a>
            </div>
          </aside>
        </div>

        {relatedArticles.length > 0 && (
          <section class="related-articles">
            <h2>Читайте также</h2>
            <div class="related-grid">
              {relatedArticles.map(related => (
                <a href={`/blog/${related.slug}/`} class="related-card">
                  <div class="related-image">
                    <img src={related.image} alt={related.title} loading="lazy" />
                  </div>
                  <div class="related-content">
                    <span class="related-category">{related.category}</span>
                    <h3>{related.title}</h3>
                    <span class="related-link">Читать &rarr;</span>
                  </div>
                </a>
              ))}
            </div>
          </section>
        )}
      </div>
    </article>
  </main>

  <SiteFooter />
</Layout>

<style>
  .article-page { padding-top: 100px; padding-bottom: 96px; }
  .article-layout { display: grid; grid-template-columns: 1fr 280px; gap: 48px; align-items: start; }
  .article-header { margin-bottom: 32px; }
  .article-category-badge { display: inline-block; padding: 4px 12px; background: #eff6ff; color: #1d4ed8; border-radius: 6px; font-size: 0.8rem; font-weight: 600; margin-bottom: 16px; }
  .article-header h1 { font-size: 2.25rem; font-weight: 700; color: #0f172a; line-height: 1.2; margin-bottom: 16px; }
  .article-meta { display: flex; align-items: center; gap: 8px; font-size: 0.85rem; color: #94a3b8; }
  .meta-dot { width: 3px; height: 3px; background: #94a3b8; border-radius: 50%; }
  .article-image { margin-bottom: 40px; border-radius: 20px; overflow: hidden; }
  .article-image img { width: 100%; height: 360px; object-fit: cover; }
  .article-body { font-size: 1rem; line-height: 1.8; color: #334155; }
  .article-intro { font-size: 1.1rem; line-height: 1.8; color: #475569; margin-bottom: 40px; padding-bottom: 32px; border-bottom: 1px solid #e2e8f0; }
  .article-section { margin-bottom: 40px; }
  .article-section h2 { font-size: 1.5rem; font-weight: 700; color: #0f172a; margin-bottom: 16px; line-height: 1.3; }
  .article-section p { margin-bottom: 16px; }
  .article-faq { margin-top: 48px; padding: 32px; background: #f8fafc; border-radius: 20px; border: 1px solid #e2e8f0; }
  .article-faq h2 { font-size: 1.3rem; font-weight: 700; color: #0f172a; margin-bottom: 24px; }
  .faq-item { margin-bottom: 20px; padding-bottom: 20px; border-bottom: 1px solid #e2e8f0; }
  .faq-item:last-child { margin-bottom: 0; padding-bottom: 0; border-bottom: none; }
  .faq-item h3 { font-size: 1rem; font-weight: 600; color: #0f172a; margin-bottom: 8px; }
  .faq-item p { font-size: 0.95rem; color: #64748b; line-height: 1.7; }
  .article-conclusion { margin-top: 40px; padding: 32px; background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%); border-radius: 20px; }
  .article-conclusion h2 { font-size: 1.3rem; font-weight: 700; color: #0f172a; margin-bottom: 12px; }
  .article-conclusion p { font-size: 1rem; color: #475569; line-height: 1.7; }
  .article-cta { margin-top: 48px; padding: 40px; background: #fff; border: 1px solid #e2e8f0; border-radius: 20px; text-align: center; }
  .article-cta h3 { font-size: 1.3rem; font-weight: 700; color: #0f172a; margin-bottom: 8px; }
  .article-cta p { font-size: 1rem; color: #64748b; margin-bottom: 24px; }
  .article-sidebar { position: sticky; top: 96px; }
  .sidebar-block { background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 16px; padding: 24px; margin-bottom: 20px; }
  .sidebar-block h4 { font-size: 0.85rem; font-weight: 600; color: #0f172a; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 16px; }
  .sidebar-links { display: flex; flex-direction: column; gap: 10px; }
  .sidebar-links a { font-size: 0.9rem; color: #475569; transition: color 0.2s; }
  .sidebar-links a:hover { color: #1d4ed8; }
  .sidebar-cta { text-align: center; background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%); }
  .sidebar-cta h4 { margin-top: 12px; text-transform: none; letter-spacing: 0; font-size: 1rem; }
  .sidebar-cta p { font-size: 0.85rem; color: #64748b; margin-bottom: 12px; }
  .sidebar-phone { display: block; font-size: 1.2rem; font-weight: 700; color: #1d4ed8; }
  .related-articles { margin-top: 64px; padding-top: 48px; border-top: 1px solid #e2e8f0; }
  .related-articles h2 { font-size: 1.5rem; font-weight: 700; color: #0f172a; margin-bottom: 32px; }
  .related-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .related-card { display: flex; flex-direction: column; background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 16px; overflow: hidden; transition: all 0.3s; }
  .related-card:hover { border-color: #bfdbfe; box-shadow: 0 8px 24px rgba(29,78,216,0.08); transform: translateY(-2px); }
  .related-image { height: 140px; overflow: hidden; }
  .related-image img { width: 100%; height: 100%; object-fit: cover; }
  .related-content { padding: 20px; flex: 1; }
  .related-category { display: inline-block; padding: 2px 8px; background: #eff6ff; color: #1d4ed8; border-radius: 4px; font-size: 0.7rem; font-weight: 600; margin-bottom: 8px; }
  .related-content h3 { font-size: 0.95rem; font-weight: 600; color: #0f172a; line-height: 1.4; margin-bottom: 12px; }
  .related-link { font-size: 0.8rem; font-weight: 600; color: #1d4ed8; }
  @media (max-width: 768px) {
    .article-layout { grid-template-columns: 1fr; gap: 32px; }
    .article-header h1 { font-size: 1.75rem; }
    .article-image img { height: 220px; }
    .article-sidebar { position: static; }
    .related-grid { grid-template-columns: 1fr; }
    .article-cta { padding: 24px; }
  }
  @media (min-width: 769px) and (max-width: 1024px) {
    .article-layout { grid-template-columns: 1fr 240px; gap: 32px; }
    .related-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
