</style>

<script>
  const SUPABASE_URL = import.meta.env.VITE_SUPABASE_URL;
  const SUPABASE_KEY = import.meta.env.VITE_SUPABASE_ANON_KEY;

  // Tab switching
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
      btn.classList.add('active');
      document.getElementById(`tab-${btn.dataset.tab}`)?.classList.add('active');
    });
  });

  // Load contacts
  async function loadContacts() {
    const cityFilter = (document.getElementById('city-filter') as HTMLSelectElement).value;
    const categoryFilter = (document.getElementById('category-filter') as HTMLSelectElement).value;

    let url = `${SUPABASE_URL}/rest/v1/b2b_contacts?select=*&order=created_at.desc&status=eq.active`;
    if (cityFilter) url += `&city=eq.${encodeURIComponent(cityFilter)}`;
    if (categoryFilter) url += `&category=eq.${encodeURIComponent(categoryFilter)}`;

    const res = await fetch(url, {
      headers: {
        'apikey': SUPABASE_KEY,
        'Authorization': `Bearer ${SUPABASE_KEY}`,
      },
    });

    const contacts = await res.json();
    const tbody = document.getElementById('contacts-body')!;
    document.getElementById('contacts-count')!.textContent = `${contacts.length} контактов`;

    if (contacts.length === 0) {
      tbody.innerHTML = `<tr><td colspan="9" class="empty-state"><p>Нет контактов. Добавьте первый контакт или импортируйте CSV.</p></td></tr>`;
      return;
    }

    tbody.innerHTML = contacts.map((c: any) => `
      <tr>
        <td><input type="checkbox" class="contact-check" data-id="${c.id}" /></td>
        <td><strong>${c.company_name}</strong></td>
        <td>${c.inn || '—'}</td>
        <td>${c.email}</td>
        <td>${c.phone || '—'}</td>
        <td>${c.city}</td>
        <td>${c.category || '—'}</td>
        <td>${c.contact_person || '—'}</td>
        <td>
          <button class="action-btn edit-contact" data-id="${c.id}">Изм.</button>
          <button class="action-btn delete delete-contact" data-id="${c.id}">Удл.</button>
        </td>
      </tr>
    `).join('');

    // Wire up edit/delete
    tbody.querySelectorAll('.edit-contact').forEach(btn => {
      btn.addEventListener('click', () => editContact((btn as HTMLElement).dataset.id!));
    });
    tbody.querySelectorAll('.delete-contact').forEach(btn => {
      btn.addEventListener('click', () => deleteContact((btn as HTMLElement).dataset.id!));
    });

    // Checkbox handling
    updateBulkActions();
  }

  // Save contact
  document.getElementById('contact-form')!.addEventListener('submit', async (e) => {
    e.preventDefault();
    const id = (document.getElementById('contact-id') as HTMLInputElement).value;
    const data = {
      company_name: (document.getElementById('company-name') as HTMLInputElement).value,
      inn: (document.getElementById('inn') as HTMLInputElement).value,
      email: (document.getElementById('contact-email') as HTMLInputElement).value,
      phone: (document.getElementById('contact-phone') as HTMLInputElement).value,
      city: (document.getElementById('contact-city') as HTMLSelectElement).value,
      category: (document.getElementById('contact-category') as HTMLSelectElement).value,
      contact_person: (document.getElementById('contact-person') as HTMLInputElement).value,
      notes: (document.getElementById('contact-notes') as HTMLInputElement).value,
    };

    const method = id ? 'PATCH' : 'POST';
    const url = id
      ? `${SUPABASE_URL}/rest/v1/b2b_contacts?id=eq.${id}`
      : `${SUPABASE_URL}/rest/v1/b2b_contacts`;

    await fetch(url, {
      method,
      headers: {
        'apikey': SUPABASE_KEY,
        'Authorization': `Bearer ${SUPABASE_KEY}`,
        'Content-Type': 'application/json',
        'Prefer': 'return=minimal',
      },
      body: JSON.stringify(data),
    });

    closeModal('modal-contact');
    loadContacts();
  });

  // Edit contact
  async function editContact(id: string) {
    const res = await fetch(`${SUPABASE_URL}/rest/v1/b2b_contacts?id=eq.${id}`, {
      headers: { 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${SUPABASE_KEY}` },
    });
    const contacts = await res.json();
    if (contacts.length === 0) return;
    const c = contacts[0];

    (document.getElementById('modal-contact-title') as HTMLElement).textContent = 'Редактировать контакт';
    (document.getElementById('contact-id') as HTMLInputElement).value = c.id;
    (document.getElementById('company-name') as HTMLInputElement).value = c.company_name || '';
    (document.getElementById('inn') as HTMLInputElement).value = c.inn || '';
    (document.getElementById('contact-email') as HTMLInputElement).value = c.email || '';
    (document.getElementById('contact-phone') as HTMLInputElement).value = c.phone || '';
    (document.getElementById('contact-city') as HTMLSelectElement).value = c.city || 'Миасс';
    (document.getElementById('contact-category') as HTMLSelectElement).value = c.category || '';
    (document.getElementById('contact-person') as HTMLInputElement).value = c.contact_person || '';
    (document.getElementById('contact-notes') as HTMLInputElement).value = c.notes || '';

    (document.getElementById('modal-contact') as HTMLElement).style.display = 'flex';
  }

  // Delete contact
  async function deleteContact(id: string) {
    if (!confirm('Удалить контакт?')) return;
    await fetch(`${SUPABASE_URL}/rest/v1/b2b_contacts?id=eq.${id}`, {
      method: 'DELETE',
      headers: { 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${SUPABASE_KEY}` },
    });
    loadContacts();
  }

  // Bulk actions
  function updateBulkActions() {
    const checked = document.querySelectorAll('.contact-check:checked');
    const bulk = document.getElementById('bulk-actions')!;
    if (checked.length > 0) {
      bulk.style.display = 'flex';
      (document.getElementById('selected-count') as HTMLElement).textContent = `${checked.length} выбрано`;
    } else {
      bulk.style.display = 'none';
    }
  }

  document.addEventListener('change', (e) => {
    if ((e.target as HTMLElement).classList.contains('contact-check')) updateBulkActions();
  });

  document.getElementById('select-all')!.addEventListener('change', (e) => {
    const checked = (e.target as HTMLInputElement).checked;
    document.querySelectorAll('.contact-check').forEach((cb: any) => cb.checked = checked);
    updateBulkActions();
  });

  document.getElementById('btn-delete-selected')!.addEventListener('click', async () => {
    const checked = Array.from(document.querySelectorAll('.contact-check:checked')).map((cb: any) => cb.dataset.id);
    if (checked.length === 0 || !confirm(`Удалить ${checked.length} контактов?`)) return;

    const orFilter = checked.map(id => `id.eq.${id}`).join(',');
    await fetch(`${SUPABASE_URL}/rest/v1/b2b_contacts?or=(${orFilter})`, {
      method: 'DELETE',
      headers: { 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${SUPABASE_KEY}` },
    });
    loadContacts();
  });

  // Add to campaign from selection
  document.getElementById('btn-add-to-campaign')!.addEventListener('click', () => {
    const checked = Array.from(document.querySelectorAll('.contact-check:checked')).map((cb: any) => cb.dataset.id);
    if (checked.length === 0) return;
    openCampaignModal();
    (document.getElementById('campaign-recipients-count') as HTMLElement).textContent = String(checked.length);
  });

  // Modal open/close
  function openModal(id: string) {
    (document.getElementById(id) as HTMLElement).style.display = 'flex';
  }

  function closeModal(id: string) {
    (document.getElementById(id) as HTMLElement).style.display = 'none';
  }

  document.getElementById('btn-add-contact')!.addEventListener('click', () => {
    (document.getElementById('contact-form') as HTMLFormElement).reset();
    (document.getElementById('contact-id') as HTMLInputElement).value = '';
    (document.getElementById('modal-contact-title') as HTMLElement).textContent = 'Добавить контакт';
    openModal('modal-contact');
  });

  document.getElementById('close-contact-modal')!.addEventListener('click', () => closeModal('modal-contact'));
  document.getElementById('cancel-contact')!.addEventListener('click', () => closeModal('modal-contact'));

  // Campaign modal
  function openCampaignModal() {
    (document.getElementById('campaign-form') as HTMLFormElement).reset();
    (document.getElementById('campaign-id') as HTMLInputElement).value = '';
    (document.getElementById('modal-campaign-title') as HTMLElement).textContent = 'Новая рассылка';
    openModal('modal-campaign');
  }

  document.getElementById('btn-new-campaign')!.addEventListener('click', openCampaignModal);
  document.getElementById('close-campaign-modal')!.addEventListener('click', () => closeModal('modal-campaign'));

  // Count recipients when filters change
  async function countRecipients() {
    const city = (document.getElementById('campaign-city') as HTMLSelectElement).value;
    const category = (document.getElementById('campaign-category') as HTMLSelectElement).value;
    let url = `${SUPABASE_URL}/rest/v1/b2b_contacts?select=id&status=eq.active`;
    if (city) url += `&city=eq.${encodeURIComponent(city)}`;
    if (category) url += `&category=eq.${encodeURIComponent(category)}`;

    const res = await fetch(url, {
      headers: { 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${SUPABASE_KEY}` },
    });

    const data = await res.json();
    (document.getElementById('campaign-recipients-count') as HTMLElement).textContent = String(data.length);
  }

  document.getElementById('campaign-city')!.addEventListener('change', countRecipients);
  document.getElementById('campaign-category')!.addEventListener('change', countRecipients);

  // Save draft
  document.getElementById('save-draft')!.addEventListener('click', async () => {
    const data = {
      subject: (document.getElementById('campaign-subject') as HTMLInputElement).value,
      body: (document.getElementById('campaign-body') as HTMLTextAreaElement).value,
      city_filter: (document.getElementById('campaign-city') as HTMLSelectElement).value,
      category_filter: (document.getElementById('campaign-category') as HTMLSelectElement).value,
      status: 'draft',
    };

    await fetch(`${SUPABASE_URL}/rest/v1/b2b_campaigns`, {
      method: 'POST',
      headers: {
        'apikey': SUPABASE_KEY,
        'Authorization': `Bearer ${SUPABASE_KEY}`,
        'Content-Type': 'application/json',
        'Prefer': 'return=minimal',
      },
      body: JSON.stringify(data),
    });

    closeModal('modal-campaign');
    loadCampaigns();
  });

  // Send campaign
  document.getElementById('campaign-form')!.addEventListener('submit', async (e) => {
    e.preventDefault();
    const subject = (document.getElementById('campaign-subject') as HTMLInputElement).value;
    const body = (document.getElementById('campaign-body') as HTMLTextAreaElement).value;
    const city = (document.getElementById('campaign-city') as HTMLSelectElement).value;
    const category = (document.getElementById('campaign-category') as HTMLSelectElement).value;

    if (!confirm('Запустить рассылку?')) return;

    const res = await fetch(`${SUPABASE_URL}/functions/v1/b2b-campaign`, {
      method: 'POST',
      headers: {
        'Authorization': `Bearer ${SUPABASE_KEY}`,
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({ subject, body, city_filter: city, category_filter: category }),
    });

    const result = await res.json();
    if (result.success) {
      alert(`Рассылка запущена! Отправлено: ${result.sent}`);
    } else {
      alert(`Ошибка: ${result.error || 'Не удалось запустить рассылку'}`);
    }

    closeModal('modal-campaign');
    loadCampaigns();
  });

  // Load campaigns
  async function loadCampaigns() {
    const res = await fetch(`${SUPABASE_URL}/rest/v1/b2b_campaigns?select=*&order=created_at.desc`, {
      headers: { 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${SUPABASE_KEY}` },
    });

    const campaigns = await res.json();
    const list = document.getElementById('campaigns-list')!;
    (document.getElementById('campaigns-count') as HTMLElement).textContent = `${campaigns.length} рассылок`;

    if (campaigns.length === 0) {
      list.innerHTML = `<div class="empty-state"><p>Нет рассылок. Создайте первую.</p></div>`;
      return;
    }

    list.innerHTML = campaigns.map((c: any) => `
      <div class="campaign-card">
        <div class="campaign-card-header">
          <h3>${c.subject}</h3>
          <span class="campaign-status ${c.status}">${c.status === 'draft' ? 'Черновик' : c.status === 'sent' ? 'Отправлено' : 'Отправка...'}</span>
        </div>
        <div class="campaign-meta">
          ${c.city_filter ? `Город: ${c.city_filter}` : 'Все города'} ${c.category_filter ? `| Категория: ${c.category_filter}` : ''}
          ${c.sent_at ? `| Отправлено: ${new Date(c.sent_at).toLocaleDateString('ru-RU')}` : ''}
        </div>
        <div class="campaign-stats">
          <div class="campaign-stat">
            <span class="campaign-stat-value">${c.total_sent}</span>
            <span class="campaign-stat-label">Отправлено</span>
          </div>
          <div class="campaign-stat">
            <span class="campaign-stat-value">${c.total_opened}</span>
            <span class="campaign-stat-label">Открыто</span>
          </div>
          <div class="campaign-stat">
            <span class="campaign-stat-value">${c.total_clicked}</span>
            <span class="campaign-stat-label">Кликов</span>
          </div>
          <div class="campaign-stat">
            <span class="campaign-stat-value">${c.total_bounced}</span>
            <span class="campaign-stat-label">Недоставлено</span>
          </div>
        </div>
      </div>
    `).join('');
  }

  // Templates
  const TEMPLATES: Record<string, { subject: string; body: string }> = {
    maintenance: {
      subject: 'Обслуживание бытовой техники для вашего предприятия',
      body: `Уважаемые коллеги!

Мастерская Master-Tehniki74 предлагает договор на регулярное обслуживание бытовой техники для вашего предприятия.

Что входит в обслуживание:
— Плановая диагностика холодильников, стиральных машин, электроплит
— Чистка фильтров, замена изношенных уплотнителей
— Мелкий ремонт без дополнительной оплаты
— Срочный выезд мастера при аварийной поломке (в течение 2 часов)

Тарифы:
— Абонентское обслуживание от 5 000 руб/мес (до 10 единиц техники)
— Полное обслуживание от 12 000 руб/мес (неограниченное количество)

Работаем по безналу (с НДС и без НДС). Полный пакет документов: договор, акт, счёт.

Звоните: 8 (951) 257-77-57
Пишите: https://t.me/Drugan1900

С уважением,
команда Master-Tehniki74`,
    },
    repair: {
      subject: 'Ремонт бытовой техники со скидкой 15% для юрлиц',
      body: `Уважаемые партнёры!

Master-Tehniki74 — ремонт бытовой техники в Миассе, Златоусте и Чебаркуле. Мы работаем с юридическими лицами и предлагаем скидку 15% на все виды ремонта.

Ремонтируем:
— Холодильники (от 2 000 руб)
— Стиральные машины (от 1 200 руб)
— Электроплиты и варочные панели (от 800 руб)
— Микроволновки (от 500 руб)
— Пылесосы (от 600 руб)

Преимущества работы с нами:
— Выезд мастера в день обращения
— Гарантия до 12 месяцев
— Работа по безналу
— Полный пакет документов

Для получения скидки 15% упомяните это письмо при обращении.

Звоните: 8 (951) 257-77-57
Пишите: https://t.me/Drugan1900

С уважением,
команда Master-Tehniki74`,
    },
    seasonal: {
      subject: 'Сезонная диагностика холодильников и техники',
      body: `Уважаемые коллеги!

Перед началом сезона предлагаем провести диагностику и профилактическое обслуживание бытовой техники на вашем предприятии.

Почему это важно:
— Профилактика в 5 раз дешевле аварийного ремонта
— Своевременная замена изношенных деталей предотвращает поломки
— Чистая техника работает эффективнее и экономит электроэнергию

Что мы проверяем:
— Герметичность холодильных камер и уплотнителей
— Состояние компрессоров и термостатов
— Нагревательные элементы плит и духовок
— Сливные системы стиральных машин
— Фильтры и щётки пылесосов

Стоимость диагностики: бесплатно при заказе обслуживания.

Звоните: 8 (951) 257-77-57
Пишите: https://t.me/Drugan1900

С уважением,
команда Master-Tehniki74`,
    },
    custom: {
      subject: '',
      body: '',
    },
  };

  document.querySelectorAll('.template-use').forEach(btn => {
    btn.addEventListener('click', () => {
      const key = (btn.closest('.template-card') as HTMLElement).dataset.template!;
      const tpl = TEMPLATES[key];
      openCampaignModal();
      (document.getElementById('campaign-subject') as HTMLInputElement).value = tpl.subject;
      (document.getElementById('campaign-body') as HTMLTextAreaElement).value = tpl.body;
    });
  });

  // Import CSV
  document.getElementById('btn-import')!.addEventListener('click', () => openModal('modal-import'));
  document.getElementById('close-import-modal')!.addEventListener('click', () => closeModal('modal-import'));
  document.getElementById('cancel-import')!.addEventListener('click', () => closeModal('modal-import'));

  let importData: any[] = [];

  document.getElementById('csv-file')!.addEventListener('change', (e) => {
    const file = (e.target as HTMLInputElement).files?.[0];
    if (!file) return;

    const reader = new FileReader();
    reader.onload = (ev) => {
      const text = ev.target?.result as string;
      const lines = text.split('\n').filter(l => l.trim());
      if (lines.length < 2) return;

      const headers = lines[0].split(',').map(h => h.trim().toLowerCase());
      importData = [];

      for (let i = 1; i < lines.length; i++) {
        const values = lines[i].split(',').map(v => v.trim());
        const obj: any = {};
        headers.forEach((h, idx) => {
          if (['company_name', 'inn', 'email', 'phone', 'city', 'category', 'contact_person'].includes(h)) {
            obj[h] = values[idx] || '';
          }
        });
        if (obj.email && obj.company_name) {
          obj.status = 'active';
          importData.push(obj);
        }
      }

      (document.getElementById('import-preview') as HTMLElement).style.display = 'block';
      (document.getElementById('import-count') as HTMLElement).textContent = String(importData.length);
      (document.getElementById('do-import') as HTMLButtonElement).disabled = importData.length === 0;
    };
    reader.readAsText(file);
  });

  document.getElementById('do-import')!.addEventListener('click', async () => {
    if (importData.length === 0) return;

    await fetch(`${SUPABASE_URL}/rest/v1/b2b_contacts`, {
      method: 'POST',
      headers: {
        'apikey': SUPABASE_KEY,
        'Authorization': `Bearer ${SUPABASE_KEY}`,
        'Content-Type': 'application/json',
        'Prefer': 'return=minimal',
      },
      body: JSON.stringify(importData),
    });

    alert(`Импортировано ${importData.length} контактов`);
    importData = [];
    closeModal('modal-import');
    loadContacts();
  });

  // Filters
  document.getElementById('city-filter')!.addEventListener('change', loadContacts);
  document.getElementById('category-filter')!.addEventListener('change', loadContacts);

  // Init
  loadContacts();
  loadCampaigns();
</script>
</Layout>
