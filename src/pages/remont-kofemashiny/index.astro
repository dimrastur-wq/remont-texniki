const problems = [
  { problem: 'Кофемашина не варит кофе', cause: 'Засор заварочного блока, поломка помпы, накипь на термоблоке', price: 'от 1 500 ₽' },
  { problem: 'Не взбивает молоко / нет пара', cause: 'Засор капучинатора, поломка парового клапана', price: 'от 1 200 ₽' },
  { problem: 'Кофе холодный или тёплый', cause: 'Неисправность термоблока, сильная накипь на ТЭНе', price: 'от 2 000 ₽' },
  { problem: 'Течёт вода снизу или сбоку', cause: 'Износ прокладок, трещина в трубках, лопнул шланг', price: 'от 1 000 ₽' },
  { problem: 'Горький или водянистый кофе', cause: 'Износ жерновов, сбой настроек помола, загрязнение тракта', price: 'от 1 800 ₽' },
  { problem: 'Кофемашина не включается', cause: 'Неисправность платы управления, сбой питания, перегрев', price: 'от 2 500 ₽' },
  { problem: 'Слабый напор кофе', cause: 'Засор кофепровода, износ помпы, накипь в термоблоке', price: 'от 1 500 ₽' },
  { problem: 'Ошибка на дисплее (CALC, CLEAN, ERROR)', cause: 'Требуется декальцинация, чистка, или неисправность датчика', price: 'от 1 500 ₽' },
  { problem: 'Не перемалывает зёрна', cause: 'Засор жерновов, износ, посторонний предмет в бункере', price: 'от 1 200 ₽' },
  { problem: 'Кофемашина шумит громче обычного', cause: 'Износ помпы, засор трубок, проблема с жерновами', price: 'от 1 200 ₽' },
];

const faqItems = [
  { question: 'Кофемашина не варит кофе — с чего начать?', answer: 'Первый шаг — достать и промыть заварочный блок (если машина разборная). Если блок чистый, но кофе не идёт — засорена помпа или термоблок покрыт накипью. Диагностика бесплатная при заказе ремонта. Чаще всего достаточно профессиональной чистки (от 1 500 руб).' },
  { question: 'Стоит ли ремонтировать кофемашину или купить новую?', answer: "Если машине менее 7 лет и это De'Longhi, Philips, Jura, Bosch или Siemens — ремонт почти всегда выгоднее. Новая автоматическая кофемашина стоит от 15 000 ₽, а ремонт в 90% случаев — от 1 500 до 5 000 ₽. Мастер честно скажет, стоит ли ремонтировать конкретную модель." },
  { question: 'Что включает в себя техническое обслуживание кофемашины?', answer: 'Стандартное ТО: промывка заварочного блока, декальцинация термоблока и бойлера, чистка капучинатора и паровой трубки, замена прокладок при необходимости, калибровка жерновов. Занимает 30–60 минут. Стоимость от 1 500 руб.' },
  { question: 'Как часто нужно обслуживать кофемашину?', answer: 'При ежедневном использовании — раз в 3–4 месяца. При использовании 1–2 раза в неделю — раз в 6 месяцев. Вода в Миассе и Златоусте жёсткая, поэтому декальцинация особенно важна — накипь быстро убивает термоблок.' },
  { question: 'Можно ли отремонтировать кофемашину на дому?', answer: 'Да, большинство ремонтов и всё техническое обслуживание выполняем с выездом на дом или в офис. Не нужно везти машину в мастерскую. Мастер приедет со всем необходимым инструментом и запчастями.' },
  { question: 'Кофе стал горьким или водянистым — это поломка?', answer: 'Часто это не поломка, а износ жерновов или неправильные настройки помола. Мастер отрегулирует степень помола и давление прессования. Если жернова стёрлись — замена от 1 800 руб. Без ремонта качество кофе будет продолжать ухудшаться.' },
];

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Ремонт и обслуживание кофемашин",
  "description": "Профессиональный ремонт и техническое обслуживание кофемашин всех брендов с выездом на дом в Миассе, Златоусте и Чебаркуле. De'Longhi, Philips, Jura, Bosch, Saeco, Melitta и другие.",
  "provider": {
    "@type": "LocalBusiness",
    "name": SITE.name,
    "telephone": SITE.phone,
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "ул. Победы, д. 18, цоколь",
      "addressLocality": "Миасс",
      "addressRegion": "Челябинская область",
    },
    "openingHours": "Mo-Su 09:00-20:00",
    "url": SITE.url,
  },
  "areaServed": [
    { "@type": "City", "name": "Миасс" },
    { "@type": "City", "name": "Златоуст" },
    { "@type": "City", "name": "Чебаркуль" },
  ],
  "serviceType": "Ремонт кофемашин",
  "offers": {
    "@type": "AggregateOffer",
    "priceCurrency": "RUB",
    "lowPrice": "1000",
    "offerCount": "10",
  },
});

const breadcrumbSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Главная", "item": SITE.url },
    { "@type": "ListItem", "position": 2, "name": "Ремонт кофемашин", "item": `${SITE.url}/remont-kofemashiny/` },
  ],
});

const popularBrands = brands.filter(b => b.popular);
const otherBrands = brands.filter(b => !b.popular);
---

<Layout
  title="Ремонт и обслуживание кофемашин в Миассе, Златоусте, Чебаркуле — все бренды | Центр восстановления бытовой техники"
  description="Ремонт кофемашин De'Longhi, Philips, Jura, Bosch, Saeco, Melitta, Nespresso и других брендов. Выезд на дом, декальцинация, замена заварочного блока, жерновов. Гарантия 12 месяцев. Звоните: 8 (951) 257-77-57"
  keywords="ремонт кофемашин миасс, ремонт кофемашины delonghi, обслуживание кофемашины jura, чистка кофемашины philips, декальцинация кофемашины, ремонт кофемашин миасс цена"
  canonical="/remont-kofemashiny/"
  schema={`[${schema},${breadcrumbSchema}]`}
  geoRegion="RU-CHE"
  geoPlace="Миасс"
>
  <SiteHeader />
  <FloatingButton />

  <main>
    <!-- Hero -->
    <section class="hero">
      <div class="hero-bg">
        <div class="hero-pattern"></div>
      </div>
      <div class="container hero-inner">
        <div class="hero-text">
          <nav class="breadcrumbs" aria-label="Навигация">
            <a href="/">Главная</a>
            <span>/</span>
            <span>Ремонт кофемашин</span>
          </nav>
          <span class="hero-badge">Все бренды · Выезд на дом</span>
          <h1>Ремонт и обслуживание<br />кофемашин</h1>
          <p class="hero-sub">
            De'Longhi, Philips, Jura, Bosch, Saeco, Melitta, Nespresso и 10+ других брендов.
            Выезд мастера в Миасс, Златоуст и Чебаркуль — в день обращения. Гарантия до 12 месяцев.
          </p>
          <TelegramButtons context="Здравствуйте! Нужен ремонт или обслуживание кофемашины." />
          <div class="hero-badges">
            <span class="hb">Диагностика бесплатно</span>
            <span class="hb">Гарантия 12 мес</span>
            <span class="hb">Запчасти в наличии</span>
          </div>
        </div>
        <div class="hero-card">
          <div class="hero-card-head">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#1d4ed8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/></svg>
            <span>Кофемашины</span>
          </div>
          <div class="hero-price-list">
            <div class="hp-row">
              <span>Диагностика</span>
              <span class="hp-price green">Бесплатно</span>
            </div>
            <div class="hp-row">
              <span>ТО и чистка</span>
              <span class="hp-price">от 1 500 ₽</span>
            </div>
            <div class="hp-row">
              <span>Ремонт помпы</span>
              <span class="hp-price">от 1 500 ₽</span>
            </div>
            <div class="hp-row">
              <span>Замена термоблока</span>
              <span class="hp-price">от 2 500 ₽</span>
            </div>
            <div class="hp-row">
              <span>Замена жерновов</span>
              <span class="hp-price">от 1 800 ₽</span>
            </div>
            <div class="hp-row">
              <span>Ремонт платы</span>
              <span class="hp-price">от 2 500 ₽</span>
            </div>
          </div>
          <a href={`tel:+${SITE.phoneRaw}`} class="hero-phone">{SITE.phone}</a>
        </div>
      </div>
    </section>

    <!-- Services -->
    <section class="section section--white">
      <div class="container">
        <div class="section-header">
          <span class="section-label">Что мы делаем</span>
          <h2>Ремонт и обслуживание кофемашин</h2>
          <p>Полный цикл — от диагностики до гарантийного обслуживания</p>
        </div>
        <div class="services-grid">
          {services.map(s => (
            <div class="service-card">
              <div class="service-icon" set:html={s.icon} />
              <div class="service-body">
                <h3>{s.title}</h3>
                <p>{s.desc}</p>
              </div>
              <div class="service-price">{s.price}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Problems table -->
    <section class="section section--gray">
      <div class="container">
        <div class="section-header">
          <span class="section-label">Цены</span>
          <h2>Частые неисправности и стоимость ремонта</h2>
          <p>Ориентировочные цены. Точную стоимость мастер назовёт после диагностики.</p>
        </div>
        <div class="table-wrap">
          <table class="price-table">
            <thead>
              <tr>
                <th>Неисправность</th>
                <th>Причина</th>
                <th>Стоимость</th>
              </tr>
            </thead>
            <tbody>
              {problems.map(p => (
                <tr>
                  <td>{p.problem}</td>
                  <td class="cause">{p.cause}</td>
                  <td class="price">{p.price}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <p class="table-note">* Цены ориентировочные. Диагностика — бесплатно при заказе ремонта.</p>
      </div>
    </section>

    <!-- Popular brands -->
    <section class="section section--white">
      <div class="container">
        <div class="section-header">
          <span class="section-label">Бренды</span>
          <h2>Популярные марки кофемашин</h2>
          <p>Работаем со всеми брендами, представленными на российском рынке</p>
        </div>
