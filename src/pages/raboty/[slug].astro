---
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import FloatingButton from '../../components/FloatingButton.astro';
import TelegramButtons from '../../components/TelegramButtons.astro';
import FAQ from '../../components/FAQ.astro';
import { SITE, CITIES, SERVICES } from '../../data/services';
import { SEO_WORKS, SERVICE_BRANDS } from '../../data/seo-pages';

export function getStaticPaths() {
  return SEO_WORKS.map(work => ({
    params: { slug: work.slug },
    props: { work },
  }));
}

const { work } = Astro.props as { work: typeof SEO_WORKS[0] };

const title = `${work.name} в Миассе, Златоусте, Чебаркуле — цена от ${work.priceFrom.toLocaleString()} ₽`;
const description = `${work.description.slice(0, 150)} Выезд мастера, гарантия 12 месяцев.`;

const howToSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": work.name,
  "description": work.description,
  "totalTime": work.time,
  "estimatedCost": { "@type": "MonetaryAmount", "currency": "RUB", "value": work.priceFrom },
  "step": work.steps.map((s, i) => ({ "@type": "HowToStep", "position": i + 1, "name": s.step, "text": s.detail })),
});

const faqSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": work.faq.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })),
});
---

<Layout title={title} description={description} keywords={work.keywords.join(', ')} schema={`[${howToSchema},${faqSchema}]`}>
  <SiteHeader />
  <FloatingButton />

  <main class="work-page">
    <section class="hero-work">
      <div class="container">
        <Breadcrumbs items={[
          { label: 'Главная', href: '/' },
          { label: 'Работы', href: '/raboty/' },
          { label: work.name },
        ]} />

        <div class="hero-work-grid">
          <div class="hero-work-text">
            <h1>{work.name}</h1>
            <p class="hero-desc">{work.description}</p>
            <div class="work-badges">
              <span class="wb-price">от {work.priceFrom.toLocaleString()} ₽</span>
              <span class="wb-time">{work.time}</span>
              <span class="wb-garant">Гарантия 12 мес</span>
            </div>
            <TelegramButtons context={`Здравствуйте! Нужна услуга: ${work.name}.`} />
          </div>
          <div class="hero-work-cta">
            <a href={`tel:+${SITE.phoneRaw}`} class="cta-phone-btn">Позвонить</a>
            <p class="cta-note">Ответим за 10 минут</p>
          </div>
        </div>
      </div>
    </section>

    <section class="signs-section">
      <div class="container">
        <h2>Признаки, когда нужен {work.name.toLowerCase()}</h2>
        <div class="signs-grid">
          {work.signs.map(sign => (
            <div class="sign-item">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              <span>{sign}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="steps-section">
      <div class="container">
        <h2>Как выполняем {work.name.toLowerCase()}</h2>
        <div class="steps-list">
          {work.steps.map((s, i) => (
            <div class="step-item">
              <div class="step-num">{i + 1}</div>
              <div class="step-content">
                <h3>{s.step}</h3>
                <p>{s.detail}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="appliances-section">
      <div class="container">
        <h2>Для какой техники подходит</h2>
        <div class="appliances-tags">
          {work.appliances.map(a => <span class="app-tag">{a}</span>)}
        </div>
      </div>
    </section>

    <section class="faq-work">
      <div class="container">
        <h2>Вопросы о {work.name.toLowerCase()}</h2>
        <FAQ items={work.faq.map(f => ({ q: f.q, a: f.a }))} />
      </div>
    </section>

    <section class="cta-final">
      <div class="container">
        <div class="cta-content">
          <h2>Нужен {work.name.toLowerCase()}?</h2>
          <p>Выезд мастера в течение 1-2 часов.</p>
          <a href={`tel:+${SITE.phoneRaw}`} class="cta-phone">{SITE.phone}</a>
        </div>
      </div>
    </section>

    <section class="other-works">
      <div class="container">
        <h2>Другие виды работ</h2>
        <div class="works-grid">
          {SEO_WORKS.filter(w => w.slug !== work.slug).slice(0, 6).map(w => (
            <a href={`/raboty/${w.slug}/`} class="work-link">
              <h3>{w.name}</h3>
              <span>от {w.priceFrom.toLocaleString()} ₽</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />
</Layout>

<style>
  .work-page { background: #f8fafc; }
  .hero-work { padding: 100px 0 60px; background: #fff; }
  .hero-work-grid { display: grid; grid-template-columns: 1fr 240px; gap: 48px; align-items: start; }
  .hero-work h1 { font-size: 2rem; font-weight: 800; color: #0f172a; margin-bottom: 16px; line-height: 1.25; }
  .hero-desc { font-size: 1.1rem; color: #475569; line-height: 1.7; margin-bottom: 24px; }
  .work-badges { display: flex; flex-wrap: wrap; gap: 12px; margin-bottom: 24px; }
  .wb-price { padding: 8px 16px; background: #1d4ed8; color: #fff; border-radius: 8px; font-weight: 700; }
  .wb-time { padding: 8px 16px; background: #f1f5f9; color: #475569; border-radius: 8px; font-weight: 600; }
  .wb-garant { padding: 8px 16px; background: #dcfce7; color: #166534; border-radius: 8px; font-weight: 600; }
  .cta-phone-btn { display: block; text-align: center; padding: 16px; background: #1d4ed8; color: #fff; border-radius: 12px; font-weight: 600; }
  .cta-note { text-align: center; font-size: 0.85rem; color: #64748b; margin-top: 8px; }
  .signs-section { padding: 64px 0; background: #f8fafc; }
  .signs-section h2 { font-size: 1.5rem; font-weight: 700; color: #0f172a; margin-bottom: 24px; text-align: center; }
  .signs-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; max-width: 800px; margin: 0 auto; }
  .sign-item { display: flex; align-items: center; gap: 10px; padding: 16px 20px; background: #fff; border: 1px solid #e2e8f0; border-radius: 12px; }
  .sign-item svg { color: #dc2626; flex-shrink: 0; }
  .steps-section { padding: 64px 0; background: #fff; }
  .steps-section h2 { font-size: 1.5rem; font-weight: 700; color: #0f172a; margin-bottom: 32px; text-align: center; }
  .steps-list { max-width: 700px; margin: 0 auto; }
  .step-item { display: flex; gap: 20px; margin-bottom: 20px; }
  .step-num { width: 44px; height: 44px; background: #1d4ed8; color: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 800; flex-shrink: 0; }
  .step-content h3 { font-size: 1.1rem; font-weight: 600; color: #0f172a; margin-bottom: 4px; }
  .step-content p { font-size: 0.95rem; color: #64748b; }
  .appliances-section { padding: 64px 0; background: #f8fafc; }
  .appliances-section h2 { font-size: 1.5rem; font-weight: 700; color: #0f172a; margin-bottom: 20px; text-align: center; }
  .appliances-tags { display: flex; flex-wrap: wrap; gap: 10px; justify-content: center; }
  .app-tag { padding: 10px 20px; background: #fff; border: 1px solid #1d4ed8; color: #1d4ed8; border-radius: 100px; font-weight: 600; }
  .faq-work { padding: 64px 0; background: #fff; }
  .faq-work h2 { font-size: 1.5rem; font-weight: 700; color: #0f172a; margin-bottom: 20px; text-align: center; }
  .cta-final { padding: 80px 0; background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 100%); }
  .cta-content { text-align: center; }
  .cta-final h2 { font-size: 1.8rem; font-weight: 700; color: #fff; margin-bottom: 10px; }
  .cta-final p { color: #94a3b8; margin-bottom: 24px; }
  .cta-phone { font-size: 1.6rem; font-weight: 800; color: #fff; }
  .other-works { padding: 64px 0; background: #f8fafc; }
  .other-works h2 { font-size: 1.5rem; font-weight: 700; color: #0f172a; margin-bottom: 20px; text-align: center; }
  .works-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; max-width: 900px; margin: 0 auto; }
  .work-link { padding: 20px; background: #fff; border: 1px solid #e2e8f0; border-radius: 12px; }
  .work-link h3 { font-size: 0.95rem; font-weight: 600; color: #0f172a; margin-bottom: 6px; }
  .work-link span { font-size: 0.85rem; color: #1d4ed8; font-weight: 600; }
  @media (max-width: 768px) { .hero-work-grid { grid-template-columns: 1fr; } .signs-grid { grid-template-columns: 1fr; } .works-grid { grid-template-columns: 1fr; } }
</style>
