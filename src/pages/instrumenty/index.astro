window.generateAct = () => {
  const v = id => (document.getElementById(id)?.value || '').trim();
  const parts = parseFloat(v('g-parts')) || 0;
  const labor = parseFloat(v('g-labor')) || 0;
  const total = parts + labor;

  const w = window.open('', '_blank');
  w.document.write(`<!DOCTYPE html><html lang="ru"><head><meta charset="UTF-8"><title>Акт</title>
    <style>
      body{font-family:Arial,sans-serif;font-size:13px;padding:30px;color:#000;max-width:800px;margin:0 auto}
      table{width:100%;border-collapse:collapse}
      th,td{border:1px solid #000;padding:7px 10px;text-align:left}
      th{background:#f3f4f6}
      .total{font-weight:bold;font-size:15px}
      @media print{@page{margin:20mm}}
    </style></head><body>
    <h2 style="text-align:center">Акт выполненных работ № _____ от ${today}</h2>
    <p><strong>Мастер:</strong> ${v('g-master') || '___________________________'}</p>
