        <tr><th>Дата ремонта</th><td>&nbsp;</td></tr>
        <tr><th>Техника (марка/модель)</th><td>&nbsp;</td></tr>
        <tr><th>Серийный номер</th><td>&nbsp;</td></tr>
      </table>
      <h2>Выполненные работы</h2>
      <table><tr><td style="height:80px">&nbsp;</td></tr></table>
