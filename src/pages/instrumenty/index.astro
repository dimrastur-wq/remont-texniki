      <tr><td>Работы</td><td>${labor.toLocaleString('ru-RU')} ₽</td></tr>
      <tr class="total"><td>Итого</td><td>${total.toLocaleString('ru-RU')} ₽</td></tr>
    </table>
    ${v('g-warranty') ? `<p style="margin-top:12px">Гарантия на выполненные работы: <strong>${v('g-warranty')} мес.</strong></p>` : ''}
