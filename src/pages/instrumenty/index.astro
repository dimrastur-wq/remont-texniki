    `, 'Гарантийный талон'),

    dogovor: () => printBase(`
      <h1>ДОГОВОР НА РЕМОНТ БЫТОВОЙ ТЕХНИКИ</h1>
      <p class="sub">г. Миасс &nbsp;&nbsp;•&nbsp;&nbsp; «___» ____________ 20___ г.</p>
      <div class="parties">
        <div class="party-block"><div class="party-label">Исполнитель</div>${company}, г. Миасс, ул. Победы, д. 18, именуемый далее «Исполнитель».</div>
        <div class="party-block"><div class="party-label">Заказчик</div>Гр. ___________________________, тел. ___________________________, именуемый далее «Заказчик».</div>
      </div>
      <p>Стороны заключили настоящий договор о нижеследующем:</p>
      <h2>1. Предмет договора</h2>
      <p style="font-size:12px;margin-bottom:10px">1.1. Исполнитель принимает на себя обязательство выполнить ремонт бытовой техники: <u>________________________________________________</u>, а Заказчик обязуется принять и оплатить работу.</p>
      <p style="font-size:12px;margin-bottom:6px">1.2. Неисправность: _____________________________________________________</p>
      <h2>2. Стоимость и порядок оплаты</h2>
      <p style="font-size:12px;margin-bottom:6px">2.1. Стоимость работ: _______________________ руб. Стоимость запчастей: _______________________ руб. <strong>Итого: _______________________ руб.</strong></p>
      <p style="font-size:12px;margin-bottom:10px">2.2. Оплата производится наличными или переводом после выполнения ремонта.</p>
      <h2>3. Сроки выполнения</h2>
      <p style="font-size:12px;margin-bottom:10px">3.1. Срок выполнения ремонта: с «___» _______ по «___» _______ 20___ г.</p>
      <h2>4. Гарантийные обязательства</h2>
      <p style="font-size:12px;margin-bottom:10px">4.1. Исполнитель предоставляет гарантию на выполненные работы и установленные запчасти сроком <strong>___________ месяцев</strong> со дня сдачи техники Заказчику.</p>
      <p style="font-size:12px;margin-bottom:10px">4.2. Гарантия не распространяется на механические повреждения и дефекты, возникшие по вине Заказчика.</p>
      <h2>5. Права и обязанности сторон</h2>
      <p style="font-size:12px;margin-bottom:6px">5.1. Исполнитель вправе использовать запчасти, аналогичные по качеству оригинальным, если иное не согласовано сторонами.</p>
      <p style="font-size:12px;margin-bottom:10px">5.2. Заказчик обязан сообщать достоверные сведения о технике и характере неисправности.</p>
      <div class="sigs">
        <div><div class="party-label" style="margin-bottom:8px">Исполнитель</div><div class="stamp">М.П.</div><div class="sig-line">_________________ / ${company}</div></div>
        <div><div class="party-label" style="margin-bottom:8px">Заказчик</div><div style="height:90px"></div><div class="sig-line">___________________ / _______________</div></div>
      </div>
    `, 'Договор на ремонт'),
  };

  document.querySelectorAll<HTMLButtonElement>('.tmpl-print-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const tmpl = btn.dataset.template!;
      if (templates[tmpl]) templates[tmpl]();
    });
  });

  // ── Generator ────────────────────────────────────────────────
  // Set default date
  const dateInput = document.getElementById('act-date') as HTMLInputElement;
  if (dateInput) dateInput.value = new Date().toISOString().split('T')[0];

  // Auto-calculate total
  function recalcTotal() {
    const labor = parseFloat((document.getElementById('labor-cost') as HTMLInputElement).value) || 0;
    let partsTotal = 0;
    document.querySelectorAll<HTMLElement>('.parts-row').forEach(row => {
      const qty = parseFloat((row.querySelector('.part-qty') as HTMLInputElement)?.value) || 0;
      const price = parseFloat((row.querySelector('.part-price') as HTMLInputElement)?.value) || 0;
      partsTotal += qty * price;
    });
    const total = labor + partsTotal;
    const display = document.getElementById('total-display') as HTMLInputElement;
    if (display) display.value = total > 0 ? total.toLocaleString('ru-RU') + ' ₽' : '';
  }

  document.getElementById('labor-cost')?.addEventListener('input', recalcTotal);

  // Add part row
  document.getElementById('add-part')?.addEventListener('click', () => {
    const list = document.getElementById('parts-list')!;
    const row = document.createElement('div');
    row.className = 'parts-row';
    row.innerHTML = `<input type="text" placeholder="Название запчасти" class="part-name" /><input type="number" placeholder="Кол-во" class="part-qty" value="1" min="1" /><input type="number" placeholder="Цена ₽" class="part-price" min="0" /><button type="button" class="part-remove" title="Удалить">✕</button>`;
    row.querySelector('.part-remove')?.addEventListener('click', () => { row.remove(); recalcTotal(); });
    row.querySelectorAll('input').forEach(i => i.addEventListener('input', recalcTotal));
    list.appendChild(row);
  });

  // Wire remove on first row
  document.querySelector('.part-remove')?.addEventListener('click', function(this: HTMLElement) {
    this.closest('.parts-row')?.remove();
    recalcTotal();
  });
  document.querySelectorAll('.parts-row input').forEach(i => i.addEventListener('input', recalcTotal));

  // Generate act
  document.getElementById('act-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const g = (id: string) => (document.getElementById(id) as HTMLInputElement)?.value || '';

    const actNum = g('act-num');
    const actDate = new Date(g('act-date')).toLocaleDateString('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' });
    const clientName = g('client-name');
    const clientPhone = g('client-phone');
    const clientCity = g('client-city');
    const clientAddr = g('client-addr');
    const appType = g('app-type');
    const appBrand = g('app-brand');
    const appSerial = g('app-serial');
    const faultDesc = g('fault-desc');
    const workDone = g('work-done');
    const laborCost = parseFloat(g('labor-cost')) || 0;
    const warranty = g('warranty-period');
    const masterName = g('master-name');

    // Collect parts
    const partsRows: { name: string; qty: number; price: number }[] = [];
    let partsTotalCost = 0;
    document.querySelectorAll<HTMLElement>('.parts-row').forEach(row => {
      const name = (row.querySelector('.part-name') as HTMLInputElement)?.value?.trim();
      const qty = parseFloat((row.querySelector('.part-qty') as HTMLInputElement)?.value) || 0;
      const price = parseFloat((row.querySelector('.part-price') as HTMLInputElement)?.value) || 0;
      if (name) {
        partsRows.push({ name, qty, price });
        partsTotalCost += qty * price;
      }
    });
    const totalCost = laborCost + partsTotalCost;

    const partsHtml = partsRows.length > 0
      ? partsRows.map(p => `<tr><td>${p.name}</td><td style="text-align:center">${p.qty}</td><td style="text-align:right">${(p.qty * p.price).toLocaleString('ru-RU')} ₽</td></tr>`).join('')
      : '<tr><td colspan="3" style="color:#999;text-align:center">—</td></tr>';

    printBase(`
      <h1>АКТ ВЫПОЛНЕННЫХ РАБОТ № ${actNum}</h1>
      <p class="sub">${company} · ${companyAddr} · ${companyPhone}</p>
      <div class="parties">
        <div class="party-block"><div class="party-label">Исполнитель</div>${company}<br>${companyAddr}<br>Тел: ${companyPhone}</div>
        <div class="party-block"><div class="party-label">Заказчик</div>${clientName}<br>Тел: ${clientPhone}<br>${clientCity}${clientAddr ? ', ' + clientAddr : ''}</div>
      </div>
      <table style="margin-bottom:20px">
        <tr><th colspan="2" style="background:#f5f5f5;text-align:center">Дата: ${actDate}</th></tr>
        <tr><th style="width:200px">Тип техники</th><td>${appType}</td></tr>
        <tr><th>Марка / Модель</th><td>${appBrand}</td></tr>
        ${appSerial ? `<tr><th>Серийный номер</th><td>${appSerial}</td></tr>` : ''}
        <tr><th>Неисправность</th><td>${faultDesc}</td></tr>
        <tr><th>Выполненные работы</th><td>${workDone}</td></tr>
      </table>
      <h2>Запчасти и материалы</h2>
      <table>
        <tr><th>Наименование</th><th style="width:70px;text-align:center">Кол-во</th><th style="width:100px;text-align:right">Стоимость</th></tr>
        ${partsHtml}
      </table>
      <h2>Расчёт стоимости</h2>
      <table>
        <tr><th style="width:200px">Стоимость работ</th><td style="text-align:right">${laborCost.toLocaleString('ru-RU')} ₽</td></tr>
        <tr><th>Стоимость запчастей</th><td style="text-align:right">${partsTotalCost.toLocaleString('ru-RU')} ₽</td></tr>
        <tr><th><strong>ИТОГО к оплате</strong></th><td style="text-align:right"><strong>${totalCost.toLocaleString('ru-RU')} ₽</strong></td></tr>
      </table>
      ${warranty !== 'без гарантии' ? `<p style="margin:14px 0 4px;font-size:12px"><strong>Гарантия:</strong> ${warranty} на выполненные работы и установленные запчасти.</p>` : ''}
      <p style="font-size:11px;color:#555;margin-bottom:4px">Мастер: ${masterName || '—'}</p>
      <p style="font-size:11px;color:#555">Работа выполнена в полном объёме. Заказчик претензий не имеет.</p>
      <div class="sigs">
        <div><div class="stamp">М.П.</div><div class="sig-line">Исполнитель: ___________________</div></div>
        <div><div style="height:90px"></div><div class="sig-line">Заказчик: ______________________</div></div>
      </div>
    `, `Акт выполненных работ № ${actNum}`);
  });
</script>
