<script>
  // ── Tab switching ──────────────────────────────────────────────
  const tabBtns = document.querySelectorAll<HTMLButtonElement>('.tab-btn');
  const tabContents = document.querySelectorAll<HTMLElement>('.tab-content');

  tabBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const target = btn.dataset.tab!;
      tabBtns.forEach(b => b.classList.toggle('active', b.dataset.tab === target));
      tabContents.forEach(tc => {
        const isTarget = tc.id === `tab-${target}`;
        tc.classList.toggle('active', isTarget);
        tc.hidden = !isTarget;
      });
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  });

  // ── Error code filtering ──────────────────────────────────────
  const cards = document.querySelectorAll<HTMLElement>('.error-card');
  const countEl = document.getElementById('errors-count');
  const noResults = document.getElementById('no-results') as HTMLElement;
  const searchInput = document.getElementById('error-search') as HTMLInputElement;
  let activeBrand = 'all';
  let activeAppliance = 'all';
  let searchQuery = '';

  function filterCards() {
    let visible = 0;
    cards.forEach(card => {
      const brandMatch = activeBrand === 'all' || card.dataset.brand === activeBrand;
      const appMatch = activeAppliance === 'all' || card.dataset.appliance === activeAppliance;
      const text = (card.dataset.text || '').toLowerCase();
      const searchMatch = !searchQuery || text.includes(searchQuery.toLowerCase());
      const show = brandMatch && appMatch && searchMatch;
      card.classList.toggle('hidden', !show);
      if (show) visible++;
    });
    if (countEl) countEl.textContent = `Показано: ${visible} кодов`;
    noResults.hidden = visible > 0;
  }

  document.getElementById('brand-chips')?.addEventListener('click', (e) => {
    const chip = (e.target as HTMLElement).closest<HTMLElement>('.chip');
    if (!chip || !chip.dataset.brand) return;
    activeBrand = chip.dataset.brand;
    document.querySelectorAll('#brand-chips .chip').forEach(c => c.classList.toggle('active', c === chip));
    filterCards();
  });

  document.getElementById('appliance-chips')?.addEventListener('click', (e) => {
    const chip = (e.target as HTMLElement).closest<HTMLElement>('.chip');
    if (!chip || !chip.dataset.appliance) return;
    activeAppliance = chip.dataset.appliance;
    document.querySelectorAll('#appliance-chips .chip').forEach(c => c.classList.toggle('active', c === chip));
    filterCards();
  });

  searchInput?.addEventListener('input', () => {
    searchQuery = searchInput.value.trim();
    filterCards();
  });

  document.getElementById('reset-filters')?.addEventListener('click', () => {
    activeBrand = 'all';
    activeAppliance = 'all';
    searchQuery = '';
    searchInput.value = '';
    document.querySelectorAll('#brand-chips .chip').forEach((c, i) => c.classList.toggle('active', i === 0));
    document.querySelectorAll('#appliance-chips .chip').forEach((c, i) => c.classList.toggle('active', i === 0));
    filterCards();
  });

  // ── Error card expand/collapse ────────────────────────────────
  document.querySelectorAll<HTMLButtonElement>('.ec-expand').forEach(btn => {
    btn.addEventListener('click', () => {
      const details = btn.nextElementSibling as HTMLElement;
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      details.hidden = expanded;
      btn.querySelector('span')?.remove();
      btn.childNodes[0].textContent = expanded ? 'Подробнее' : 'Свернуть';
    });
  });

  // ── Print templates ───────────────────────────────────────────
  const today = new Date().toLocaleDateString('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' });
  const company = 'Центр восстановления бытовой техники';
  const companyAddr = 'г. Миасс, ул. Победы, д. 18';
  const companyPhone = '8 (951) 257-77-57';

  const printBase = (content: string, title: string) => {
    const win = window.open('', '_blank', 'width=900,height=700');
    if (!win) return;
    win.document.write(`<!DOCTYPE html><html lang="ru"><head>
      <meta charset="UTF-8"><title>${title}</title>
      <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: Arial, sans-serif; font-size: 13px; color: #000; padding: 24mm 20mm; }
        h1 { font-size: 17px; text-align: center; margin-bottom: 6px; }
        h2 { font-size: 14px; margin: 16px 0 8px; }
        .sub { text-align: center; color: #555; font-size: 12px; margin-bottom: 20px; }
        .parties { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 20px; }
        .party-block { border: 1px solid #ccc; border-radius: 6px; padding: 12px 14px; }
        .party-label { font-size: 11px; font-weight: bold; text-transform: uppercase; color: #777; margin-bottom: 8px; }
        table { width: 100%; border-collapse: collapse; margin-bottom: 16px; }
        td, th { border: 1px solid #ccc; padding: 7px 10px; font-size: 12px; vertical-align: top; }
        th { background: #f5f5f5; font-weight: 600; text-align: left; }
        .sigs { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; margin-top: 40px; }
        .sig-line { border-top: 1px solid #000; padding-top: 6px; font-size: 11px; color: #555; }
        .stamp { border: 2px dashed #ccc; border-radius: 50%; width: 90px; height: 90px; display: flex; align-items: center; justify-content: center; font-size: 11px; color: #aaa; text-align: center; margin: 12px 0; }
        .footer-note { font-size: 11px; color: #777; border-top: 1px solid #eee; padding-top: 12px; margin-top: 20px; }
        @media print { body { padding: 15mm 12mm; } @page { margin: 0; } }
      </style></head><body>${content}<script>window.print();<\/script></body></html>`);
    win.document.close();
  };

  const templates: Record<string, () => void> = {
    priom: () => printBase(`
      <h1>АКТ ПРИЁМА-ПЕРЕДАЧИ ТЕХНИКИ</h1>
      <p class="sub">${company} · ${companyAddr} · ${companyPhone}</p>
