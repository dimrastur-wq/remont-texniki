        <div class="party-block"><div class="party-label">Исполнитель</div>${company}<br>${companyAddr}<br>Тел: ${companyPhone}</div>
        <div class="party-block"><div class="party-label">Заказчик</div>ФИО: ___________________<br>Тел: ___________________<br>Адрес: _________________</div>
      </div>
      <p>Дата приёма: ________________________</p>
      <h2>Сведения о технике</h2>
      <table>
        <tr><th style="width:200px">Параметр</th><th>Значение</th></tr>
        <tr><td>Тип техники</td><td>&nbsp;</td></tr>
        <tr><td>Марка / Модель</td><td>&nbsp;</td></tr>
        <tr><td>Серийный номер</td><td>&nbsp;</td></tr>
        <tr><td>Цвет / внешний вид</td><td>&nbsp;</td></tr>
        <tr><td>Видимые дефекты</td><td>&nbsp;</td></tr>
        <tr><td>Комплектность</td><td>&nbsp;</td></tr>
      </table>
      <h2>Заявленная неисправность</h2>
      <table><tr><td style="height:60px">&nbsp;</td></tr></table>
      <h2>Предварительная стоимость</h2>
      <table><tr><th>Диагностика</th><th>Ориентировочный ремонт</th><th>Срок исполнения</th></tr>
        <tr><td>Бесплатно</td><td>&nbsp;</td><td>&nbsp;</td></tr></table>
      <p style="font-size:12px;color:#555;margin:12px 0">Стороны подтверждают, что техника передана в указанном состоянии, претензий к внешнему виду при приёме не имеется.</p>
      <div class="sigs">
        <div><div class="stamp">М.П.</div><div class="sig-line">Исполнитель: ______________________</div></div>
        <div><div style="height:90px"></div><div class="sig-line">Заказчик: _________________________</div></div>
      </div>
      <p class="footer-note">Срок хранения невостребованной техники — 3 месяца с даты приёма. ${company} не несёт ответственности за данные, хранящиеся на устройстве.</p>
    `, 'Акт приёма-передачи техники'),

    garantiya: () => printBase(`
      <h1>ГАРАНТИЙНЫЙ ТАЛОН</h1>
      <p class="sub">${company} · ${companyPhone}</p>
      <table style="margin-bottom:20px">
        <tr><th style="width:220px">Исполнитель</th><td>${company}, ${companyAddr}</td></tr>
