---
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import { ERROR_CODES, ERROR_BRANDS, ERROR_APPLIANCES } from '../../data/errors';
import { SITE } from '../../data/services';

const urgencyLabel: Record<string, string> = { high: 'Срочно', medium: 'Умеренно', low: 'Несрочно' };
const applianceIcon: Record<string, string> = {
  'стиральная машина': '🫧',
  'холодильник': '🧊',
  'микроволновка': '📡',
  'посудомоечная машина': '🍽️',
  'кофемашина': '☕',
};
---

<Layout
  title="Инструменты мастера — коды ошибок, шаблоны, генератор актов"
  description="База кодов ошибок бытовой техники Bosch, LG, Samsung, Indesit, Whirlpool. Шаблоны актов приёма, гарантийных талонов. Генератор документов для мастеров по ремонту."
  keywords="коды ошибок стиральных машин, ошибки холодильников, шаблон акта приёма техники, гарантийный талон шаблон, генератор акта ремонта"
>
  <SiteHeader />

  <main class="tools-page">

    <!-- Hero -->
    <section class="tools-hero">
      <div class="container">
        <div class="hero-badge">Профессиональный инструментарий</div>
        <h1>Инструменты мастера</h1>
        <p class="hero-sub">База кодов ошибок, шаблоны документов и генератор актов выполненных работ — всё необходимое для профессионального сервиса в одном месте</p>
        <div class="hero-features">
          <div class="hf">
            <div class="hf-icon">🔍</div>
            <div>
              <div class="hf-title">{ERROR_CODES.length}+ кодов ошибок</div>
              <div class="hf-sub">Bosch, LG, Samsung, Indesit и другие</div>
            </div>
          </div>
          <div class="hf">
            <div class="hf-icon">📄</div>
            <div>
              <div class="hf-title">3 шаблона документов</div>
              <div class="hf-sub">Акт, договор, гарантийный талон</div>
            </div>
          </div>
          <div class="hf">
            <div class="hf-icon">🖨️</div>
            <div>
              <div class="hf-title">Генератор акта</div>
              <div class="hf-sub">Заполни форму — получи PDF</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Sticky tabs -->
    <div class="tabs-bar" id="tabs-bar">
      <div class="container">
        <div class="tabs-nav">
          <button class="tab-btn active" data-tab="errors">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            Коды ошибок
          </button>
          <button class="tab-btn" data-tab="templates">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
            Шаблоны документов
          </button>
          <button class="tab-btn" data-tab="generator">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2"/><line x1="8" y1="6" x2="16" y2="6"/><line x1="8" y1="10" x2="10" y2="10"/><line x1="14" y1="10" x2="16" y2="10"/><line x1="8" y1="14" x2="10" y2="14"/><line x1="14" y1="14" x2="16" y2="14"/></svg>
            Генератор акта
          </button>
        </div>
      </div>
    </div>

    <!-- ─── TAB 1: Error Codes ─── -->
    <div class="tab-content active" id="tab-errors">
      <div class="container">
        <div class="filter-bar">
          <div class="filter-search-wrap">
            <svg class="search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input type="text" id="error-search" placeholder="Поиск по коду, бренду или описанию..." class="filter-search" />
          </div>
          <div class="filter-row">
            <div class="filter-group">
              <span class="filter-label">Бренд:</span>
              <div class="filter-chips" id="brand-chips">
                <button class="chip active" data-brand="all">Все</button>
                {ERROR_BRANDS.map(b => (
                  <button class="chip" data-brand={b}>{b}</button>
                ))}
              </div>
            </div>
            <div class="filter-group">
              <span class="filter-label">Техника:</span>
              <div class="filter-chips" id="appliance-chips">
                <button class="chip active" data-appliance="all">Все</button>
                {ERROR_APPLIANCES.map(a => (
                  <button class="chip" data-appliance={a}>{a}</button>
                ))}
              </div>
            </div>
          </div>
        </div>

        <div class="errors-count" id="errors-count">Показано: {ERROR_CODES.length} кодов</div>

        <div class="errors-grid" id="errors-grid">
          {ERROR_CODES.map(err => (
            <div
              class="error-card"
              data-brand={err.brand}
              data-appliance={err.appliance}
              data-text={`${err.code} ${err.brand} ${err.appliance} ${err.meaning} ${err.causes.join(' ')}`}
            >
              <div class="ec-header">
                <div class="ec-code">{err.code}</div>
                <div class="ec-badges">
                  <span class={`urgency-badge urgency-${err.urgency}`}>{urgencyLabel[err.urgency]}</span>
                  <span class="appliance-badge">{applianceIcon[err.appliance] || '🔧'} {err.appliance}</span>
                </div>
              </div>
              <div class="ec-brand">{err.brand}</div>
              <p class="ec-meaning">{err.meaning}</p>
              <button class="ec-expand" aria-expanded="false">
                Подробнее
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <div class="ec-details" hidden>
                {err.causes.length > 0 && (
                  <div class="ec-section">
                    <div class="ec-section-title">Причины</div>
                    <ul class="ec-list">
                      {err.causes.map(c => <li>{c}</li>)}
                    </ul>
                  </div>
                )}
                {err.diySteps.length > 0 && (
                  <div class="ec-section">
                    <div class="ec-section-title">Что проверить самостоятельно</div>
                    <ol class="ec-list">
                      {err.diySteps.map(s => <li>{s}</li>)}
                    </ol>
                  </div>
                )}
                <div class="ec-section">
                  <div class="ec-section-title">Когда вызвать мастера</div>
                  <p class="ec-when">{err.whenCallMaster}</p>
                </div>
                <div class="ec-footer">
                  <span class="ec-price">{err.repairPrice}</span>
                  <a href={`tel:+${SITE.phoneRaw}`} class="ec-call">Вызвать мастера</a>
                </div>
              </div>
            </div>
          ))}
        </div>

        <div class="no-results" id="no-results" hidden>
          <div class="no-results-icon">🔍</div>
          <p>Ничего не найдено. Попробуйте другой запрос или бренд.</p>
          <button class="reset-btn" id="reset-filters">Сбросить фильтры</button>
        </div>
      </div>
    </div>

    <!-- ─── TAB 2: Templates ─── -->
    <div class="tab-content" id="tab-templates" hidden>
      <div class="container">
        <div class="templates-header">
          <h2>Шаблоны документов для мастера</h2>
          <p>Готовые формы для профессионального оформления ремонта. Нажмите «Печать» — откроется готовый документ для распечатки или сохранения в PDF.</p>
        </div>

        <div class="templates-grid">

          <!-- Template 1: Приёмный акт -->
          <div class="template-card">
            <div class="tmpl-icon">📋</div>
            <h3>Акт приёма-передачи техники</h3>
            <p class="tmpl-desc">Оформляется при приёме устройства от клиента. Фиксирует состояние техники, видимые повреждения и перечень принятых комплектующих.</p>
            <ul class="tmpl-includes">
              <li>Данные клиента и мастера</li>
              <li>Описание техники и её состояния</li>
              <li>Видимые дефекты при приёме</li>
              <li>Подписи обеих сторон</li>
            </ul>
            <button class="tmpl-print-btn" data-template="priom">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
              Открыть и распечатать
            </button>
          </div>

          <!-- Template 2: Гарантийный талон -->
          <div class="template-card">
            <div class="tmpl-icon">🛡️</div>
            <h3>Гарантийный талон</h3>
            <p class="tmpl-desc">Выдаётся клиенту после завершения ремонта. Подтверждает гарантийные обязательства сервисного центра на выполненные работы и установленные запчасти.</p>
            <ul class="tmpl-includes">
              <li>Перечень выполненных работ</li>
              <li>Заменённые запчасти</li>
              <li>Срок гарантии (до 12 месяцев)</li>
              <li>Печать и подпись мастера</li>
            </ul>
            <button class="tmpl-print-btn" data-template="garantiya">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
              Открыть и распечатать
            </button>
          </div>

          <!-- Template 3: Договор на ремонт -->
          <div class="template-card">
            <div class="tmpl-icon">📝</div>
            <h3>Договор на ремонт</h3>
            <p class="tmpl-desc">Полноценный договор бытового подряда. Устанавливает права и обязанности сторон, стоимость работ, сроки и условия гарантии.</p>
            <ul class="tmpl-includes">
              <li>Предмет договора и стороны</li>
              <li>Стоимость и порядок оплаты</li>
              <li>Права и обязанности сторон</li>
              <li>Гарантийные обязательства</li>
            </ul>
            <button class="tmpl-print-btn" data-template="dogovor">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
              Открыть и распечатать
            </button>
          </div>

        </div>

        <div class="templates-tip">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
          В браузере нажмите Ctrl+P (или Cmd+P на Mac) и выберите «Сохранить как PDF», чтобы получить файл.
        </div>
      </div>
    </div>

    <!-- ─── TAB 3: Generator ─── -->
    <div class="tab-content" id="tab-generator" hidden>
      <div class="container">
        <div class="gen-layout">
          <div class="gen-form-wrap">
            <div class="gen-header">
              <h2>Генератор акта выполненных работ</h2>
              <p>Заполните форму — получите готовый документ, который можно сохранить в PDF или распечатать.</p>
            </div>

            <form id="act-form" class="act-form">

              <div class="form-section">
                <div class="form-section-title">Реквизиты документа</div>
                <div class="form-row-2">
                  <div class="fg">
                    <label for="act-num">Номер акта</label>
                    <input type="text" id="act-num" placeholder="№ 001" value="001" />
                  </div>
                  <div class="fg">
                    <label for="act-date">Дата</label>
                    <input type="date" id="act-date" />
                  </div>
                </div>
              </div>

              <div class="form-section">
                <div class="form-section-title">Данные клиента</div>
                <div class="fg">
                  <label for="client-name">ФИО клиента *</label>
                  <input type="text" id="client-name" placeholder="Иванов Иван Иванович" required />
                </div>
                <div class="form-row-2">
                  <div class="fg">
                    <label for="client-phone">Телефон *</label>
                    <input type="tel" id="client-phone" placeholder="+7 (___) ___-__-__" required />
                  </div>
                  <div class="fg">
                    <label for="client-city">Город *</label>
                    <select id="client-city" required>
                      <option value="">Выберите город</option>
                      <option value="г. Миасс">г. Миасс</option>
                      <option value="г. Златоуст">г. Златоуст</option>
                      <option value="г. Чебаркуль">г. Чебаркуль</option>
                    </select>
                  </div>
                </div>
                <div class="fg">
                  <label for="client-addr">Адрес (необязательно)</label>
                  <input type="text" id="client-addr" placeholder="ул. Ленина, д. 1, кв. 5" />
                </div>
              </div>

              <div class="form-section">
                <div class="form-section-title">Техника</div>
                <div class="form-row-2">
                  <div class="fg">
                    <label for="app-type">Тип техники *</label>
                    <select id="app-type" required>
                      <option value="">Выберите тип</option>
                      <option>Холодильник</option>
                      <option>Стиральная машина</option>
                      <option>Микроволновая печь</option>
                      <option>Посудомоечная машина</option>
                      <option>Электрическая плита</option>
                      <option>Духовой шкаф</option>
                      <option>Пылесос</option>
                      <option>Кофемашина</option>
                      <option>Другое</option>
                    </select>
                  </div>
                  <div class="fg">
                    <label for="app-brand">Марка и модель *</label>
                    <input type="text" id="app-brand" placeholder="Bosch WAN28163OE" required />
                  </div>
                </div>
                <div class="fg">
                  <label for="app-serial">Серийный номер (необязательно)</label>
                  <input type="text" id="app-serial" placeholder="SN: XXXXXXXXXX" />
                </div>
              </div>

              <div class="form-section">
                <div class="form-section-title">Ремонт</div>
                <div class="fg">
                  <label for="fault-desc">Описание неисправности *</label>
                  <textarea id="fault-desc" rows="2" placeholder="Например: не сливает воду, ошибка E18" required></textarea>
                </div>
                <div class="fg">
                  <label for="work-done">Выполненные работы *</label>
                  <textarea id="work-done" rows="2" placeholder="Например: замена насоса сливного, чистка фильтра" required></textarea>
                </div>
              </div>

              <div class="form-section">
                <div class="form-section-title">Запчасти</div>
                <div id="parts-list">
                  <div class="parts-row">
                    <input type="text" placeholder="Название запчасти" class="part-name" />
                    <input type="number" placeholder="Кол-во" class="part-qty" value="1" min="1" />
                    <input type="number" placeholder="Цена ₽" class="part-price" min="0" />
                    <button type="button" class="part-remove" title="Удалить">✕</button>
                  </div>
                </div>
                <button type="button" id="add-part" class="add-part-btn">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                  Добавить запчасть
                </button>
              </div>

              <div class="form-section">
                <div class="form-section-title">Стоимость</div>
                <div class="form-row-2">
                  <div class="fg">
                    <label for="labor-cost">Стоимость работ (₽) *</label>
                    <input type="number" id="labor-cost" placeholder="0" min="0" required />
                  </div>
                  <div class="fg">
                    <label>Итого (авто)</label>
                    <input type="text" id="total-display" readonly class="total-field" placeholder="0 ₽" />
                  </div>
                </div>
                <div class="fg">
                  <label for="warranty-period">Гарантия</label>
                  <select id="warranty-period">
                    <option value="без гарантии">Без гарантии</option>
                    <option value="1 месяц">1 месяц</option>
                    <option value="3 месяца">3 месяца</option>
                    <option value="6 месяцев">6 месяцев</option>
                    <option value="12 месяцев" selected>12 месяцев</option>
                  </select>
                </div>
              </div>

              <div class="form-section">
                <div class="form-section-title">Мастер</div>
                <div class="fg">
                  <label for="master-name">ФИО мастера</label>
                  <input type="text" id="master-name" placeholder="Иванов Дмитрий" value="Дмитрий" />
                </div>
              </div>

              <button type="submit" class="gen-btn">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
                Сформировать акт и открыть для печати
              </button>
            </form>
          </div>

          <div class="gen-sidebar">
            <div class="gen-tip-card">
              <div class="gen-tip-title">Как использовать</div>
              <ol class="gen-tips">
                <li>Заполните все обязательные поля (*)</li>
                <li>Нажмите «Сформировать акт»</li>
                <li>Откроется новое окно с документом</li>
                <li>В браузере нажмите <strong>Ctrl+P</strong></li>
                <li>Выберите принтер или «Сохранить как PDF»</li>
              </ol>
            </div>
            <div class="gen-tip-card">
              <div class="gen-tip-title">Компания-исполнитель</div>
              <p class="gen-company-info">
                Центр восстановления бытовой техники<br>
                г. Миасс, ул. Победы, д. 18<br>
                Тел: {SITE.phone}
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>

  </main>

  <SiteFooter />
</Layout>

<style>
  .tools-page { background: #f8fafc; min-height: 100vh; }

  /* Hero */
  .tools-hero { padding: 100px 0 56px; background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 100%); }
  .hero-badge { display: inline-block; padding: 4px 14px; background: rgba(255,255,255,0.15); color: #93c5fd; border: 1px solid rgba(255,255,255,0.2); border-radius: 100px; font-size: 0.78rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 16px; }
  .tools-hero h1 { font-size: 2.5rem; font-weight: 800; color: #fff; margin-bottom: 16px; }
  .tools-hero .hero-sub { font-size: 1.05rem; color: #94a3b8; line-height: 1.7; max-width: 600px; margin-bottom: 40px; }
  .hero-features { display: flex; gap: 32px; flex-wrap: wrap; }
  .hf { display: flex; align-items: center; gap: 16px; }
  .hf-icon { font-size: 2rem; flex-shrink: 0; }
  .hf-title { font-size: 0.95rem; font-weight: 700; color: #fff; }
  .hf-sub { font-size: 0.8rem; color: #64748b; margin-top: 2px; }

  /* Tabs */
  .tabs-bar { background: #fff; border-bottom: 1px solid #e2e8f0; position: sticky; top: 72px; z-index: 100; }
  .tabs-nav { display: flex; gap: 4px; padding: 10px 0; overflow-x: auto; }
  .tabs-nav::-webkit-scrollbar { display: none; }
  .tab-btn { display: inline-flex; align-items: center; gap: 7px; padding: 10px 18px; border: none; background: none; cursor: pointer; font-size: 0.9rem; font-weight: 500; color: #64748b; border-radius: 10px; transition: all 0.2s; white-space: nowrap; font-family: inherit; }
  .tab-btn:hover { color: #1d4ed8; background: #f1f5f9; }
  .tab-btn.active { color: #1d4ed8; background: #eff6ff; font-weight: 600; }

  /* Tab content */
  .tab-content { padding: 40px 0 80px; }

  /* ─ Error codes ─ */
  .filter-bar { background: #fff; border: 1px solid #e2e8f0; border-radius: 16px; padding: 20px 24px; margin-bottom: 24px; }
  .filter-search-wrap { position: relative; margin-bottom: 16px; }
