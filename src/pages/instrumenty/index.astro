---
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import { ERROR_CODES, ERROR_BRANDS, ERROR_APPLIANCES } from '../../data/errors';

const errJSON = JSON.stringify(ERROR_CODES);
const errBrandsJSON = JSON.stringify(ERROR_BRANDS);
const errAppsJSON = JSON.stringify(ERROR_APPLIANCES);
---

<Layout title="Инструменты мастера — Мастер Техники 74" description="Бесплатные инструменты для мастеров по ремонту бытовой техники: коды ошибок, шаблоны документов, генератор актов">
  <SiteHeader />

  <main class="tools-page">
    <div class="page-hero">
      <div class="hero-inner">
        <div class="hero-tag">Бесплатно</div>
        <h1 class="hero-title">Инструменты мастера</h1>
        <p class="hero-sub">Коды ошибок, шаблоны документов и генератор актов — всё что нужно для работы</p>
      </div>
    </div>

    <div class="tabs-wrap">
      <div class="tabs-bar">
        <button class="tab-btn active" data-tab="errors">🔍 Коды ошибок</button>
        <button class="tab-btn" data-tab="templates">📄 Шаблоны</button>
        <button class="tab-btn" data-tab="generator">✏️ Генератор</button>
      </div>

      <!-- TAB: ERRORS -->
      <div id="tab-errors" class="tab-panel active">
        <div class="panel-inner">
          <div class="filter-row">
            <div class="filter-chips" id="brand-chips">
              <button class="chip active" data-brand="">Все марки</button>
              <span id="brand-chip-list"></span>
            </div>
            <div class="filter-chips" id="app-chips">
              <button class="chip active" data-app="">Вся техника</button>
              <span id="app-chip-list"></span>
            </div>
            <input class="search-input" id="error-search" type="text" placeholder="Поиск по коду или описанию..." />
          </div>
          <div id="errors-grid" class="errors-grid"></div>
        </div>
      </div>

      <!-- TAB: TEMPLATES -->
      <div id="tab-templates" class="tab-panel hidden">
        <div class="panel-inner">
          <div class="templates-grid">

            <div class="template-card">
              <div class="template-icon">📋</div>
              <h3>Акт приёма-передачи</h3>
              <p>Фиксирует приём техники в ремонт от клиента с описанием неисправностей и видимых повреждений</p>
              <button class="btn-print" onclick="printTemplate('accept')">Распечатать</button>
            </div>

            <div class="template-card">
              <div class="template-icon">🛡️</div>
              <h3>Гарантийный талон</h3>
              <p>Подтверждает гарантию на выполненные работы и установленные запчасти</p>
              <button class="btn-print" onclick="printTemplate('warranty')">Распечатать</button>
            </div>

            <div class="template-card">
              <div class="template-icon">📝</div>
              <h3>Договор на ремонт</h3>
              <p>Юридически оформляет отношения между мастером и клиентом, включая стоимость и сроки</p>
              <button class="btn-print" onclick="printTemplate('contract')">Распечатать</button>
            </div>

          </div>
        </div>
      </div>

      <!-- TAB: GENERATOR -->
      <div id="tab-generator" class="tab-panel hidden">
        <div class="panel-inner">
          <div class="gen-layout">
            <div class="gen-form-wrap">
              <h2 class="gen-title">Генератор акта выполненных работ</h2>
              <form id="gen-form" class="gen-form">
                <div class="gen-row">
                  <div class="gen-group">
                    <label>Клиент</label>
                    <input type="text" id="g-client" placeholder="Иванов Иван Иванович" />
                  </div>
                  <div class="gen-group">
                    <label>Телефон</label>
                    <input type="tel" id="g-phone" placeholder="+7 (900) 000-00-00" />
                  </div>
                </div>
                <div class="gen-row">
                  <div class="gen-group">
                    <label>Техника</label>
                    <input type="text" id="g-appliance" placeholder="Стиральная машина" />
                  </div>
                  <div class="gen-group">
                    <label>Марка и модель</label>
                    <input type="text" id="g-model" placeholder="Indesit IWSB 5105" />
                  </div>
                </div>
                <div class="gen-group full">
                  <label>Описание неисправности</label>
                  <textarea id="g-fault" rows="2" placeholder="Не крутит барабан, посторонние звуки..."></textarea>
                </div>
                <div class="gen-group full">
                  <label>Выполненные работы</label>
                  <textarea id="g-work" rows="3" placeholder="Заменён подшипник барабана 6205ZZ, заменена манжета люка..."></textarea>
                </div>
                <div class="gen-row">
                  <div class="gen-group">
                    <label>Запчасти (₽)</label>
                    <input type="number" id="g-parts" placeholder="0" min="0" />
                  </div>
                  <div class="gen-group">
                    <label>Работы (₽)</label>
                    <input type="number" id="g-labor" placeholder="0" min="0" />
                  </div>
                </div>
                <div class="gen-row">
                  <div class="gen-group">
                    <label>Гарантия (мес.)</label>
                    <input type="number" id="g-warranty" placeholder="3" min="0" max="24" />
                  </div>
                  <div class="gen-group">
                    <label>Мастер</label>
                    <input type="text" id="g-master" placeholder="ИП Петров А.В." />
                  </div>
                </div>
                <button type="button" class="btn-generate" onclick="generateAct()">📄 Сформировать и распечатать</button>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- PREMIUM TEASER -->
    <section class="premium-teaser">
      <div class="teaser-inner">
        <div class="teaser-badge">ПРЕМИУМ ДЛЯ МАСТЕРОВ</div>
        <h2 class="teaser-title">Полный профессиональный кабинет</h2>
        <p class="teaser-sub">Разблокируйте мощные инструменты для роста вашего сервиса</p>
        <div class="teaser-grid">
          <div class="teaser-card locked">
            <div class="lock-icon">🔒</div>
            <div class="teaser-card-icon">📦</div>
            <h4>Менеджер заказов</h4>
            <p>CRM с автоматическим подсчётом выручки, расходов и прибыли</p>
          </div>
          <div class="teaser-card locked">
            <div class="lock-icon">🔒</div>
            <div class="teaser-card-icon">🔧</div>
            <h4>Подбор запчастей</h4>
            <p>База совместимых деталей с OEM-номерами и ценами</p>
          </div>
          <div class="teaser-card locked">
            <div class="lock-icon">🔒</div>
            <div class="teaser-card-icon">📋</div>
            <h4>Сервисные режимы</h4>
            <p>Инструкции по входу в тест-режимы Bosch, LG, Samsung, Indesit</p>
          </div>
          <div class="teaser-card locked">
            <div class="lock-icon">🔒</div>
            <div class="teaser-card-icon">🏷️</div>
            <h4>Скидка 15%</h4>
            <p>Персональный промокод на запчасти для премиум-мастеров</p>
          </div>
        </div>
        <div class="teaser-cta-wrap">
          <a href="/master/login/" class="teaser-cta-btn">Подключить за 390 ₽/мес →</a>
          <p class="teaser-cta-note">Отмена в любой момент · Демо-режим доступен сразу</p>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />
</Layout>

<style>
  :root {
    --orange: #ea580c;
    --orange-dark: #c2410c;
    --orange-light: #fff7ed;
    --orange-mid: #fed7aa;
    --gray-50: #f9fafb;
    --gray-100: #f3f4f6;
    --gray-200: #e5e7eb;
    --gray-400: #9ca3af;
    --gray-600: #4b5563;
    --gray-700: #374151;
    --gray-900: #111827;
    --green: #16a34a;
    --green-light: #dcfce7;
    --yellow: #ca8a04;
    --yellow-light: #fef9c3;
    --red: #dc2626;
    --red-light: #fee2e2;
    --shadow-sm: 0 1px 3px rgba(0,0,0,.07);
    --shadow: 0 4px 12px rgba(0,0,0,.1);
    --radius: 12px;
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  .tools-page { min-height: 80vh; }

  /* HERO */
  .page-hero { background: linear-gradient(135deg, #1f2937 0%, #111827 100%); padding: 48px 16px; }
  .hero-inner { max-width: 700px; margin: 0 auto; text-align: center; }
  .hero-tag {
    display: inline-block; background: var(--orange); color: #fff;
    font-size: .72rem; font-weight: 700; padding: 3px 12px; border-radius: 20px;
    letter-spacing: .06em; margin-bottom: 14px;
  }
  .hero-title { font-size: 2rem; font-weight: 800; color: #fff; margin-bottom: 10px; }
  .hero-sub { font-size: .95rem; color: #9ca3af; line-height: 1.5; }

  /* TABS */
  .tabs-wrap { max-width: 1100px; margin: 0 auto; padding: 0 16px; }
  .tabs-bar {
    display: flex; gap: 0; border-bottom: 1px solid var(--gray-200);
    overflow-x: auto; scrollbar-width: none; margin-top: 0;
    background: #fff; position: sticky; top: 56px; z-index: 40;
  }
  .tabs-bar::-webkit-scrollbar { display: none; }
  .tab-btn {
    padding: 14px 20px; background: none; border: none; border-bottom: 2px solid transparent;
    color: var(--gray-600); font-size: .875rem; font-weight: 500; cursor: pointer;
    white-space: nowrap; transition: all .15s;
  }
  .tab-btn:hover { color: var(--gray-900); }
  .tab-btn.active { color: var(--orange); border-bottom-color: var(--orange); }

  .tab-panel { display: none; }
  .tab-panel.active { display: block; }
  .panel-inner { padding: 24px 0 40px; }

  /* FILTER ROW */
  .filter-row { display: flex; flex-direction: column; gap: 10px; margin-bottom: 20px; }
  .filter-chips { display: flex; flex-wrap: wrap; gap: 6px; }
  .chip {
    padding: 5px 13px; border-radius: 20px; border: 1px solid var(--gray-200);
    background: #fff; color: var(--gray-600); font-size: .78rem; cursor: pointer;
    transition: all .15s;
  }
  .chip:hover { border-color: var(--orange); color: var(--orange); }
  .chip.active { background: var(--orange); color: #fff; border-color: var(--orange); }
  .search-input {
    width: 100%; max-width: 360px; padding: 9px 14px;
    border: 1px solid var(--gray-200); border-radius: 9px;
    font-size: .875rem; color: var(--gray-900);
  }
  .search-input:focus { outline: none; border-color: var(--orange); }

  /* ERRORS GRID */
  .errors-grid {
    display: grid; grid-template-columns: 1fr;
    gap: 10px;
  }
  @media (min-width: 640px) { .errors-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 900px) { .errors-grid { grid-template-columns: repeat(3, 1fr); } }

  .error-card {
    background: #fff; border: 1px solid var(--gray-200); border-radius: var(--radius);
    padding: 14px 16px; box-shadow: var(--shadow-sm); transition: box-shadow .15s;
  }
  .error-card:hover { box-shadow: var(--shadow); }
  .error-card-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 8px; margin-bottom: 6px; }
  .error-code { font-size: 1.05rem; font-weight: 800; color: var(--gray-900); }
  .error-brand { font-size: .7rem; font-weight: 600; padding: 2px 8px; border-radius: 6px; background: var(--gray-100); color: var(--gray-600); }
  .error-desc { font-size: .875rem; font-weight: 600; color: var(--gray-800); margin-bottom: 4px; }
  .error-cause { font-size: .78rem; color: var(--gray-500); line-height: 1.45; }
  .urgency-dot {
    display: inline-block; width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; margin-top: 4px;
  }
  .urgency-high { background: var(--red); }
  .urgency-medium { background: #f59e0b; }
  .urgency-low { background: var(--green); }
  .urgency-label { font-size: .68rem; font-weight: 600; }
  .urgency-label.urgency-high { color: var(--red); }
  .urgency-label.urgency-medium { color: #b45309; }
  .urgency-label.urgency-low { color: var(--green); }
  .error-footer { display: flex; align-items: center; gap: 5px; margin-top: 8px; }

  /* TEMPLATES */
  .templates-grid { display: grid; grid-template-columns: 1fr; gap: 16px; }
  @media (min-width: 600px) { .templates-grid { grid-template-columns: repeat(3, 1fr); } }
  .template-card {
    background: #fff; border: 1px solid var(--gray-200); border-radius: var(--radius);
    padding: 24px 20px; text-align: center; box-shadow: var(--shadow-sm);
    transition: box-shadow .15s;
  }
  .template-card:hover { box-shadow: var(--shadow); }
  .template-icon { font-size: 2.4rem; margin-bottom: 12px; }
  .template-card h3 { font-size: .95rem; font-weight: 700; color: var(--gray-900); margin-bottom: 8px; }
  .template-card p { font-size: .82rem; color: var(--gray-600); line-height: 1.5; margin-bottom: 16px; }
  .btn-print {
    padding: 9px 20px; background: var(--gray-900); color: #fff; border: none;
    border-radius: 8px; font-size: .85rem; font-weight: 600; cursor: pointer;
    transition: background .15s;
  }
  .btn-print:hover { background: var(--orange); }

  /* GENERATOR */
  .gen-layout { max-width: 680px; }
  .gen-title { font-size: 1.1rem; font-weight: 700; color: var(--gray-900); margin-bottom: 20px; }
  .gen-form { display: flex; flex-direction: column; gap: 14px; }
  .gen-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  @media (max-width: 520px) { .gen-row { grid-template-columns: 1fr; } }
  .gen-group { display: flex; flex-direction: column; gap: 5px; }
  .gen-group.full { grid-column: 1/-1; }
  .gen-group label { font-size: .78rem; font-weight: 600; color: var(--gray-700); }
  .gen-group input, .gen-group textarea {
    padding: 9px 12px; border: 1px solid var(--gray-200); border-radius: 8px;
    font-size: .875rem; color: var(--gray-900); background: #fff; font-family: inherit;
  }
  .gen-group input:focus, .gen-group textarea:focus { outline: none; border-color: var(--orange); }
  .gen-group textarea { resize: vertical; }
  .btn-generate {
    padding: 13px 24px; background: linear-gradient(135deg, var(--orange), var(--orange-dark));
    color: #fff; font-size: .95rem; font-weight: 700; border: none; border-radius: 10px;
    cursor: pointer; transition: opacity .15s; box-shadow: 0 3px 10px rgba(234,88,12,.3);
  }
  .btn-generate:hover { opacity: .9; }

  /* PREMIUM TEASER */
  .premium-teaser {
    background: linear-gradient(135deg, #1f2937 0%, #111827 100%);
    margin-top: 60px; padding: 60px 16px;
  }
  .teaser-inner { max-width: 900px; margin: 0 auto; text-align: center; }
  .teaser-badge {
    display: inline-block; background: linear-gradient(135deg, var(--orange), var(--orange-dark));
    color: #fff; font-size: .7rem; font-weight: 700; padding: 4px 14px; border-radius: 20px;
    letter-spacing: .08em; margin-bottom: 16px;
  }
  .teaser-title { font-size: 1.7rem; font-weight: 800; color: #fff; margin-bottom: 10px; }
  .teaser-sub { font-size: .95rem; color: #9ca3af; margin-bottom: 36px; }
  .teaser-grid {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 14px;
    margin-bottom: 36px; text-align: left;
  }
  @media (min-width: 640px) { .teaser-grid { grid-template-columns: repeat(4, 1fr); } }
  .teaser-card {
    background: #1f2937; border: 1px solid #374151; border-radius: var(--radius);
    padding: 18px 14px; position: relative; overflow: hidden;
    transition: border-color .2s;
  }
  .teaser-card:hover { border-color: #4b5563; }
  .teaser-card.locked::after {
    content: ''; position: absolute; inset: 0;
    background: rgba(17,24,39,.5); border-radius: var(--radius);
  }
  .lock-icon {
    position: absolute; top: 10px; right: 10px; font-size: 1rem; z-index: 2;
    opacity: .7;
  }
  .teaser-card-icon { font-size: 1.8rem; margin-bottom: 8px; }
  .teaser-card h4 { font-size: .9rem; font-weight: 700; color: #f3f4f6; margin-bottom: 6px; }
  .teaser-card p { font-size: .78rem; color: #9ca3af; line-height: 1.4; }
  .teaser-cta-wrap { display: flex; flex-direction: column; align-items: center; gap: 10px; }
  .teaser-cta-btn {
    display: inline-block; padding: 16px 36px;
    background: linear-gradient(135deg, var(--orange), var(--orange-dark));
    color: #fff; font-size: 1rem; font-weight: 700; border-radius: var(--radius);
    text-decoration: none; transition: transform .15s, box-shadow .15s;
    box-shadow: 0 4px 14px rgba(234,88,12,.4);
  }
  .teaser-cta-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(234,88,12,.5); }
  .teaser-cta-note { font-size: .78rem; color: #6b7280; }

  .hidden { display: none !important; }
</style>

<script define:vars={{ errJSON, errBrandsJSON, errAppsJSON }}>
const ERRORS = JSON.parse(errJSON);
const BRANDS = JSON.parse(errBrandsJSON);
const APPS = JSON.parse(errAppsJSON);

const $ = id => document.getElementById(id);

// ── TABS ─────────────────────────────────────────────────────────────────────
document.querySelectorAll('.tab-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('tab-' + btn.dataset.tab).classList.add('active');
  });
});

// ── ERROR CODES ───────────────────────────────────────────────────────────────
let activeBrand = '';
let activeApp = '';

function buildChips() {
  const bl = $('brand-chip-list');
  BRANDS.forEach(b => {
    const btn = document.createElement('button');
    btn.className = 'chip';
    btn.dataset.brand = b;
    btn.textContent = b;
    btn.addEventListener('click', () => setBrand(b, btn));
    bl.appendChild(btn);
  });
  document.querySelector('[data-brand=""]').addEventListener('click', e => setBrand('', e.currentTarget));

  const al = $('app-chip-list');
  APPS.forEach(a => {
    const btn = document.createElement('button');
    btn.className = 'chip';
    btn.dataset.app = a;
    btn.textContent = a;
    btn.addEventListener('click', () => setApp(a, btn));
    al.appendChild(btn);
  });
  document.querySelector('[data-app=""]').addEventListener('click', e => setApp('', e.currentTarget));
}

function setBrand(val, el) {
  activeBrand = val;
  document.querySelectorAll('#brand-chips .chip').forEach(c => c.classList.remove('active'));
  el.classList.add('active');
  filterErrors();
}
function setApp(val, el) {
  activeApp = val;
  document.querySelectorAll('#app-chips .chip').forEach(c => c.classList.remove('active'));
  el.classList.add('active');
  filterErrors();
}

$('error-search').addEventListener('input', filterErrors);

function filterErrors() {
  const q = $('error-search').value.toLowerCase().trim();
  let results = ERRORS;
  if (activeBrand) results = results.filter(e => e.brand === activeBrand);
  if (activeApp) results = results.filter(e => e.appliance === activeApp);
  if (q) results = results.filter(e =>
    e.code.toLowerCase().includes(q) ||
    e.description.toLowerCase().includes(q) ||
    e.cause.toLowerCase().includes(q)
  );
  renderErrors(results);
}

function renderErrors(list) {
  const URGENCY = { high: 'Срочно', medium: 'Внимание', low: 'Норма' };
  $('errors-grid').innerHTML = list.length === 0
    ? '<div style="grid-column:1/-1;text-align:center;padding:40px;color:#9ca3af;">Ничего не найдено</div>'
    : list.map(e => `
      <div class="error-card">
        <div class="error-card-top">
          <div class="error-code">${e.code}</div>
          <span class="error-brand">${e.brand}</span>
        </div>
        <div class="error-desc">${e.description}</div>
        <div class="error-cause">${e.cause}</div>
        <div class="error-footer">
          <span class="urgency-dot urgency-${e.urgency}"></span>
          <span class="urgency-label urgency-${e.urgency}">${URGENCY[e.urgency]}</span>
          <span style="font-size:.7rem;color:#9ca3af;margin-left:4px;">· ${e.appliance}</span>
        </div>
      </div>
    `).join('');
}

// ── TEMPLATES ─────────────────────────────────────────────────────────────────
const today = new Date().toLocaleDateString('ru-RU', { day: '2-digit', month: '2-digit', year: 'numeric' });

window.printTemplate = (type) => {
  const templates = {
    accept: `
      <h2 style="text-align:center;margin-bottom:24px;">Акт приёма-передачи техники в ремонт</h2>
      <p>Дата: ${today}&emsp;№ _____</p>
      <p style="margin-top:12px;"><strong>Мастер/Организация:</strong> _________________________________</p>
      <p><strong>Клиент:</strong> _________________________________________ Тел.: ___________________</p>
      <table style="width:100%;border-collapse:collapse;margin:16px 0;">
        <tr><th style="border:1px solid #000;padding:6px 10px;text-align:left;background:#f3f4f6;">Параметр</th><th style="border:1px solid #000;padding:6px 10px;background:#f3f4f6;">Значение</th></tr>
        <tr><td style="border:1px solid #000;padding:6px 10px;">Тип техники</td><td style="border:1px solid #000;padding:6px 10px;">&nbsp;</td></tr>
        <tr><td style="border:1px solid #000;padding:6px 10px;">Марка и модель</td><td style="border:1px solid #000;padding:6px 10px;">&nbsp;</td></tr>
        <tr><td style="border:1px solid #000;padding:6px 10px;">Серийный номер</td><td style="border:1px solid #000;padding:6px 10px;">&nbsp;</td></tr>
