---
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import FloatingButton from '../../components/FloatingButton.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import TelegramButtons from '../../components/TelegramButtons.astro';
import FAQ from '../../components/FAQ.astro';
import { SITE, CITIES, SERVICES } from '../../data/services';

const title = 'Обслуживание бытовой техники для предприятий — договор, безнал, гарантия | Master-Tehniki74';
const description = `Заключите договор на обслуживание бытовой техники для кафе, ресторана, гостиницы, детского сада или производства. Выезд за 1-2 часа, полный пакет документов, работа по безналу. Миасс, Златоуст, Чебаркуль. Телефон: ${SITE.phone}`;

const b2bFaq = [
  { question: 'Как заключить договор на обслуживание?', answer: 'Позвоните или напишите в Telegram. Менеджер уточнит тип и количество техники, подготовит персональный расчёт и договор. Подписание — в офисе или удалённо (электронный документооборот). Работу начинаем в день подписания.' },
  { question: 'Работаете ли вы с бюджетными организациями (44-ФЗ, 223-ФЗ)?', answer: 'Да. Работаем с детскими садами, школами, больницами и муниципальными учреждениями. Предоставляем весь пакет документов для госзакупок: договор, акт, счёт, счёт-фактура, гарантийный талон, отчёт. Опыт работы с госзаказчиками — с 2017 года.' },
  { question: 'Как быстро приедет мастер при аварийной поломке?', answer: 'Для клиентов по договору — приоритетный выезд в течение 1-2 часов. Для разовых обращений — в день обращения. Работаем ежедневно с 9:00 до 20:00. Для тарифа «Полное обслуживание» — экстренный выезд в нерабочее время.' },
  { question: 'Можно ли оплатить безналом?', answer: 'Да, работаем только по безналу для юридических лиц. НДС — по запросу. Отсрочка платежа до 30 дней — для клиентов с тарифом «Полное обслуживание». Каждый месяц — закрывающие документы.' },
  { question: 'Что входит в плановую диагностику?', answer: 'Мастер проверяет каждую единицу техники: измеряет температуру (холодильники), давление в гидросистеме (стиральные машины), состояние ТЭНов, термостатов, уплотнителей, проводки. Мелкие проблемы устраняет на месте. По итогу — письменный отчёт.' },
  { question: 'Сколько стоит обслуживание?', answer: 'Абонентское — от 5 000 руб/мес (до 10 единиц). Полное — от 12 000 руб/мес (без ограничений + любой ремонт включён). Разовый ремонт для юрлиц — со скидкой 15% от розничной цены. Точный расчёт — после консультации.' },
];

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Обслуживание бытовой техники для предприятий",
  "description": description,
  "provider": {
    "@type": "LocalBusiness",
    "name": "Master-Tehniki74",
    "telephone": SITE.phone,
    "address": { "@type": "PostalAddress", "addressLocality": "Миасс", "addressRegion": "Челябинская область", "streetAddress": "ул. Победы, д. 18" },
    "openingHours": "Mo-Su 09:00-20:00",
    "url": SITE.url,
    "sameAs": [SITE.telegram],
  },
  "areaServed": Object.values(CITIES).map(c => ({ "@type": "City", "name": c.name })),
  "serviceType": "Абонентское обслуживание бытовой техники",
  "offers": [
    { "@type": "Offer", "name": "Абонентское обслуживание", "price": "5000", "priceCurrency": "RUB", "priceSpecification": { "unitText": "month" } },
    { "@type": "Offer", "name": "Полное обслуживание", "price": "12000", "priceCurrency": "RUB", "priceSpecification": { "unitText": "month" } },
  ],
});
---

<Layout title={title} description={description} keywords="обслуживание техники для предприятия, договор на ремонт, абонентское обслуживание, ремонт для юрлиц, безналичный расчёт ремонт техники, 44-ФЗ ремонт техники, ремонт холодильников кафе, обслуживание стиральных машин гостиница" canonical="/b2b/" schema={`[${schema}]`} geoPlace="Миасс">
  <SiteHeader />
  <FloatingButton />

  <main class="b2b-page">

    <!-- HERO -->
    <section class="hero-section" id="hero">
      <div class="container">
        <div class="hero-layout">
          <div class="hero-content">
            <Breadcrumbs items={[{ label: 'Главная', href: '/' }, { label: 'Для бизнеса' }]} />
            <div class="hero-badge">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
              Для юридических лиц
            </div>
            <h1>Обслуживание бытовой техники для предприятий</h1>
            <p class="hero-desc">
              Один договор — и ваша техника под защитой. Плановая диагностика, срочный выезд за 1-2 часа,
              полный пакет документов. Работаем с кафе, гостиницами, детсадами, больницами и производствами.
            </p>
            <div class="hero-trust">
              <div class="trust-item">
                <strong>10 лет</strong>
                <span>на рынке</span>
              </div>
              <div class="trust-sep"></div>
              <div class="trust-item">
                <strong>150+</strong>
                <span>предприятий обслужено</span>
              </div>
              <div class="trust-sep"></div>
              <div class="trust-item">
                <strong>24 мес</strong>
                <span>гарантия</span>
              </div>
              <div class="trust-sep"></div>
              <div class="trust-item">
                <strong>44-ФЗ</strong>
                <span>госзакупки</span>
              </div>
            </div>
            <div class="hero-actions">
              <TelegramButtons context="Здравствуйте! Хочу заключить договор на обслуживание бытовой техники для предприятия." />
              <a href={`tel:+${SITE.phoneRaw}`} class="btn-call">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                {SITE.phone}
              </a>
            </div>
          </div>

          <!-- Sticky sidebar -->
          <div class="hero-card">
            <div class="card-label">Быстрая связь</div>
            <h3>Получить расчёт</h3>
            <p>Напишите нам — менеджер подготовит персональное предложение в течение 2 часов</p>
            <a href={SITE.telegram} target="_blank" rel="noopener noreferrer" class="card-btn tg">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
              Написать в Telegram
            </a>
            <a href={SITE.whatsapp} target="_blank" rel="noopener noreferrer" class="card-btn wa">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
              Написать в WhatsApp
            </a>
            <div class="card-divider"></div>
            <a href={`tel:+${SITE.phoneRaw}`} class="card-phone">{SITE.phone}</a>
            <p class="card-hours">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              {SITE.workHours}
            </p>
            <div class="card-docs">
              <span>Работаем по безналу</span>
              <span>НДС / без НДС</span>
              <span>44-ФЗ / 223-ФЗ</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ANCHOR NAV -->
    <nav class="anchor-nav" aria-label="Разделы страницы">
      <div class="container">
        <div class="anchor-nav-inner">
          <a href="#problems">Проблемы</a>
          <a href="#solutions">Что входит</a>
          <a href="#whom">Кому подходит</a>
          <a href="#tariffs">Тарифы</a>
          <a href="#process">Как начать</a>
          <a href="#docs">Документы</a>
          <a href="#faq">Вопросы</a>
        </div>
      </div>
    </nav>

    <!-- PROBLEMS -->
    <section class="problems-section" id="problems">
      <div class="container">
        <div class="section-header center">
          <span class="section-label">Знакомо?</span>
          <h2>Проблемы, которые решает договор</h2>
          <p class="section-desc">Каждая из этих ситуаций обходится предприятию дороже, чем ежемесячный абонент</p>
        </div>
        <div class="problems-grid">
          <div class="problem-card">
            <div class="problem-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg></div>
            <h3>Холодильник сломался ночью</h3>
            <p>Утром приходите на работу — продукты испорчены. Убытки на 15-50 тысяч рублей. Мастер — только завтра.</p>
            <div class="problem-cost">Потери: от 15 000 ₽</div>
          </div>
          <div class="problem-card">
            <div class="problem-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div>
            <h3>Мастер «на следующей неделе»</h3>
            <p>Стиральная машина в гостинице не работает 3 дня. Гости жалуются. Возвраты, негативные отзывы.</p>
            <div class="problem-cost">Потери: репутация + отзывы</div>
          </div>
          <div class="problem-card">
            <div class="problem-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/></svg></div>
            <h3>Расходы без документов</h3>
            <p>Частный мастер берёт наличными, документов нет. Бухгалтерия не может учесть расход. Налоговые риски.</p>
            <div class="problem-cost">Риск: налоговые претензии</div>
          </div>
          <div class="problem-card">
            <div class="problem-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div>
            <h3>Ремонт без гарантии</h3>
            <p>Та же поломка через месяц — и снова платить. Без письменной гарантии претензию не предъявить.</p>
            <div class="problem-cost">Потери: двойные расходы</div>
          </div>
        </div>
      </div>
    </section>

    <!-- SOLUTIONS -->
    <section class="solution-section" id="solutions">
      <div class="container">
        <div class="section-header center">
          <span class="section-label">Что включено</span>
          <h2>Что входит в договор на обслуживание</h2>
          <p class="section-desc">Всё, что нужно для бесперебойной работы техники — в одном договоре</p>
        </div>
        <div class="solution-grid">
          <div class="solution-card">
            <div class="sol-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#1d4ed8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
            </div>
            <h3>Плановая диагностика</h3>
            <p>Раз в квартал (или в месяц на «Полном» тарифе) мастер осматривает всю технику. Температуры, давление, контакты, уплотнители. Мелкие неисправности — сразу.</p>
            <div class="sol-badge">Раз в квартал</div>
          </div>
          <div class="solution-card">
            <div class="sol-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#1d4ed8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <h3>Срочный выезд за 1-2 ч</h3>
            <p>Аварийная поломка — мастер выедет в течение 1-2 часов. Для договорных клиентов — без очереди, в приоритете.</p>
            <div class="sol-badge">Приоритет</div>
          </div>
          <div class="solution-card">
            <div class="sol-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#1d4ed8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
            </div>
            <h3>Мелкий ремонт в абонент</h3>
            <p>Замена лампочек, чистка фильтров, регулировка дверец, подтяжка контактов — всё входит в абонентскую плату без доплат.</p>
            <div class="sol-badge">Без доплат</div>
          </div>
          <div class="solution-card">
            <div class="sol-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#1d4ed8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
            </div>
            <h3>Скидка 15% на запчасти</h3>
            <p>Для договорных клиентов — постоянная скидка 15% на все запчасти. Оригинальные детали и качественные аналоги.</p>
            <div class="sol-badge">Экономия</div>
          </div>
          <div class="solution-card">
            <div class="sol-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#1d4ed8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><polyline points="9 15 12 18 15 15"/></svg>
            </div>
            <h3>Полный пакет документов</h3>
            <p>Договор, акт, счёт, счёт-фактура, гарантийный талон, ежемесячный отчёт. Безнал, НДС / без НДС, 44-ФЗ / 223-ФЗ.</p>
            <div class="sol-badge">Безнал</div>
          </div>
          <div class="solution-card">
            <div class="sol-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#1d4ed8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <h3>Гарантия до 24 месяцев</h3>
            <p>Расширенная гарантия на все работы. Повторная поломка в гарантийный срок — ремонт за наш счёт.</p>
            <div class="sol-badge">24 месяца</div>
          </div>
        </div>
      </div>
    </section>

    <!-- WHOM -->
    <section class="whom-section" id="whom">
      <div class="container">
        <div class="section-header center">
          <span class="section-label">Наши клиенты</span>
          <h2>Кому нужен договор на обслуживание</h2>
        </div>
        <div class="whom-grid">
          <div class="whom-card">
            <div class="whom-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#1d4ed8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/></svg>
            </div>
            <h3>Кафе и рестораны</h3>
            <ul class="whom-list">
              <li>Холодильники и морозильные лари</li>
              <li>Электрические плиты и духовки</li>
              <li>Микроволновые печи</li>
              <li>Выездной ремонт за 1-2 часа</li>
            </ul>
          </div>
          <div class="whom-card">
            <div class="whom-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#1d4ed8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18"/><path d="M5 21V7l8-4v18"/><path d="M19 21V11l-6-4"/></svg>
            </div>
            <h3>Гостиницы и отели</h3>
            <ul class="whom-list">
              <li>Промышленные стиральные машины</li>
              <li>Холодильники в номерах</li>
              <li>Бытовая техника в прачечной</li>
              <li>Единый договор на весь номерной фонд</li>
            </ul>
          </div>
          <div class="whom-card">
            <div class="whom-icon">
