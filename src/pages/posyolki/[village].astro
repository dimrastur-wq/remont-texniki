---
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import FloatingButton from '../../components/FloatingButton.astro';
import TelegramButtons from '../../components/TelegramButtons.astro';
import { SITE, SERVICES, VILLAGES, type VillageKey } from '../../data/services';

export function getStaticPaths() {
  return Object.entries(VILLAGES).map(([key, village]) => ({
    params: { village: village.slug },
    props: { villageKey: key },
  }));
}

const { villageKey } = Astro.props;
const village = VILLAGES[villageKey as VillageKey];
const serviceKeys = Object.keys(SERVICES) as Array<keyof typeof SERVICES>;

const title = `Ремонт бытовой техники в ${village.namePrepositional} с выездом — Центр восстановления бытовой техники`;
const description = `Ремонт холодильников, стиральных машин и другой бытовой техники в ${village.namePrepositional}. Выезд мастера на дом — ${village.distanceKm} км от ${village.nearCity}. Звоните: ${SITE.phone}`;
const keywords = `ремонт бытовой техники ${village.name}, ремонт холодильника ${village.name}, ремонт стиральной машины ${village.name}, мастер по ремонту техники ${village.name}`;

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": SITE.name,
  "description": description,
  "telephone": SITE.phone,
  "url": `${SITE.url}/posyolki/${village.slug}/`,
  "areaServed": {
    "@type": "Place",
    "name": village.name,
    "containedInPlace": {
      "@type": "City",
      "name": village.nearCity,
    },
  },
  "openingHours": "Mo-Su 09:00-20:00",
});
---

<Layout
  title={title}
  description={description}
  keywords={keywords}
  canonical={`/posyolki/${village.slug}/`}
  schema={schema}
  geoRegion="RU-CHE"
  geoPlace={village.name}
>
  <SiteHeader />

  <main>
    <section class="breadcrumbs-bar">
      <div class="container">
        <nav class="breadcrumbs">
          <a href="/">Главная</a>
          <span>/</span>
          <a href={`/${village.nearCitySlug}/`}>{village.nearCity}</a>
          <span>/</span>
          <span>{village.name}</span>
        </nav>
      </div>
    </section>

    <section class="hero">
      <div class="hero-bg"></div>
      <div class="container hero-content">
        <div class="hero-text">
          <span class="hero-badge">{village.distanceKm} км от {village.nearCity}</span>
          <h1>Ремонт бытовой техники<br />в {village.namePrepositional}</h1>
          <p class="hero-sub">{village.description}</p>
          <TelegramButtons context={`Здравствуйте! Мне нужен ремонт техники в ${village.namePrepositional}.`} />
          <div class="landmarks">
            {village.landmarks.map(l => (
              <span class="landmark-tag">{l}</span>
            ))}
          </div>
        </div>
        <div class="hero-card-wrap">
          <div class="hero-info-card">
            <div class="info-row">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1d4ed8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              <span><strong>{village.distanceKm} км</strong> от {village.nearCity}</span>
            </div>
            <div class="info-row">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1d4ed8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              <span><strong>{SITE.workHours}</strong></span>
            </div>
            <div class="info-row">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1d4ed8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              <a href={`tel:+${SITE.phoneRaw}`} class="phone-link">{SITE.phone}</a>
            </div>
            <div class="guarantee-row">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              Гарантия до 12 месяцев
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="services-section">
      <div class="container">
        <div class="section-header">
          <h2>Виды ремонта в {village.namePrepositional}</h2>
          <p>Все виды ремонта бытовой техники с выездом на дом</p>
        </div>
        <div class="services-grid">
          {serviceKeys.map(key => {
            const service = SERVICES[key];
            return (
              <a href={`/${village.nearCitySlug}/${service.slug}/`} class="service-card">
                <div class="service-icon" set:html={service.icon} />
                <div>
                  <h3>{service.name}</h3>
                  <p>{service.commonProblems[0].price}</p>
                </div>
                <span class="service-arrow">&rarr;</span>
              </a>
            );
          })}
        </div>
      </div>
    </section>

    <section class="why-section">
      <div class="container">
        <h2>Почему выбирают нас в {village.namePrepositional}</h2>
        <div class="why-grid">
          <div class="why-card">
            <div class="why-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#1d4ed8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <h3>Выезд в день обращения</h3>
            <p>Приезжаем в {village.namePrepositional} в день звонка или на следующий день.</p>
          </div>
          <div class="why-card">
            <div class="why-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#1d4ed8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
            </div>
            <h3>Честная цена</h3>
            <p>Стоимость озвучиваем до начала работ. Без скрытых доплат.</p>
          </div>
          <div class="why-card">
            <div class="why-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#1d4ed8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <h3>Гарантия до 12 месяцев</h3>
            <p>Все виды ремонта с письменной гарантией на работы и запчасти.</p>
          </div>
          <div class="why-card">
            <div class="why-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#1d4ed8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
            <h3>Опытные мастера</h3>
            <p>Мастера с опытом 7–14 лет. Знаем все марки и модели техники.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="cta-section">
      <div class="container">
        <div class="cta-inner">
          <h2>Нужен ремонт в {village.namePrepositional}?</h2>
          <p>Звоните или пишите — мастер приедет из {village.nearCity} ({village.distanceKm} км)</p>
          <div class="cta-btns">
            <a href={SITE.telegram} target="_blank" rel="noopener noreferrer" class="cta-btn cta-btn--tg">Написать в Telegram</a>
            <a href={`tel:+${SITE.phoneRaw}`} class="cta-btn cta-btn--call">{SITE.phone}</a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />
  <FloatingButton />
</Layout>

<style>
  .breadcrumbs-bar {
    background: #f8fafc;
    border-bottom: 1px solid #e2e8f0;
    padding: 12px 0;
  }

  .breadcrumbs {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.82rem;
    color: #94a3b8;
  }

  .breadcrumbs a { color: #64748b; }
  .breadcrumbs a:hover { color: #1d4ed8; }
  .breadcrumbs span:last-child { color: #0f172a; font-weight: 500; }

  .hero {
    position: relative;
    padding: 80px 0 64px;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 60%, #bfdbfe 100%);
  }

  .hero-content {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
  }

  .hero-badge {
    display: inline-block;
    padding: 5px 14px;
    background: rgba(29,78,216,0.1);
    color: #1d4ed8;
    border-radius: 100px;
    font-size: 0.8rem;
    font-weight: 600;
    margin-bottom: 16px;
  }

  .hero h1 {
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    font-weight: 800;
    color: #0f172a;
    line-height: 1.15;
    margin-bottom: 16px;
  }

  .hero-sub {
    font-size: 1.05rem;
    color: #475569;
    line-height: 1.7;
    margin-bottom: 28px;
  }

  .landmarks {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 20px;
  }

  .landmark-tag {
    padding: 5px 12px;
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    font-size: 0.78rem;
    color: #475569;
  }

  .hero-info-card {
    background: #fff;
    border-radius: 20px;
    padding: 28px;
    box-shadow: 0 16px 48px rgba(29,78,216,0.1), 0 4px 12px rgba(0,0,0,0.04);
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .info-row {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 0.92rem;
    color: #475569;
  }

  .info-row strong { color: #0f172a; }

  .phone-link {
    font-weight: 700;
    color: #1d4ed8;
    font-size: 1rem;
  }

  .guarantee-row {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.85rem;
    font-weight: 600;
    color: #166534;
    background: #f0fdf4;
    border: 1px solid #bbf7d0;
    padding: 8px 14px;
    border-radius: 8px;
    margin-top: 4px;
  }

  .services-section {
    padding: 72px 0;
    background: #fff;
  }

  .section-header {
    text-align: center;
    margin-bottom: 36px;
  }

  .section-header h2 {
    font-size: clamp(1.4rem, 2.5vw, 1.9rem);
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 8px;
  }

  .section-header p { color: #64748b; }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .service-card {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 20px;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 14px;
    transition: all 0.2s;
  }

  .service-card:hover {
    border-color: #1d4ed8;
    background: #eff6ff;
    box-shadow: 0 4px 16px rgba(29,78,216,0.08);
  }

  .service-icon {
    width: 48px;
    height: 48px;
    min-width: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #fff;
    border-radius: 12px;
    color: #1d4ed8;
  }

  .service-card h3 {
    font-size: 0.92rem;
    font-weight: 600;
    color: #0f172a;
    margin-bottom: 2px;
  }

  .service-card p {
    font-size: 0.8rem;
    color: #1d4ed8;
    font-weight: 600;
  }

  .service-arrow {
    margin-left: auto;
    color: #94a3b8;
    font-size: 1rem;
    transition: color 0.2s;
  }

  .service-card:hover .service-arrow { color: #1d4ed8; }

  .why-section {
    padding: 72px 0;
    background: #f8fafc;
  }

  .why-section h2 {
    font-size: clamp(1.4rem, 2.5vw, 1.9rem);
    font-weight: 700;
    color: #0f172a;
    text-align: center;
    margin-bottom: 36px;
  }

  .why-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }

  .why-card {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 14px;
    padding: 24px;
    transition: box-shadow 0.2s;
  }

  .why-card:hover { box-shadow: 0 6px 24px rgba(29,78,216,0.07); }

  .why-icon {
    width: 44px;
    height: 44px;
    background: #eff6ff;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 14px;
  }

  .why-card h3 {
    font-size: 0.95rem;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 6px;
  }

  .why-card p {
    font-size: 0.82rem;
    color: #64748b;
    line-height: 1.5;
  }

  .cta-section {
    background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 100%);
    padding: 64px 0;
    text-align: center;
  }

  .cta-inner h2 { font-size: clamp(1.4rem, 2.5vw, 1.9rem); font-weight: 700; color: #fff; margin-bottom: 10px; }
  .cta-inner p { color: #94a3b8; margin-bottom: 28px; }
  .cta-btns { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }

  .cta-btn {
    padding: 13px 24px;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.95rem;
    color: #fff;
    transition: filter 0.2s;
  }

  .cta-btn:hover { filter: brightness(1.1); }
  .cta-btn--tg { background: #0088cc; }
  .cta-btn--call { background: #1d4ed8; }

  @media (max-width: 768px) {
    .hero-content { grid-template-columns: 1fr; }
    .services-grid { grid-template-columns: 1fr 1fr; }
    .why-grid { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 480px) {
    .services-grid { grid-template-columns: 1fr; }
    .why-grid { grid-template-columns: 1fr; }
  }
</style>
