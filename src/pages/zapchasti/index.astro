---
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import FloatingButton from '../../components/FloatingButton.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import TelegramButtons from '../../components/TelegramButtons.astro';
import { SITE } from '../../data/services';
import { SHOP_PARTS, SHOP_CATEGORIES, retailPrice, masterPrice, formatPrice } from '../../data/parts';

const title = 'Магазин запчастей для бытовой техники — Миасс, Златоуст, Чебаркуль | Центр восстановления';
const description = 'Запчасти для стиральных машин, холодильников, микроволновок и водонагревателей. ТЭНы, помпы, подшипники, ремни. Цены с наценкой +30%. Скидка 15% для мастеров.';
const keywords = 'запчасти бытовая техника, ТЭН стиральной машины, помпа слива, подшипник барабана, компрессор холодильника, магнетрон, запчасти Миасс';

const subcategoriesMap: Record<string, string[]> = {};
for (const part of SHOP_PARTS) {
  if (!subcategoriesMap[part.category]) subcategoriesMap[part.category] = [];
  if (!subcategoriesMap[part.category].includes(part.subcategory)) {
    subcategoriesMap[part.category].push(part.subcategory);
  }
}

const popularParts = SHOP_PARTS.filter(p => p.popular);
const totalInStock = SHOP_PARTS.filter(p => p.inStock).length;

const categoryIcons: { [key: string]: string } = {
  'Стиральные машины': '🫧',
  'Холодильники': '❄️',
  'Микроволновки': '📡',
  'Водонагреватели': '🔥',
};
---

<Layout title={title} description={description} keywords={keywords}>
  <SiteHeader />
  <FloatingButton />

  <main>
    <div class="container">
      <Breadcrumbs items={[{ label: 'Магазин запчастей' }]} />
    </div>

    <!-- Hero -->
    <section class="shop-hero">
      <div class="container">
        <div class="hero-content">
          <div class="hero-text">
            <div class="hero-badges">
              <span class="badge badge-blue">Склад в Миассе</span>
              <span class="badge badge-green">{totalInStock} позиций в наличии</span>
            </div>
            <h1>Магазин запчастей<br><span class="accent">для бытовой техники</span></h1>
            <p class="hero-desc">
              ТЭНы, помпы, подшипники, ремни, манжеты и компрессоры.
              Оригинальные и совместимые детали для всех популярных брендов.
              Розничная цена уже включает наценку +30%. Мастерам — скидка 15%.
            </p>
            <div class="hero-stats">
              <div class="stat">
                <strong>50+</strong>
                <span>позиций в каталоге</span>
              </div>
              <div class="stat">
                <strong>4</strong>
                <span>категории техники</span>
              </div>
              <div class="stat">
                <strong>−15%</strong>
                <span>скидка мастерам</span>
              </div>
            </div>
            <TelegramButtons context="Здравствуйте! Хочу заказать запчасть." />
          </div>
          <div class="hero-categories">
            {SHOP_CATEGORIES.map(cat => {
              const count = SHOP_PARTS.filter(p => p.category === cat).length;
              return (
                <button class="cat-pill" data-cat={cat}>
                  <span class="cat-icon">{categoryIcons[cat]}</span>
                  <span class="cat-name">{cat}</span>
                  <span class="cat-count">{count}</span>
                </button>
              );
            })}
          </div>
        </div>
      </div>
    </section>

    <!-- Master discount banner -->
    <section class="master-banner">
      <div class="container">
        <div class="master-inner">
          <div class="master-icon">🔧</div>
          <div class="master-text">
            <strong>Скидка 15% для профессиональных мастеров</strong>
            <span>Зарегистрируйтесь в Кабинете мастера — и получайте запчасти по сниженным ценам при каждом заказе.</span>
          </div>
          <a href="/master/" class="master-cta">Кабинет мастера</a>
        </div>
      </div>
    </section>

    <!-- Catalog -->
    <section class="catalog-section">
      <div class="container">
        <div class="catalog-layout">

          <!-- Sidebar filters -->
          <aside class="sidebar" id="sidebar">
            <div class="sidebar-section">
              <h3>Категория</h3>
              <button class="side-btn active" data-cat="all" data-sub="all">Все запчасти</button>
              {SHOP_CATEGORIES.map(cat => (
                <button class="side-btn" data-cat={cat} data-sub="all">{cat}</button>
              ))}
            </div>

            <div class="sidebar-section" id="subcats-panel" style="display:none">
              <h3 id="subcats-title">Подкатегория</h3>
              <div id="subcats-list"></div>
            </div>

            <div class="sidebar-section">
              <h3>Состояние</h3>
              <label class="checkbox-label">
                <input type="checkbox" id="filter-new" checked> Новый
              </label>
              <label class="checkbox-label">
                <input type="checkbox" id="filter-used" checked> Б/У
              </label>
            </div>

            <div class="sidebar-section">
              <h3>Наличие</h3>
              <label class="checkbox-label">
                <input type="checkbox" id="filter-instock"> Только в наличии
              </label>
            </div>
          </aside>

          <!-- Main content -->
          <div class="catalog-main">
            <div class="catalog-toolbar">
              <div class="toolbar-left">
                <span class="results-count" id="results-count">{SHOP_PARTS.length} товаров</span>
              </div>
              <button class="mobile-filter-btn" id="mobile-filter-btn">Фильтры</button>
            </div>

            <!-- Popular strip -->
            <div class="popular-strip" id="popular-strip">
              <h2 class="section-title">Популярные запчасти</h2>
              <div class="parts-grid" id="popular-grid">
                {popularParts.map(part => (
                  <div
                    class="part-card"
                    data-id={part.id}
                    data-cat={part.category}
                    data-sub={part.subcategory}
                    data-condition={part.condition}
                    data-instock={part.inStock ? '1' : '0'}
                    data-popular="1"
                  >
                    {part.popular && <div class="card-badge">Топ продаж</div>}
                    <div class="card-meta">
                      <span class={`condition-tag ${part.condition === 'Новый' ? 'new' : 'used'}`}>{part.condition}</span>
                      <span class={`stock-tag ${part.inStock ? 'instock' : 'order'}`}>
                        {part.inStock ? 'В наличии' : 'Под заказ'}
                      </span>
                    </div>
                    <h3 class="card-title">{part.name}</h3>
                    <div class="card-brands">{part.brands.slice(0, 3).join(', ')}</div>
                    <div class="card-prices">
                      <div class="price-retail">
                        <span class="price-label">Розничная</span>
                        <span class="price-value">{formatPrice(retailPrice(part))}</span>
                      </div>
                      <div class="price-master">
                        <span class="price-label">Мастерам −15%</span>
                        <span class="price-value master">{formatPrice(masterPrice(part))}</span>
                      </div>
                    </div>
                    <button
                      class="card-order add-to-cart"
                      data-id={part.id}
                      data-name={part.name}
                      data-retail={retailPrice(part)}
                      data-master={masterPrice(part)}
                      data-condition={part.condition}
                    >
                      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
                      В корзину
                    </button>
                  </div>
                ))}
              </div>
            </div>

            <!-- All parts -->
            <div id="all-parts-section">
              <h2 class="section-title" id="all-parts-title">Все запчасти</h2>
              <div class="parts-grid" id="all-grid">
                {SHOP_PARTS.map(part => (
                  <div
                    class="part-card"
                    data-id={part.id}
                    data-cat={part.category}
                    data-sub={part.subcategory}
                    data-condition={part.condition}
                    data-instock={part.inStock ? '1' : '0'}
                    data-popular={part.popular ? '1' : '0'}
                  >
                    {part.popular && <div class="card-badge">Топ продаж</div>}
                    <div class="card-meta">
                      <span class={`condition-tag ${part.condition === 'Новый' ? 'new' : 'used'}`}>{part.condition}</span>
                      <span class={`stock-tag ${part.inStock ? 'instock' : 'order'}`}>
                        {part.inStock ? 'В наличии' : 'Под заказ'}
                      </span>
                    </div>
                    <h3 class="card-title">{part.name}</h3>
                    <div class="card-brands">{part.brands.slice(0, 3).join(', ')}</div>
                    <div class="card-prices">
                      <div class="price-retail">
                        <span class="price-label">Розничная</span>
                        <span class="price-value">{formatPrice(retailPrice(part))}</span>
                      </div>
                      <div class="price-master">
                        <span class="price-label">Мастерам −15%</span>
                        <span class="price-value master">{formatPrice(masterPrice(part))}</span>
                      </div>
                    </div>
                    <button
                      class="card-order add-to-cart"
                      data-id={part.id}
                      data-name={part.name}
                      data-retail={retailPrice(part)}
                      data-master={masterPrice(part)}
                      data-condition={part.condition}
                    >
                      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
                      В корзину
                    </button>
                  </div>
                ))}
              </div>

              <div class="no-results" id="no-results" style="display:none">
                <p>По выбранным фильтрам ничего не найдено.</p>
                <button id="reset-filters">Сбросить фильтры</button>
              </div>
            </div>
          </div>
        </div>

        <!-- Not found block -->
        <div class="not-found-block">
          <div class="not-found-inner">
            <h3>Не нашли нужную запчасть?</h3>
            <p>Подберём и доставим под заказ. Работаем с поставщиками по всей России.</p>
            <a href={SITE.telegram} target="_blank" class="btn-tg">Написать в Telegram</a>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="cta-section">
      <div class="container">
        <div class="cta-block">
          <h2>Нужна консультация по запчастям?</h2>
          <p>Мастер поможет подобрать нужную деталь под вашу модель</p>
          <TelegramButtons context="Здравствуйте! Нужна консультация по запчастям." />
          <div class="cta-phone">
            <span>Или позвоните:</span>
            <a href={`tel:+${SITE.phoneRaw}`}>{SITE.phone}</a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />
</Layout>

<!-- Pass subcategory map to client -->
<script define:vars={{ subcategoriesMap }}>
  const allCards = Array.from(document.querySelectorAll('#all-grid .part-card'));
  const popularCards = Array.from(document.querySelectorAll('#popular-grid .part-card'));
  const countEl = document.getElementById('results-count');
  const noResults = document.getElementById('no-results');
  const popularStrip = document.getElementById('popular-strip');
  const allTitle = document.getElementById('all-parts-title');
  const subcatsPanel = document.getElementById('subcats-panel');
  const subcatsList = document.getElementById('subcats-list');
  const subcatsTitle = document.getElementById('subcats-title');

  let activeCat = 'all';
  let activeSub = 'all';
  let showNew = true;
  let showUsed = true;
  let onlyInStock = false;

  function buildSubcats(cat) {
    subcatsList.innerHTML = '';
    if (!subcategoriesMap[cat]) return;
    const all = document.createElement('button');
    all.className = 'sub-btn active';
    all.dataset.sub = 'all';
    all.textContent = 'Все';
    all.addEventListener('click', () => selectSub('all'));
    subcatsList.appendChild(all);

    subcategoriesMap[cat].forEach(sub => {
      const btn = document.createElement('button');
      btn.className = 'sub-btn';
      btn.dataset.sub = sub;
      btn.textContent = sub;
      btn.addEventListener('click', () => selectSub(sub));
      subcatsList.appendChild(btn);
    });
  }

  function selectCat(cat) {
    activeCat = cat;
    activeSub = 'all';

    document.querySelectorAll('.side-btn').forEach(b => b.classList.remove('active'));
    document.querySelectorAll(`.side-btn[data-cat="${cat}"]`).forEach(b => {
      if (b.dataset.sub === 'all') b.classList.add('active');
    });

    document.querySelectorAll('.cat-pill').forEach(b => {
      b.classList.toggle('active', b.dataset.cat === cat);
    });

    if (cat !== 'all') {
      buildSubcats(cat);
      subcatsTitle.textContent = cat;
      subcatsPanel.style.display = '';
    } else {
      subcatsPanel.style.display = 'none';
    }

    applyFilters();
  }

  function selectSub(sub) {
    activeSub = sub;
    document.querySelectorAll('.sub-btn').forEach(b => b.classList.remove('active'));
    document.querySelectorAll(`.sub-btn[data-sub="${sub}"]`).forEach(b => b.classList.add('active'));
    applyFilters();
  }

  function cardMatches(card) {
    const cat = card.dataset.cat;
    const sub = card.dataset.sub;
    const condition = card.dataset.condition;
    const instock = card.dataset.instock === '1';

    if (activeCat !== 'all' && cat !== activeCat) return false;
    if (activeSub !== 'all' && sub !== activeSub) return false;
    if (!showNew && condition === 'Новый') return false;
    if (!showUsed && condition === 'Б/У') return false;
    if (onlyInStock && !instock) return false;
    return true;
  }

  function applyFilters() {
    let visible = 0;

    allCards.forEach(card => {
      const show = cardMatches(card);
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    // Popular strip: only when showing all
    const showPopular = activeCat === 'all' && activeSub === 'all' && !onlyInStock && showNew && showUsed;
    popularStrip.style.display = showPopular ? '' : 'none';
    allTitle.textContent = showPopular ? 'Все запчасти' : (activeCat !== 'all' ? activeCat : 'Результаты');

    countEl.textContent = `${visible} товаров`;
    noResults.style.display = visible === 0 ? '' : 'none';
  }

  // Category pills in hero
  document.querySelectorAll('.cat-pill').forEach(btn => {
    btn.addEventListener('click', () => selectCat(btn.dataset.cat));
  });

  // Sidebar category buttons
  document.querySelectorAll('.side-btn[data-cat]').forEach(btn => {
    btn.addEventListener('click', () => {
      if (btn.dataset.sub === 'all') selectCat(btn.dataset.cat);
    });
  });

  // Checkboxes
  document.getElementById('filter-new').addEventListener('change', e => {
    showNew = e.target.checked; applyFilters();
  });
  document.getElementById('filter-used').addEventListener('change', e => {
    showUsed = e.target.checked; applyFilters();
  });
  document.getElementById('filter-instock').addEventListener('change', e => {
    onlyInStock = e.target.checked; applyFilters();
  });

  // Reset
  document.getElementById('reset-filters').addEventListener('click', () => {
    activeCat = 'all'; activeSub = 'all';
    showNew = true; showUsed = true; onlyInStock = false;
    document.getElementById('filter-new').checked = true;
    document.getElementById('filter-used').checked = true;
    document.getElementById('filter-instock').checked = false;
    document.querySelectorAll('.side-btn').forEach(b => b.classList.remove('active'));
    document.querySelector('.side-btn[data-cat="all"]').classList.add('active');
    document.querySelectorAll('.cat-pill').forEach(b => b.classList.remove('active'));
    subcatsPanel.style.display = 'none';
    applyFilters();
  });

  // Mobile sidebar toggle
  const mobileBtn = document.getElementById('mobile-filter-btn');
  const sidebar = document.getElementById('sidebar');
  mobileBtn.addEventListener('click', () => {
    sidebar.classList.toggle('open');
    mobileBtn.textContent = sidebar.classList.contains('open') ? 'Закрыть' : 'Фильтры';
  });

  // ── Cart logic ──
  function getCart() {
    try { return JSON.parse(localStorage.getItem('cart') || '[]'); } catch { return []; }
  }
  function saveCart(cart) {
    localStorage.setItem('cart', JSON.stringify(cart));
    window.dispatchEvent(new Event('cart-updated'));
  }

  document.querySelectorAll('.add-to-cart').forEach(btn => {
    btn.addEventListener('click', () => {
      const { id, name, retail, master, condition } = btn.dataset;
      const cart = getCart();
      const existing = cart.find(i => i.id === id);
      if (existing) {
        existing.qty = (existing.qty || 1) + 1;
      } else {
        cart.push({ id, name, retail: Number(retail), master: Number(master), condition, qty: 1 });
      }
      saveCart(cart);

      btn.textContent = '✓ Добавлено';
      btn.classList.add('added');
      setTimeout(() => {
        btn.innerHTML = '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg> В корзину';
        btn.classList.remove('added');
      }, 1500);
    });
  });
</script>

<style>
  /* ── Base ── */
  .container { max-width: 1200px; margin: 0 auto; padding: 0 20px; }

  /* ── Hero ── */
  .shop-hero {
    padding: 24px 0 56px;
    background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 60%, #bfdbfe 100%);
  }

  .hero-content {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 48px;
    align-items: start;
  }

  .hero-badges { display: flex; gap: 8px; margin-bottom: 20px; flex-wrap: wrap; }
  .badge {
    display: inline-block;
    padding: 5px 14px;
    border-radius: 100px;
    font-size: 0.8rem;
    font-weight: 600;
  }
  .badge-blue { background: rgba(29,78,216,0.12); color: #1d4ed8; }
  .badge-green { background: rgba(22,163,74,0.12); color: #15803d; }

  .shop-hero h1 {
    font-size: 2.6rem;
    font-weight: 800;
    line-height: 1.15;
    color: #0f172a;
    margin-bottom: 20px;
  }
  .accent { color: #1d4ed8; }

  .hero-desc {
    font-size: 1.05rem;
    color: #475569;
    line-height: 1.7;
    margin-bottom: 28px;
    max-width: 600px;
  }

  .hero-stats {
    display: flex;
    gap: 32px;
    margin-bottom: 32px;
  }
  .stat { display: flex; flex-direction: column; }
  .stat strong { font-size: 1.6rem; font-weight: 800; color: #1d4ed8; line-height: 1; }
  .stat span { font-size: 0.8rem; color: #64748b; margin-top: 4px; }

  .hero-categories {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .cat-pill {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 18px;
    background: #fff;
    border: 1.5px solid #e2e8f0;
    border-radius: 14px;
    cursor: pointer;
    transition: all 0.2s;
    font-family: inherit;
    text-align: left;
  }
  .cat-pill:hover, .cat-pill.active {
    border-color: #1d4ed8;
    background: #eff6ff;
    box-shadow: 0 4px 16px rgba(29,78,216,0.1);
  }
  .cat-icon { font-size: 1.4rem; }
  .cat-name { font-size: 0.9rem; font-weight: 600; color: #0f172a; flex: 1; }
  .cat-count {
    font-size: 0.75rem;
    font-weight: 700;
    background: #e0e7ff;
    color: #1d4ed8;
    padding: 2px 8px;
    border-radius: 20px;
  }

  /* ── Master banner ── */
  .master-banner {
    background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 100%);
    padding: 20px 0;
  }
  .master-inner {
    display: flex;
    align-items: center;
    gap: 20px;
  }
  .master-icon { font-size: 2rem; }
  .master-text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .master-text strong { color: #fff; font-size: 1rem; }
  .master-text span { color: #94a3b8; font-size: 0.85rem; }
  .master-cta {
    padding: 10px 22px;
    background: #1d4ed8;
    color: #fff;
    border-radius: 10px;
    font-weight: 600;
    font-size: 0.9rem;
    white-space: nowrap;
    transition: background 0.2s;
  }
  .master-cta:hover { background: #1e40af; }

  /* ── Catalog layout ── */
  .catalog-section { padding: 56px 0 40px; }

  .catalog-layout {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 32px;
    align-items: start;
  }

  /* ── Sidebar ── */
  .sidebar {
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 16px;
    padding: 20px;
    position: sticky;
    top: 80px;
  }
  .sidebar-section { margin-bottom: 24px; }
  .sidebar-section:last-child { margin-bottom: 0; }
  .sidebar-section h3 {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #94a3b8;
    margin-bottom: 10px;
  }
  .side-btn {
    display: block;
    width: 100%;
    text-align: left;
    padding: 8px 12px;
    border: none;
    border-radius: 8px;
    background: transparent;
    font-size: 0.875rem;
    color: #475569;
    cursor: pointer;
    transition: all 0.15s;
    font-family: inherit;
    margin-bottom: 2px;
  }
  .side-btn:hover { background: #e0e7ff; color: #1d4ed8; }
  .side-btn.active { background: #1d4ed8; color: #fff; }
  .sub-btn {
    display: block;
    width: 100%;
    text-align: left;
    padding: 6px 10px;
    border: none;
    border-radius: 6px;
    background: transparent;
    font-size: 0.82rem;
    color: #64748b;
    cursor: pointer;
    transition: all 0.15s;
    font-family: inherit;
    margin-bottom: 2px;
  }
  .sub-btn:hover { background: #e0e7ff; color: #1d4ed8; }
  .sub-btn.active { background: #dbeafe; color: #1d4ed8; font-weight: 600; }
