---
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import FloatingButton from '../../components/FloatingButton.astro';
import { SITE } from '../../data/services';

const title = 'Диагностика техники онлайн — опишите проблему в мессенджере | Master-Tehniki74';
const description = 'Опишите симптом неисправности в Telegram или WhatsApp — мастер ответит за 5 минут и поставит предварительный диагноз бесплатно.';
---

<Layout
  title={title}
  description={description}
  keywords="диагностика техники онлайн, диагностика холодильника, ремонт стиральной машины онлайн, мастер в telegram, бесплатная диагностика"
  canonical="/diagnostika/"
  geoRegion="RU-CHE"
  geoPlace="Миасс"
>
  <SiteHeader />
  <FloatingButton />

  <main>
    <!-- Hero -->
    <section class="diag-hero">
      <div class="container">
        <div class="hero-badge">Бесплатно · Ответ за 5 минут</div>
        <h1>Диагностика техники<br>через мессенджер</h1>
        <p class="hero-sub">Опишите, что случилось с техникой — мастер поставит предварительный диагноз и назовёт примерную стоимость ещё до выезда</p>
        <div class="hero-messengers">
          <a href={SITE.telegram} target="_blank" rel="noopener noreferrer" class="btn-messenger btn-tg">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
            Написать в Telegram
          </a>
          <a href={SITE.whatsapp} target="_blank" rel="noopener noreferrer" class="btn-messenger btn-wa">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
            Написать в WhatsApp
          </a>
        </div>
        <div class="hero-note">Или воспользуйтесь интерактивным помощником ниже — выберите симптом и получите подсказку мгновенно</div>
      </div>
    </section>

    <!-- Interactive symptom checker -->
    <section class="checker-section">
      <div class="container">
        <div class="checker-wrap" id="checker">

          <!-- Step 1: appliance -->
          <div class="step active" id="step-1">
            <div class="step-num">Шаг 1 из 3</div>
            <h2>Какая техника не работает?</h2>
            <div class="opts-grid">
              <button class="opt-card" data-next="2" data-app="holodilnik" data-app-label="Холодильник">
                <span class="opt-icon">
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2"/><line x1="4" y1="10" x2="20" y2="10"/></svg>
                </span>
                <span>Холодильник</span>
              </button>
              <button class="opt-card" data-next="2" data-app="stiralnaya" data-app-label="Стиральная машина">
                <span class="opt-icon">
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="2" width="18" height="20" rx="2"/><circle cx="12" cy="13" r="4"/><line x1="3" y1="7" x2="21" y2="7"/></svg>
                </span>
                <span>Стиральная машина</span>
              </button>
              <button class="opt-card" data-next="2" data-app="elektroplita" data-app-label="Электроплита / духовка">
                <span class="opt-icon">
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="6" width="20" height="14" rx="2"/><circle cx="8" cy="13" r="3"/><circle cx="16" cy="13" r="3"/></svg>
                </span>
                <span>Электроплита / духовка</span>
              </button>
              <button class="opt-card" data-next="2" data-app="mikrovolnovka" data-app-label="Микроволновка">
                <span class="opt-icon">
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><rect x="4" y="6" width="12" height="12" rx="1"/></svg>
                </span>
                <span>Микроволновка</span>
              </button>
              <button class="opt-card" data-next="2" data-app="posudomoechnaya" data-app-label="Посудомоечная машина">
                <span class="opt-icon">
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="2" width="18" height="20" rx="2"/><path d="M7 10h10M7 14h10"/></svg>
                </span>
                <span>Посудомоечная машина</span>
              </button>
              <button class="opt-card" data-next="2" data-app="pylesos" data-app-label="Пылесос">
                <span class="opt-icon">
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="3"/></svg>
                </span>
                <span>Пылесос</span>
              </button>
              <button class="opt-card" data-next="2" data-app="kofemasina" data-app-label="Кофемашина">
                <span class="opt-icon">
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 8h1a4 4 0 0 1 0 8h-1"/><rect x="3" y="8" width="14" height="12" rx="2"/><line x1="3" y1="12" x2="17" y2="12"/></svg>
                </span>
                <span>Кофемашина</span>
              </button>
              <button class="opt-card" data-next="2" data-app="other" data-app-label="Другая техника">
                <span class="opt-icon">
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                </span>
                <span>Другая</span>
              </button>
            </div>
          </div>

          <!-- Step 2: symptoms (populated dynamically) -->
          <div class="step" id="step-2">
            <button class="back-btn" id="back-1">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
              Назад
            </button>
            <div class="step-num">Шаг 2 из 3</div>
            <h2>Что именно происходит?</h2>
            <div class="opts-grid" id="symptoms-grid"></div>
          </div>

          <!-- Step 3: result -->
          <div class="step" id="step-3">
            <button class="back-btn" id="back-2">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
              Назад
            </button>
            <div class="step-num">Шаг 3 из 3</div>
            <h2>Уточните несколько деталей</h2>
            <div class="age-question">
              <p class="age-label">Сколько лет технике?</p>
              <div class="age-opts">
                <button class="age-opt" data-age="до 3 лет">До 3 лет</button>
                <button class="age-opt" data-age="3–7 лет">3–7 лет</button>
                <button class="age-opt" data-age="7–12 лет">7–12 лет</button>
                <button class="age-opt" data-age="более 12 лет">Более 12 лет</button>
              </div>
            </div>
          </div>

          <!-- Step 4: diagnosis result -->
          <div class="step" id="step-4">
            <div class="result-wrap">
              <div class="result-icon">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              </div>
              <h2 id="result-title">Предварительный диагноз</h2>
              <div class="result-diagnosis" id="result-diagnosis"></div>
              <div class="result-price" id="result-price"></div>
              <p class="result-note">Точную стоимость назовём после осмотра. Диагностика на дому — <strong>бесплатно</strong> при ремонте</p>
              <div class="result-actions">
                <a href={SITE.telegram} target="_blank" rel="noopener noreferrer" class="result-btn result-btn--tg">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
                  Уточнить в Telegram
                </a>
                <a href={SITE.whatsapp} target="_blank" rel="noopener noreferrer" class="result-btn result-btn--wa">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
                  Уточнить в WhatsApp
                </a>
                <a href={`tel:+${SITE.phoneRaw}`} class="result-btn result-btn--call">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                  Позвонить мастеру
                </a>
              </div>
              <button class="restart-btn" id="restart-btn">Начать заново</button>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- How it works -->
    <section class="how-section">
      <div class="container">
        <div class="section-header">
          <h2>Как работает онлайн-диагностика</h2>
          <p>Три простых шага до ясности</p>
        </div>
        <div class="steps-grid">
          <div class="how-step">
            <div class="how-num">1</div>
            <h3>Опишите симптом</h3>
            <p>Напишите в мессенджер или пройдите квиз-помощник — укажите технику и что именно происходит</p>
          </div>
          <div class="how-step">
            <div class="how-num">2</div>
            <h3>Мастер отвечает за 5 минут</h3>
            <p>Специалист задаст уточняющие вопросы и поставит предварительный диагноз по описанию</p>
          </div>
          <div class="how-step">
            <div class="how-num">3</div>
            <h3>Называем цену до выезда</h3>
            <p>Вы узнаёте примерную стоимость ремонта и принимаете решение без обязательств</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Benefits -->
    <section class="benefits-section">
      <div class="container">
        <div class="benefits-grid">
          <div class="benefit-card">
            <div class="benefit-icon benefit-icon--green">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div>
              <h4>Диагностика бесплатно</h4>
              <p>При ремонте — стоимость диагностики включена в счёт</p>
            </div>
          </div>
          <div class="benefit-card">
            <div class="benefit-icon benefit-icon--blue">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div>
              <h4>Ответ за 5 минут</h4>
              <p>Работаем ежедневно с 9:00 до 20:00 по Челябинску</p>
            </div>
          </div>
          <div class="benefit-card">
            <div class="benefit-icon benefit-icon--orange">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
            </div>
            <div>
              <h4>14 лет опыта</h4>
              <p>Мастер знает типичные поломки наизусть — диагностирует по описанию точно</p>
            </div>
          </div>
          <div class="benefit-card">
            <div class="benefit-icon benefit-icon--teal">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            </div>
            <div>
              <h4>Без обязательств</h4>
              <p>Можно узнать стоимость и отказаться — никакого давления</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="cta-section">
      <div class="container">
        <div class="cta-box">
          <h2>Не нашли свою проблему в списке?</h2>
          <p>Напишите прямо — опишите своими словами, что происходит с техникой</p>
          <div class="cta-btns">
            <a href={SITE.telegram} target="_blank" rel="noopener noreferrer" class="cta-btn cta-btn--tg">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
              Telegram
            </a>
            <a href={SITE.whatsapp} target="_blank" rel="noopener noreferrer" class="cta-btn cta-btn--wa">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
