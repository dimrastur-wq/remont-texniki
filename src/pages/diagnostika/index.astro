    ],
    kofemasina: [
      { label: 'Не варит кофе (нет воды)', diagnosis: 'Засорена или неисправна помпа подачи воды. Также возможно накипеобразование трактов.', price: 'Примерная стоимость: 1 000 – 4 000 ₽' },
      { label: 'Течёт снизу', diagnosis: 'Трещина в поддоне, повреждение шланга или прокладки группы.', price: 'Примерная стоимость: 800 – 3 000 ₽' },
      { label: 'Не молет кофе', diagnosis: 'Засор или износ жерновов кофемолки. Могут быть повреждены шестерни привода.', price: 'Примерная стоимость: 1 200 – 5 000 ₽' },
      { label: 'Не включается', diagnosis: 'Неисправна плата управления или термопредохранитель.', price: 'Примерная стоимость: 1 500 – 6 000 ₽' },
    ],
    other: [
      { label: 'Не включается', diagnosis: 'Для точного диагноза нужно знать тип техники. Напишите нам — ответим в течение 5 минут.', price: 'Стоимость уточняется после описания' },
      { label: 'Шум / посторонние звуки', diagnosis: 'Напишите нам с указанием модели — мастер поставит диагноз по описанию.', price: 'Стоимость уточняется после описания' },
      { label: 'Другая проблема', diagnosis: 'Опишите проблему своими словами в мессенджере — мастер разберётся.', price: 'Стоимость уточняется после описания' },
    ],
  };

  let selectedApp = '';
  let selectedAppLabel = '';
  let selectedSymptom: {label: string; diagnosis: string; price: string} | null = null;
  let selectedAge = '';

  function showStep(id: string) {
    document.querySelectorAll('.step').forEach(s => s.classList.remove('active'));
    const el = document.getElementById(id);
    if (el) {
      el.classList.add('active');
      el.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  }

  function buildSymptoms() {
    const grid = document.getElementById('symptoms-grid');
    if (!grid) return;
    grid.innerHTML = '';
    const symptoms = SYMPTOMS[selectedApp] || SYMPTOMS.other;
    symptoms.forEach((s, i) => {
      const btn = document.createElement('button');
      btn.className = 'symptom-opt';
      btn.innerHTML = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg> ${s.label}`;
      btn.addEventListener('click', () => {
        selectedSymptom = s;
        showStep('step-3');
      });
      grid.appendChild(btn);
    });
  }

  // Step 1 -> 2
  document.querySelectorAll('.opt-card').forEach(btn => {
    btn.addEventListener('click', () => {
      selectedApp = (btn as HTMLElement).dataset.app || 'other';
      selectedAppLabel = (btn as HTMLElement).dataset.appLabel || '';
      buildSymptoms();
      showStep('step-2');
    });
  });

  // Age -> result
  document.querySelectorAll('.age-opt').forEach(btn => {
    btn.addEventListener('click', () => {
      selectedAge = (btn as HTMLElement).dataset.age || '';
      showResult();
      showStep('step-4');
    });
  });

  function showResult() {
    if (!selectedSymptom) return;
    const titleEl = document.getElementById('result-title');
    const diagEl = document.getElementById('result-diagnosis');
    const priceEl = document.getElementById('result-price');

    if (titleEl) titleEl.textContent = `Диагноз: ${selectedAppLabel}`;
    if (diagEl) diagEl.innerHTML = `<strong>${selectedSymptom.label}</strong><br><br>${selectedSymptom.diagnosis}`;
    if (priceEl) {
      let priceText = selectedSymptom.price;
      if (selectedAge === 'более 12 лет') {
        priceText += ' (возможна надбавка за сложность разборки)';
      }
      priceEl.textContent = priceText;
    }
  }

  // Back buttons
  document.getElementById('back-1')?.addEventListener('click', () => showStep('step-1'));
  document.getElementById('back-2')?.addEventListener('click', () => showStep('step-2'));

  // Restart
  document.getElementById('restart-btn')?.addEventListener('click', () => {
    selectedApp = '';
    selectedAppLabel = '';
    selectedSymptom = null;
    selectedAge = '';
    showStep('step-1');
  });
</script>
