---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import FloatingButton from '../../components/FloatingButton.astro';
import TelegramButtons from '../../components/TelegramButtons.astro';
import { SITE } from '../../data/services';
import { ERROR_CODES } from '../../data/errors';

export function getStaticPaths() {
  return ERROR_CODES.map(err => ({
    params: { slug: err.slug },
    props: { errSlug: err.slug },
  }));
}

const { errSlug } = Astro.props;
const err = ERROR_CODES.find(e => e.slug === errSlug)!;

const related = ERROR_CODES.filter(e => e.brand === err.brand && e.slug !== err.slug).slice(0, 4);

const urgencyLabel: Record<string, string> = {
  high: 'Срочно нужен мастер',
  medium: 'Нужен мастер',
  low: 'Можно решить самостоятельно',
};
const urgencyColor: Record<string, string> = {
  high: '#dc2626',
  medium: '#d97706',
  low: '#16a34a',
};

const title = `${err.title} — расшифровка и ремонт | Центр восстановления бытовой техники`;
const description = `Ошибка ${err.code} на ${err.appliance} ${err.brand}: ${err.meaning} Причины, что делать самому, когда звать мастера. Ремонт ${err.repairPrice}.`;

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": err.title,
  "description": description,
  "author": {
    "@type": "Organization",
    "name": "Центр восстановления бытовой техники",
  },
  "publisher": {
    "@type": "Organization",
    "name": "Центр восстановления бытовой техники",
    "url": SITE.url,
  },
  "mainEntityOfPage": `${SITE.url}/oshibki/${err.slug}/`,
});

const breadcrumbSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Главная", "item": SITE.url },
    { "@type": "ListItem", "position": 2, "name": "Коды ошибок", "item": `${SITE.url}/oshibki/` },
    { "@type": "ListItem", "position": 3, "name": `${err.brand} ${err.code}`, "item": `${SITE.url}/oshibki/${err.slug}/` },
  ],
});
---

<Layout
  title={title}
  description={description}
  keywords={err.keywords.join(', ')}
  canonical={`/oshibki/${err.slug}/`}
  schema={`${schema}\n${breadcrumbSchema}`}
  geoRegion="RU-CHE"
  geoPlace="Миасс"
>
  <SiteHeader />

  <main>
    <section class="breadcrumbs-bar">
      <div class="container">
        <nav class="breadcrumbs" aria-label="Навигация">
          <a href="/">Главная</a>
          <span class="sep">/</span>
          <a href="/oshibki/">Коды ошибок</a>
          <span class="sep">/</span>
          <span>{err.brand} {err.code}</span>
        </nav>
      </div>
    </section>

    <section class="hero">
      <div class="container">
        <div class="hero-inner">
          <div class="hero-meta">
            <span class="brand-tag">{err.brand}</span>
            <span class="appliance-tag">{err.appliance}</span>
            <span class="urgency-tag" style={`color:${urgencyColor[err.urgency]};background:${urgencyColor[err.urgency]}18`}>
              {urgencyLabel[err.urgency]}
            </span>
          </div>
          <h1>Ошибка <span class="code-highlight">{err.code}</span> {err.appliance.charAt(0).toUpperCase() + err.appliance.slice(1) + 'а'} {err.brand}</h1>
          <p class="meaning">{err.meaning}</p>
          <div class="price-block">
            <span class="price-label">Стоимость ремонта:</span>
            <span class="price-value">{err.repairPrice}</span>
          </div>
        </div>
      </div>
    </section>

    <div class="container content-layout">
      <div class="main-content">

        <section class="content-card">
          <h2>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#1d4ed8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            Почему появляется ошибка {err.code}
          </h2>
          <ul class="causes-list">
            {err.causes.map(cause => (
              <li>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#64748b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                {cause}
              </li>
            ))}
          </ul>
        </section>

        <section class="content-card diy-card">
          <h2>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
            Что можно проверить самостоятельно
          </h2>
          <ol class="diy-list">
            {err.diySteps.map((step, i) => (
              <li>
                <span class="step-num">{i + 1}</span>
                <span>{step}</span>
              </li>
            ))}
          </ol>
        </section>

        <section class="content-card warning-card">
          <h2>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            Когда нужен мастер
          </h2>
          <p>{err.whenCallMaster}</p>
          <div class="call-to-action">
            <TelegramButtons context={`Здравствуйте! На ${err.appliance} ${err.brand} ошибка ${err.code}. Нужна помощь.`} />
          </div>
        </section>

      </div>

      <aside class="sidebar">
        <div class="sidebar-card">
          <div class="sidebar-code">{err.code}</div>
          <div class="sidebar-brand">{err.brand} · {err.appliance}</div>
          <div class="sidebar-price">{err.repairPrice}</div>
          <div class="sidebar-urgency" style={`color:${urgencyColor[err.urgency]}`}>{urgencyLabel[err.urgency]}</div>
          <a href={SITE.telegram} target="_blank" rel="noopener noreferrer" class="sidebar-btn sidebar-btn--tg">
            Написать в Telegram
          </a>
          <a href={`tel:+${SITE.phoneRaw}`} class="sidebar-btn sidebar-btn--call">
            {SITE.phone}
          </a>
          <div class="sidebar-info">
            <div class="info-row">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              {SITE.workHours}
            </div>
            <div class="info-row">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              Миасс, Златоуст, Чебаркуль
            </div>
          </div>
        </div>

        {related.length > 0 && (
          <div class="sidebar-card related-card">
            <div class="related-title">Другие ошибки {err.brand}</div>
            <div class="related-list">
              {related.map(r => (
                <a href={`/oshibki/${r.slug}/`} class="related-item">
                  <span class="related-code">{r.code}</span>
                  <span class="related-text">{r.meaning.slice(0, 48)}…</span>
                </a>
              ))}
            </div>
          </div>
        )}

        <div class="sidebar-card nav-card">
          <a href="/oshibki/" class="all-errors-link">
            &larr; Все коды ошибок
          </a>
        </div>
      </aside>
    </div>
  </main>

  <SiteFooter />
  <FloatingButton />
</Layout>

<style>
  .breadcrumbs-bar {
    background: #f8fafc;
    border-bottom: 1px solid #e2e8f0;
    padding: 12px 0;
  }

  .breadcrumbs {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.82rem;
    color: #94a3b8;
    flex-wrap: wrap;
  }

  .breadcrumbs a { color: #64748b; transition: color 0.2s; }
  .breadcrumbs a:hover { color: #1d4ed8; }
  .breadcrumbs span:last-child { color: #0f172a; font-weight: 500; }
  .sep { color: #cbd5e1; }

  .hero {
    background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 100%);
    padding: 56px 0 48px;
    color: #fff;
  }

  .hero-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 16px;
  }

  .brand-tag, .appliance-tag {
    font-size: 0.75rem;
    font-weight: 600;
    padding: 4px 12px;
    border-radius: 100px;
    background: rgba(255,255,255,0.12);
    color: #e2e8f0;
  }

  .urgency-tag {
    font-size: 0.75rem;
    font-weight: 700;
    padding: 4px 12px;
    border-radius: 100px;
  }

  .hero h1 {
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    font-weight: 800;
    color: #fff;
    line-height: 1.2;
    margin-bottom: 12px;
  }

  .code-highlight {
    color: #60a5fa;
    font-family: monospace;
  }

  .meaning {
    font-size: 1.05rem;
    color: #94a3b8;
    line-height: 1.6;
    max-width: 600px;
    margin-bottom: 20px;
  }

  .price-block {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.12);
    padding: 8px 18px;
    border-radius: 8px;
  }

  .price-label { font-size: 0.82rem; color: #94a3b8; }
  .price-value { font-size: 1rem; font-weight: 700; color: #4ade80; }

  .content-layout {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 32px;
    padding-top: 40px;
    padding-bottom: 64px;
    align-items: start;
  }

  .main-content { display: flex; flex-direction: column; gap: 24px; }

  .content-card {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 16px;
    padding: 28px;
  }

  .content-card h2 {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 1.1rem;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 18px;
  }

  .causes-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .causes-list li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 0.9rem;
    color: #475569;
    line-height: 1.5;
  }

  .causes-list li svg { flex-shrink: 0; margin-top: 3px; }

  .diy-card { border-color: #bbf7d0; }

  .diy-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .diy-list li {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    font-size: 0.9rem;
    color: #475569;
    line-height: 1.5;
  }

  .step-num {
    min-width: 26px;
    height: 26px;
    background: #dcfce7;
    color: #166534;
    font-size: 0.78rem;
    font-weight: 700;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .warning-card { border-color: #fde68a; background: #fffbeb; }

  .warning-card p {
    font-size: 0.9rem;
    color: #92400e;
    line-height: 1.6;
    margin-bottom: 20px;
  }

  .sidebar { display: flex; flex-direction: column; gap: 16px; }

  .sidebar-card {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 16px;
    padding: 20px;
  }

  .sidebar-code {
    font-size: 2rem;
    font-weight: 800;
    color: #1d4ed8;
    font-family: monospace;
    line-height: 1;
    margin-bottom: 4px;
  }

  .sidebar-brand {
    font-size: 0.82rem;
    color: #94a3b8;
    margin-bottom: 12px;
    text-transform: capitalize;
  }

  .sidebar-price {
    font-size: 1.1rem;
    font-weight: 700;
    color: #16a34a;
    margin-bottom: 4px;
  }

  .sidebar-urgency {
    font-size: 0.8rem;
    font-weight: 600;
    margin-bottom: 18px;
  }

  .sidebar-btn {
    display: block;
    width: 100%;
    text-align: center;
    padding: 11px 16px;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.88rem;
    color: #fff;
    margin-bottom: 8px;
    transition: filter 0.2s;
  }

  .sidebar-btn:hover { filter: brightness(1.1); }
  .sidebar-btn--tg { background: #0088cc; }
  .sidebar-btn--call { background: #1d4ed8; }

  .sidebar-info { margin-top: 14px; display: flex; flex-direction: column; gap: 6px; }

  .info-row {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.78rem;
    color: #64748b;
  }

  .related-title {
    font-size: 0.85rem;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 12px;
  }

  .related-list { display: flex; flex-direction: column; gap: 8px; }

  .related-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 8px 10px;
    background: #f8fafc;
    border-radius: 8px;
    transition: background 0.2s;
  }

  .related-item:hover { background: #eff6ff; }

  .related-code {
    font-size: 0.82rem;
    font-weight: 700;
    color: #1d4ed8;
    font-family: monospace;
    white-space: nowrap;
    min-width: 42px;
  }

  .related-text {
    font-size: 0.78rem;
    color: #64748b;
    line-height: 1.4;
  }

  .all-errors-link {
    display: block;
    font-size: 0.85rem;
    font-weight: 600;
    color: #1d4ed8;
    text-align: center;
  }

  .all-errors-link:hover { text-decoration: underline; }

  @media (max-width: 900px) {
    .content-layout {
      grid-template-columns: 1fr;
    }

    .sidebar { order: -1; }
    .sidebar-card:first-child { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; align-items: start; }
  }

  @media (max-width: 600px) {
    .hero { padding: 40px 0 32px; }
    .sidebar-card:first-child { grid-template-columns: 1fr; }
  }
</style>
