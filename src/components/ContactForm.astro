---
const phone = '8 (951) 257-77-57';
const phoneRaw = '79512577757';
---

<section class="contact" id="contact">
  <div class="container">
    <div class="contact-layout">
      <div class="contact-info">
        <span class="section-label">Свяжитесь с нами</span>
        <h2>Оставьте заявку на ремонт</h2>
        <p class="contact-desc">
          Заполните форму или позвоните — мастер перезвонит в течение 15 минут и согласует удобное время выезда.
        </p>

        <div class="contact-details">
          <div class="detail-item">
            <div class="detail-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
              </svg>
            </div>
            <div>
              <span class="detail-label">Телефон</span>
              <a href={`tel:+${phoneRaw}`} class="detail-value link">{phone}</a>
            </div>
          </div>

          <div class="detail-item">
            <div class="detail-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                <circle cx="12" cy="10" r="3" />
              </svg>
            </div>
            <div>
              <span class="detail-label">Адрес мастерской</span>
              <span class="detail-value">г. Миасс, ул. Победы, д. 18, цоколь</span>
            </div>
          </div>

          <div class="detail-item">
            <div class="detail-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10" />
                <polyline points="12 6 12 12 16 14" />
              </svg>
            </div>
            <div>
              <span class="detail-label">Время работы</span>
              <span class="detail-value">Ежедневно с 9:00 до 20:00</span>
            </div>
          </div>
        </div>
      </div>

      <form class="contact-form" id="request-form">
        <div class="form-group">
          <label for="name">Ваше имя</label>
          <input type="text" id="name" name="name" placeholder="Иван Иванов" required />
        </div>

        <div class="form-group">
          <label for="phone-input">Телефон</label>
          <input type="tel" id="phone-input" name="phone" placeholder="+7 (___) ___-__-__" required />
        </div>

        <div class="form-group">
          <label for="city">Город</label>
          <select id="city" name="city" required>
            <option value="" disabled selected>Выберите город</option>
            <option value="miass">Миасс</option>
            <option value="zlatoust">Златоуст</option>
            <option value="chebarkul">Чебаркуль</option>
          </select>
        </div>

        <div class="form-group">
          <label for="appliance">Тип техники</label>
          <select id="appliance" name="appliance" required>
            <option value="" disabled selected>Что нужно починить?</option>
            <option value="fridge">Холодильник</option>
            <option value="washer">Стиральная машина</option>
            <option value="microwave">Микроволновка</option>
            <option value="dishwasher">Посудомоечная машина</option>
            <option value="other">Другое</option>
          </select>
        </div>

        <div class="form-group">
          <label for="message">Опишите проблему</label>
          <textarea id="message" name="message" rows="3" placeholder="Например: холодильник не морозит, компрессор гудит..."></textarea>
        </div>

        <button type="submit" class="submit-btn">
          Отправить заявку
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12" />
            <polyline points="12 5 19 12 12 19" />
          </svg>
        </button>

        <p class="form-note">Нажимая кнопку, вы соглашаетесь с обработкой персональных данных</p>
      </form>
    </div>
  </div>
</section>

<style>
  .contact {
    padding: 96px 0;
    background: #f8fafc;
  }

  .section-label {
    display: inline-block;
    padding: 4px 14px;
    background: #eff6ff;
    color: #1d4ed8;
    border-radius: 100px;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 16px;
  }

  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: start;
  }

  .contact-info h2 {
    font-size: 2.25rem;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 16px;
  }

  .contact-desc {
    font-size: 1.05rem;
    color: #64748b;
    line-height: 1.7;
    margin-bottom: 40px;
  }

  .contact-details {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .detail-item {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .detail-icon {
    width: 48px;
    height: 48px;
    min-width: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #eff6ff;
    border-radius: 12px;
    color: #1d4ed8;
  }

  .detail-label {
    display: block;
    font-size: 0.8rem;
    color: #94a3b8;
    margin-bottom: 2px;
  }

  .detail-value {
    font-size: 1rem;
    font-weight: 500;
    color: #0f172a;
  }

  .detail-value.link {
    color: #1d4ed8;
    transition: color 0.2s;
  }

  .detail-value.link:hover {
    color: #1e40af;
  }

  .contact-form {
    background: #fff;
    padding: 40px;
    border-radius: 20px;
    border: 1px solid #e2e8f0;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.04);
  }

  .form-group {
    margin-bottom: 20px;
  }

  .form-group label {
    display: block;
    font-size: 0.85rem;
    font-weight: 500;
    color: #475569;
    margin-bottom: 6px;
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid #e2e8f0;
    border-radius: 10px;
    font-size: 0.95rem;
    color: #0f172a;
    background: #f8fafc;
    transition: border-color 0.2s, box-shadow 0.2s;
    font-family: inherit;
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: #1d4ed8;
    box-shadow: 0 0 0 3px rgba(29, 78, 216, 0.1);
    background: #fff;
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: #94a3b8;
  }

  .form-group select {
    appearance: none;
    background-image: url("data:image/svg+xml,%3Csvg width='12' height='8' viewBox='0 0 12 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1.5L6 6.5L11 1.5' stroke='%2394a3b8' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 16px center;
    padding-right: 40px;
  }

  .form-group textarea {
    resize: vertical;
    min-height: 80px;
  }

  .submit-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    padding: 14px 28px;
    background: #1d4ed8;
    color: #fff;
    border: none;
    border-radius: 12px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.25s;
    box-shadow: 0 4px 14px rgba(29, 78, 216, 0.35);
    font-family: inherit;
  }

  .submit-btn:hover {
    background: #1e40af;
    transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(29, 78, 216, 0.45);
  }

  .form-note {
    margin-top: 12px;
    font-size: 0.75rem;
    color: #94a3b8;
    text-align: center;
  }

  @media (max-width: 768px) {
    .contact {
      padding: 64px 0;
    }

    .contact-layout {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .contact-info h2 {
      font-size: 1.75rem;
    }

    .contact-form {
      padding: 24px;
    }
  }
</style>

<script>
  const SUPABASE_URL = 'https://ujoxaraxvppnxulxjfwg.supabase.co/functions/v1/send-telegram';
  const SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InVqb3hhcmF4dnBwbnh1bHhqZndnIiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzc3MDQ1OTMsImV4cCI6MjA5MzI4MDU5M30.UVegLPhJINlt9fm2drUkmnAJoT7mSlMgH5YVHgxfW7E';
  const FORMSUBMIT_URL = 'https://formsubmit.co/ajax/dimrastur@gmail.com';

  const form = document.getElementById('request-form') as HTMLFormElement;
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = form.querySelector('.submit-btn') as HTMLButtonElement;
    const originalText = btn.innerHTML;

    const name = (form.querySelector('#name') as HTMLInputElement).value;
    const phone = (form.querySelector('#phone-input') as HTMLInputElement).value;
    const city = (form.querySelector('#city') as HTMLSelectElement).value;
    const appliance = (form.querySelector('#appliance') as HTMLSelectElement).value;
    const message = (form.querySelector('#message') as HTMLTextAreaElement).value;

    btn.innerHTML = 'Отправка...';
    btn.disabled = true;

    try {
      const [telegramRes, emailRes] = await Promise.allSettled([
        fetch(SUPABASE_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + SUPABASE_KEY },
          body: JSON.stringify({ name, phone, city, problem: `${appliance}: ${message}` }),
        }),
        fetch(FORMSUBMIT_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({
            name,
            phone,
            city,
            problem: `${appliance}: ${message}`,
            _subject: 'Новая заявка на ремонт — master-tehniki74.store',
          }),
        }),
      ]);

      const success = telegramRes.status === 'fulfilled' && telegramRes.value.ok
        || emailRes.status === 'fulfilled' && emailRes.value.ok;

      if (success) {
        btn.innerHTML = 'Заявка отправлена!';
        btn.style.background = '#16a34a';
        btn.style.boxShadow = '0 4px 14px rgba(22, 163, 74, 0.35)';
        setTimeout(() => {
          btn.innerHTML = originalText;
          btn.style.background = '';
          btn.style.boxShadow = '';
          btn.disabled = false;
          form.reset();
        }, 3000);
      } else {
        throw new Error('Both delivery channels failed');
      }
    } catch {
      btn.innerHTML = 'Ошибка. Позвоните нам!';
      btn.style.background = '#dc2626';
      btn.style.boxShadow = '0 4px 14px rgba(220, 38, 38, 0.35)';
      setTimeout(() => {
        btn.innerHTML = originalText;
        btn.style.background = '';
        btn.style.boxShadow = '';
        btn.disabled = false;
      }, 3000);
    }
  });
</script>
