---
const phone = '8 (951) 257-77-57';
const phoneRaw = '79512577757';
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          <svg width="28" height="28" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect width="32" height="32" rx="8" fill="#1d4ed8" />
            <path d="M8 10h16v2H8zM8 15h12v2H8zM8 20h14v2H8z" fill="#fff" />
            <circle cx="24" cy="21" r="3" fill="#60a5fa" />
          </svg>
          <span>Центр восстановления</span>
        </a>
        <p class="footer-about">Профессиональный ремонт бытовой техники в Миассе, Златоусте и Чебаркуле. Работаем с 2015 года.</p>
      </div>

      <div class="footer-links">
        <h4>Навигация</h4>
        <a href="#services">Услуги</a>
        <a href="#why-us">Почему мы</a>
        <a href="#map">Карта</a>
        <a href="#contact">Контакты</a>
      </div>

      <div class="footer-links">
        <h4>Услуги</h4>
        <a href="#services">Ремонт холодильников</a>
        <a href="#services">Ремонт стиральных машин</a>
        <a href="#services">Ремонт микроволновок</a>
        <a href="#services">Диагностика</a>
      </div>

      <div class="footer-contacts">
        <h4>Контакты</h4>
        <a href={`tel:+${phoneRaw}`} class="footer-phone">{phone}</a>
        <p>г. Миасс, ул. Победы, д. 18, цоколь</p>
        <p>Ежедневно 9:00 — 20:00</p>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {year} Центр восстановления бытовой техники. Все права защищены.</p>
      <p>Ремонт бытовой техники в Миассе, Златоусте, Чебаркуле</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: #0f172a;
    color: #94a3b8;
    padding: 64px 0 0;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1.2fr;
    gap: 48px;
    padding-bottom: 48px;
    border-bottom: 1px solid #1e293b;
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-weight: 700;
    font-size: 1.1rem;
    color: #fff;
    margin-bottom: 16px;
  }

  .footer-about {
    font-size: 0.9rem;
    line-height: 1.7;
    color: #94a3b8;
  }

  .footer-links h4,
  .footer-contacts h4 {
    font-size: 0.85rem;
    font-weight: 600;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 16px;
  }

  .footer-links a {
    display: block;
    font-size: 0.9rem;
    color: #94a3b8;
    margin-bottom: 10px;
    transition: color 0.2s;
  }

  .footer-links a:hover {
    color: #60a5fa;
  }

  .footer-phone {
    display: block;
    font-size: 1.1rem;
    font-weight: 600;
    color: #60a5fa;
    margin-bottom: 12px;
    transition: color 0.2s;
  }

  .footer-phone:hover {
    color: #93c5fd;
  }

  .footer-contacts p {
    font-size: 0.9rem;
    margin-bottom: 6px;
    color: #94a3b8;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 24px 0;
    font-size: 0.8rem;
    color: #64748b;
  }

  @media (max-width: 768px) {
    .footer {
      padding: 48px 0 0;
    }

    .footer-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .footer-bottom {
      flex-direction: column;
      gap: 8px;
      text-align: center;
    }
  }

  @media (min-width: 769px) and (max-width: 1024px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 32px;
    }
  }
</style>
