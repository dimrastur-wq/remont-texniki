---
const phone = '8 (951) 257-77-57';
const phoneRaw = '79512577757';
---

<section class="hero">
  <div class="hero-bg">
    <div class="hero-pattern"></div>
  </div>
  <div class="container hero-content">
    <div class="hero-text">
      <span class="hero-badge">Работаем по Южному Уралу</span>
      <h1>Ремонт бытовой техники<br />с выездом на дом</h1>
      <p class="hero-subtitle">
        Холодильники, стиральные машины, микроволновки &mdash; починим быстро и с гарантией.
        Обслуживаем Миасс, Златоуст и Чебаркуль.
      </p>
      <div class="hero-actions">
        <a href="#contact" class="btn btn-primary">Оставить заявку</a>
        <a href={`tel:+${phoneRaw}`} class="btn btn-outline">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
          </svg>
          {phone}
        </a>
      </div>
      <div class="hero-cities">
        <span class="city-tag">Миасс</span>
        <span class="city-tag">Златоуст</span>
        <span class="city-tag">Чебаркуль</span>
      </div>
    </div>
    <div class="hero-visual">
      <div class="hero-master-card">
        <div class="master-photo-wrap">
          <img src="/дима_мастер.png" alt="Мастер Дмитрий" class="master-photo" />
          <div class="master-badge">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            Дипломированный специалист
          </div>
        </div>
        <div class="master-meta">
          <div class="master-name-hero">Дмитрий — ведущий мастер</div>
          <div class="master-stats-row">
            <div class="mstat">
              <span class="mstat-val">14+</span>
              <span class="mstat-lbl">лет опыта</span>
            </div>
            <div class="mstat-div"></div>
            <div class="mstat">
              <span class="mstat-val">500+</span>
              <span class="mstat-lbl">ремонтов</span>
            </div>
            <div class="mstat-div"></div>
            <div class="mstat">
              <span class="mstat-val">1</span>
              <span class="mstat-lbl">день</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding: 120px 0 80px;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 50%, #bfdbfe 100%);
  }

  .hero-pattern {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle at 1px 1px, #93c5fd 1px, transparent 0);
    background-size: 40px 40px;
    opacity: 0.3;
  }

  .hero-content {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
  }

  .hero-text {
    max-width: 560px;
  }

  .hero-badge {
    display: inline-block;
    padding: 6px 16px;
    background: rgba(29, 78, 216, 0.1);
    color: #1d4ed8;
    border-radius: 100px;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 24px;
  }

  h1 {
    font-size: 3rem;
    font-weight: 700;
    line-height: 1.15;
    color: #0f172a;
    margin-bottom: 20px;
  }

  .hero-subtitle {
    font-size: 1.15rem;
    color: #475569;
    line-height: 1.7;
    margin-bottom: 32px;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 32px;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 28px;
    border-radius: 12px;
    font-weight: 600;
    font-size: 1rem;
    transition: all 0.25s;
    cursor: pointer;
    border: none;
  }

  .btn-primary {
    background: #1d4ed8;
    color: #fff;
    box-shadow: 0 4px 14px rgba(29, 78, 216, 0.35);
  }

  .btn-primary:hover {
    background: #1e40af;
    box-shadow: 0 6px 20px rgba(29, 78, 216, 0.45);
    transform: translateY(-1px);
  }

  .btn-outline {
    background: #fff;
    color: #1d4ed8;
    border: 2px solid #bfdbfe;
  }

  .btn-outline:hover {
    border-color: #1d4ed8;
    background: #eff6ff;
  }

  .hero-cities {
    display: flex;
    gap: 10px;
  }

  .city-tag {
    padding: 6px 14px;
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    font-size: 0.85rem;
    font-weight: 500;
    color: #475569;
  }

  .hero-visual {
    display: flex;
    justify-content: center;
  }

  .hero-master-card {
    background: #fff;
    border-radius: 24px;
    box-shadow: 0 20px 60px rgba(29, 78, 216, 0.12), 0 4px 16px rgba(0, 0, 0, 0.06);
    width: 100%;
    max-width: 400px;
    overflow: hidden;
  }

  .master-photo-wrap {
    position: relative;
    aspect-ratio: 4/5;
    overflow: hidden;
  }

  .master-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  .master-badge {
    position: absolute;
    bottom: 14px;
    left: 14px;
    background: #1d4ed8;
    color: #fff;
    font-size: 0.72rem;
    font-weight: 700;
    padding: 5px 12px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    gap: 5px;
    letter-spacing: 0.02em;
    box-shadow: 0 2px 8px rgba(29,78,216,0.35);
  }

  .master-meta {
    padding: 20px 24px;
  }

  .master-name-hero {
    font-size: 1rem;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 14px;
  }

  .master-stats-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .mstat {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex: 1;
  }

  .mstat-val {
    font-size: 1.5rem;
    font-weight: 700;
    color: #1d4ed8;
    line-height: 1;
  }

  .mstat-lbl {
    font-size: 0.75rem;
    color: #64748b;
    margin-top: 3px;
  }

  .mstat-div {
    width: 1px;
    height: 36px;
    background: #e2e8f0;
  }

  @media (max-width: 768px) {
    .hero {
      padding: 100px 0 48px;
    }

    .hero-content {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    h1 {
      font-size: 2rem;
    }

    .hero-subtitle {
      font-size: 1rem;
    }

    .hero-actions {
      flex-direction: column;
    }

    .btn {
      justify-content: center;
      width: 100%;
    }

    .hero-cities {
      flex-wrap: wrap;
    }

    .hero-card {
      padding: 24px;
    }

    .icon-item {
      width: 60px;
      height: 60px;
    }
  }
</style>
