---
import { MASTERS, SERVICE_LABELS } from '../data/masters';
const mastersJSON = JSON.stringify(
  MASTERS.filter(m => m.is_active).map(m => ({
    id: m.id, slug: m.slug, display_name: m.display_name,
    avatar_url: m.avatar_url, experience_years: m.experience_years,
    service_types: m.service_types, is_online: m.is_online,
    is_verified: m.is_verified, rating: m.rating,
    reviews_count: m.reviews_count, city_name: m.city_name,
    city_slug: m.city_slug,
  }))
);
const labelsJSON = JSON.stringify(SERVICE_LABELS);
---

<section class="masters-matcher">
  <div class="container">
    <div class="matcher-header">
      <div>
        <h2>Найдите мастера в вашем городе</h2>
        <p>Выберите город и тип техники — покажем доступных мастеров с рейтингом и ценами</p>
      </div>
      <a href="/masters/" class="btn-all-masters">Все мастера →</a>
    </div>

    <!-- City selector -->
    <div class="city-tabs" id="city-tabs">
      <button class="city-tab active" data-city="all">Все города</button>
      <button class="city-tab" data-city="miass">Миасс</button>
      <button class="city-tab" data-city="zlatoust">Златоуст</button>
      <button class="city-tab" data-city="chebarkul">Чебаркуль</button>
    </div>

    <!-- Masters display -->
    <div id="masters-display" class="masters-display">
    </div>

    <!-- Map placeholder -->
    <div class="mini-map">
      <div class="mini-map-inner" id="mini-map-inner">
        <div class="mini-map-label">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          Яндекс Карты API · готово к подключению
        </div>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ mastersJSON, labelsJSON }}>
  const SERVICE_LABELS = JSON.parse(labelsJSON);
  const allMasters = JSON.parse(mastersJSON);
  let activeCity = 'all';

  function filterMasters() {
    if (activeCity === 'all') return allMasters;
    return allMasters.filter(m => m.city_slug === activeCity);
  }

  function starsHTML(rating) {
    return [1,2,3,4,5].map(i =>
      `<svg width="12" height="12" viewBox="0 0 24 24" fill="${i <= Math.round(rating) ? '#f59e0b' : 'none'}" stroke="#f59e0b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`
    ).join('');
  }

  function renderMasters() {
    const display = document.getElementById('masters-display');
    const masters = filterMasters();

    if (masters.length === 0) {
      display.innerHTML = `<div class="no-masters">В этом городе пока нет мастеров. <a href="/master/">Зарегистрироваться как мастер →</a></div>`;
      renderMapPins([]);
      return;
    }

    display.innerHTML = `
      <div class="m-grid">
        ${masters.slice(0, 6).map(m => `
          <div class="m-card">
            <div class="m-head">
              <div class="m-av-wrap">
                ${m.avatar_url
                  ? `<img src="${m.avatar_url}" alt="${m.display_name}" class="m-av" />`
                  : `<div class="m-av-ph">${m.display_name.charAt(0)}</div>`}
                <span class="m-dot ${m.is_online ? 'online' : 'offline'}"></span>
              </div>
              <div class="m-info">
                <div class="m-name">
                  ${m.display_name}
                  ${m.is_verified ? '<span class="m-ver" title="Проверен">✓</span>' : ''}
                </div>
                <div class="m-city">${m.city_name} · ${m.experience_years} лет опыта</div>
                <div class="m-rating">
                  ${starsHTML(m.rating)}
                  <span>${Number(m.rating).toFixed(1)}</span>
                  <span class="m-cnt">(${m.reviews_count})</span>
                </div>
              </div>
            </div>
            <div class="m-chips">
              ${m.service_types.slice(0, 3).map(s => `<span class="m-chip">${SERVICE_LABELS[s] || s}</span>`).join('')}
            </div>
            <div class="m-actions">
              <a href="/masters/${m.slug}/" class="m-btn-profile">Профиль</a>
              <a href="/masters/${m.slug}/?call=1" class="m-btn-call">Вызвать</a>
            </div>
          </div>
        `).join('')}
      </div>
      ${masters.length > 6 ? `<div class="more-link"><a href="/masters/?city=${activeCity}">Ещё ${masters.length - 6} мастеров в каталоге →</a></div>` : ''}
    `;

    renderMapPins(masters);
  }

  function renderMapPins(masters) {
    const map = document.getElementById('mini-map-inner');
    if (!map) return;
    map.querySelectorAll('.m-pin').forEach(p => p.remove());
    masters.slice(0, 6).forEach((m, i) => {
      const pin = document.createElement('a');
      pin.href = `/masters/${m.slug}/`;
      pin.className = `m-pin ${m.is_online ? 'online' : 'offline'}`;
      pin.style.left = (15 + (i % 4) * 20 + Math.sin(i * 1.3) * 5) + '%';
      pin.style.top  = (20 + Math.floor(i / 4) * 30 + Math.cos(i * 1.1) * 5) + '%';
      pin.title = m.display_name;
      pin.innerHTML = `<span>${Number(m.rating).toFixed(1)}</span>`;
      map.appendChild(pin);
    });
  }

  document.getElementById('city-tabs')?.addEventListener('click', (e) => {
    const btn = e.target.closest('.city-tab');
    if (!btn) return;
    activeCity = btn.dataset.city;
    document.querySelectorAll('.city-tab').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    renderMasters();
  });

  renderMasters();
</script>

<style>
  .masters-matcher {
    padding: 72px 0;
    background: #f8fafc;
    border-top: 1px solid #e2e8f0;
  }
  .container { max-width: 1200px; margin: 0 auto; padding: 0 20px; }

  .matcher-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 28px;
    gap: 20px;
    flex-wrap: wrap;
  }
  .matcher-header h2 {
    font-size: clamp(1.3rem, 2.5vw, 1.8rem);
    font-weight: 800;
    color: #0f172a;
    margin-bottom: 6px;
  }
  .matcher-header p { font-size: 0.9rem; color: #64748b; max-width: 480px; }
  .btn-all-masters {
    padding: 10px 22px;
    background: #1d4ed8;
    color: #fff;
    border-radius: 10px;
    font-weight: 600;
    font-size: 0.88rem;
    white-space: nowrap;
    text-decoration: none;
    transition: background 0.2s;
    flex-shrink: 0;
  }
  .btn-all-masters:hover { background: #1e40af; }

  /* City tabs */
  .city-tabs {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 24px;
  }
  .city-tab {
    padding: 8px 18px;
    background: #fff;
    border: 1.5px solid #e2e8f0;
    border-radius: 100px;
    font-size: 0.85rem;
    font-weight: 600;
    color: #475569;
    cursor: pointer;
    font-family: inherit;
    transition: all 0.2s;
  }
  .city-tab:hover { border-color: #1d4ed8; color: #1d4ed8; }
  .city-tab.active { background: #1d4ed8; border-color: #1d4ed8; color: #fff; }

  /* Loading */
  .masters-loading {
    display: flex; align-items: center; gap: 12px;
    padding: 40px;
    color: #94a3b8;
    font-size: 0.9rem;
  }
  .spinner {
    width: 20px; height: 20px;
    border: 2px solid #e2e8f0;
    border-top-color: #1d4ed8;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* Masters grid */
  .m-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
    gap: 16px;
    margin-bottom: 16px;
  }
  .m-card {
    background: #fff;
    border: 1.5px solid #e2e8f0;
    border-radius: 18px;
    padding: 18px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: box-shadow 0.2s, transform 0.2s;
  }
  .m-card:hover { box-shadow: 0 6px 24px rgba(15,23,42,0.09); transform: translateY(-1px); }

  .m-head { display: flex; gap: 12px; }
  .m-av-wrap { position: relative; flex-shrink: 0; }
  .m-av { width: 52px; height: 52px; border-radius: 12px; object-fit: cover; }
  .m-av-ph {
    width: 52px; height: 52px;
    border-radius: 12px;
    background: linear-gradient(135deg, #1d4ed8, #3b82f6);
    color: #fff;
    font-size: 1.3rem;
    font-weight: 700;
    display: flex; align-items: center; justify-content: center;
  }
  .m-dot {
    position: absolute; bottom: -2px; right: -2px;
    width: 12px; height: 12px;
    border-radius: 50%;
    border: 2px solid #fff;
  }
  .m-dot.online { background: #4ade80; }
  .m-dot.offline { background: #94a3b8; }

  .m-info { flex: 1; min-width: 0; }
  .m-name {
    font-size: 0.92rem; font-weight: 700; color: #0f172a;
    display: flex; align-items: center; gap: 5px;
    margin-bottom: 3px;
  }
  .m-ver {
    background: #1d4ed8; color: #fff;
    border-radius: 50%;
    width: 16px; height: 16px;
    font-size: 0.6rem;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .m-city { font-size: 0.75rem; color: #64748b; margin-bottom: 4px; }
  .m-rating { display: flex; align-items: center; gap: 3px; font-size: 0.78rem; font-weight: 700; color: #0f172a; }
  .m-cnt { font-size: 0.72rem; color: #94a3b8; font-weight: 400; }

  .m-chips { display: flex; flex-wrap: wrap; gap: 4px; }
  .m-chip {
    padding: 2px 8px;
    background: #eff6ff;
    color: #1d4ed8;
    border-radius: 100px;
    font-size: 0.68rem;
    font-weight: 600;
    white-space: nowrap;
  }

  .m-actions { display: flex; gap: 6px; margin-top: auto; }
  .m-btn-profile, .m-btn-call {
    flex: 1;
    padding: 8px 10px;
    border-radius: 8px;
    font-size: 0.78rem;
    font-weight: 600;
    text-align: center;
    text-decoration: none;
    transition: all 0.2s;
  }
  .m-btn-profile { background: #f8fafc; border: 1px solid #e2e8f0; color: #374151; }
  .m-btn-profile:hover { border-color: #1d4ed8; color: #1d4ed8; }
  .m-btn-call { background: #1d4ed8; color: #fff; }
  .m-btn-call:hover { background: #1e40af; }

  .more-link { text-align: center; margin-top: 16px; }
  .more-link a { font-size: 0.88rem; color: #1d4ed8; font-weight: 600; }
  .more-link a:hover { text-decoration: underline; }

  .no-masters, .load-error {
    padding: 40px 20px;
    text-align: center;
    color: #64748b;
    font-size: 0.9rem;
  }
  .no-masters a, .load-error a { color: #1d4ed8; font-weight: 600; }

  /* Mini map */
  .mini-map {
    margin-top: 24px;
    border: 1.5px solid #e2e8f0;
    border-radius: 18px;
    overflow: hidden;
    height: 220px;
  }
  .mini-map-inner {
    position: relative;
    width: 100%; height: 100%;
    background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 60%, #ede9fe 100%);
    display: flex;
    align-items: flex-end;
    justify-content: flex-end;
    padding: 12px;
  }
  .m-pin {
    position: absolute;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    transition: transform 0.2s;
  }
  .m-pin:hover { transform: translateX(-50%) scale(1.15); z-index: 10; }
  .m-pin span {
    padding: 3px 8px;
    border-radius: 14px;
    font-size: 0.72rem;
    font-weight: 700;
    color: #fff;
    box-shadow: 0 2px 8px rgba(0,0,0,0.2);
  }
  .m-pin.online span { background: #1d4ed8; }
  .m-pin.offline span { background: #64748b; }
  .mini-map-label {
    display: flex; align-items: center; gap: 6px;
    background: rgba(255,255,255,0.85);
    border-radius: 8px;
    padding: 5px 10px;
    font-size: 0.72rem;
    color: #94a3b8;
    backdrop-filter: blur(4px);
  }

  @media (max-width: 768px) {
    .matcher-header { flex-direction: column; }
    .m-grid { grid-template-columns: 1fr; }
    .mini-map { height: 160px; }
  }
</style>
