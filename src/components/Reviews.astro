---
import { REVIEWS } from '../data/reviews';
import { CITIES, SITE, type CityKey } from '../data/services';

interface Props {
  city?: string;
  service?: string;
}

const { city, service } = Astro.props;

let filteredReviews = REVIEWS;
if (city) {
  filteredReviews = filteredReviews.filter(r => r.city === city);
}
if (service) {
  filteredReviews = filteredReviews.filter(r => r.service === service);
}
if (filteredReviews.length < 3) {
  filteredReviews = REVIEWS.slice(0, 6);
}

const formatDate = (dateStr: string) => {
  const d = new Date(dateStr);
  return d.toLocaleDateString('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' });
};

const cityOptions = Object.values(CITIES);

const avgRating = 4.9;
const reviewCount = filteredReviews.length;

const aggregateRatingSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "AggregateRating",
  "itemReviewed": {
    "@type": "LocalBusiness",
    "name": "Master-Tehniki74",
    "url": SITE.url,
  },
  "ratingValue": avgRating,
  "bestRating": 5,
  "worstRating": 1,
  "reviewCount": reviewCount,
});
---

<section class="reviews-section" id="reviews">
  <div class="container">
    <script type="application/ld+json" set:html={aggregateRatingSchema} />
    <div class="section-header">
      <span class="section-label">Отзывы</span>
      <h2>Отзывы наших клиентов</h2>
      <div class="rating-badge">
        <span class="rating-value">{avgRating}</span>
        <div class="rating-stars">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        </div>
        <span class="rating-count">на основе {reviewCount} отзывов</span>
      </div>
      <p class="section-desc">Реальные отзывы от жителей Миасса, Златоуста и Чебаркуля</p>
    </div>

    <div class="reviews-grid">
      {filteredReviews.slice(0, 6).map(review => (
        <div class="review-card">
          <div class="review-header">
            <div class="review-avatar">{review.name.charAt(0)}</div>
            <div>
              <span class="review-name">{review.name}</span>
              <span class="review-meta">{review.city} &middot; {formatDate(review.date)}</span>
            </div>
            <div class="review-stars">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            </div>
          </div>
          <p class="review-text">{review.text}</p>
          <span class="review-service">{review.service}</span>
        </div>
      ))}
    </div>

    <div class="review-form-block">
      <h3>Оставить отзыв</h3>
      <p class="form-desc">Расскажите о своём опыте — это поможет другим выбрать мастера</p>
      <form class="review-form" id="review-form">
        <div class="form-row">
          <div class="form-group">
            <label for="review-name">Ваше имя</label>
            <input type="text" id="review-name" name="name" placeholder="Иван Иванов" required />
          </div>
          <div class="form-group">
            <label for="review-city">Город</label>
            <select id="review-city" name="city" required>
              <option value="" disabled selected>Выберите город</option>
              {cityOptions.map(c => (
                <option value={c.name}>{c.name}</option>
              ))}
            </select>
          </div>
        </div>
        <div class="form-group">
          <label for="review-text">Ваш отзыв</label>
          <textarea id="review-text" name="text" rows="3" placeholder="Расскажите, какую технику чинили и как прошёл ремонт..." required></textarea>
        </div>
        <button type="submit" class="submit-btn" id="review-submit">
          Отправить отзыв
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
          </svg>
        </button>
        <p class="form-note">Отзыв будет опубликован после проверки модератором</p>
      </form>
    </div>
  </div>
</section>

<style>
  .reviews-section {
    padding: 80px 0;
    background: #f8fafc;
  }

  .section-header {
    text-align: center;
    max-width: 600px;
    margin: 0 auto 48px;
  }

  .section-label {
    display: inline-block;
    padding: 4px 14px;
    background: #eff6ff;
    color: #1d4ed8;
    border-radius: 100px;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 16px;
  }

  .section-header h2 {
    font-size: 2rem;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 12px;
  }

  .section-desc {
    font-size: 1.05rem;
    color: #64748b;
  }

  .rating-badge {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-bottom: 12px;
  }

  .rating-value {
    font-size: 1.5rem;
    font-weight: 700;
    color: #0f172a;
  }

  .rating-stars {
    display: flex;
    gap: 2px;
  }

  .rating-count {
    font-size: 0.85rem;
    color: #94a3b8;
  }

  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 48px;
  }

  .review-card {
    padding: 24px;
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 16px;
    transition: all 0.3s;
  }

  .review-card:hover {
    border-color: #bfdbfe;
    box-shadow: 0 4px 16px rgba(29, 78, 216, 0.06);
  }

  .review-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 14px;
  }

  .review-avatar {
    width: 40px;
    height: 40px;
    min-width: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #1d4ed8;
    color: #fff;
    border-radius: 50%;
    font-weight: 700;
    font-size: 1rem;
  }

  .review-name {
    display: block;
    font-size: 0.95rem;
    font-weight: 600;
    color: #0f172a;
  }

  .review-meta {
    display: block;
    font-size: 0.75rem;
    color: #94a3b8;
  }

  .review-stars {
    display: flex;
    gap: 2px;
    margin-left: auto;
  }

  .review-text {
    font-size: 0.9rem;
    color: #475569;
    line-height: 1.6;
    margin-bottom: 12px;
  }

  .review-service {
    display: inline-block;
    padding: 3px 10px;
    background: #eff6ff;
    color: #1d4ed8;
    border-radius: 6px;
    font-size: 0.75rem;
    font-weight: 500;
  }

  .review-form-block {
    background: #fff;
    padding: 40px;
    border-radius: 20px;
    border: 1px solid #e2e8f0;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.04);
  }

  .review-form-block h3 {
    font-size: 1.3rem;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 8px;
  }

  .form-desc {
    font-size: 0.95rem;
    color: #64748b;
    margin-bottom: 24px;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .form-group {
    margin-bottom: 16px;
  }

  .form-group label {
    display: block;
    font-size: 0.85rem;
    font-weight: 500;
    color: #475569;
    margin-bottom: 6px;
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid #e2e8f0;
    border-radius: 10px;
    font-size: 0.95rem;
    color: #0f172a;
    background: #f8fafc;
    transition: border-color 0.2s, box-shadow 0.2s;
    font-family: inherit;
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: #1d4ed8;
    box-shadow: 0 0 0 3px rgba(29, 78, 216, 0.1);
    background: #fff;
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: #94a3b8;
  }

  .form-group select {
    appearance: none;
    background-image: url("data:image/svg+xml,%3Csvg width='12' height='8' viewBox='0 0 12 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1.5L6 6.5L11 1.5' stroke='%2394a3b8' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 16px center;
    padding-right: 40px;
  }

  .form-group textarea {
    resize: vertical;
    min-height: 80px;
  }

  .submit-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 14px 28px;
    background: #1d4ed8;
    color: #fff;
    border: none;
    border-radius: 12px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.25s;
    box-shadow: 0 4px 14px rgba(29, 78, 216, 0.35);
    font-family: inherit;
  }

  .submit-btn:hover {
    background: #1e40af;
    transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(29, 78, 216, 0.45);
  }

  .submit-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
  }

  .form-note {
    margin-top: 12px;
    font-size: 0.75rem;
    color: #94a3b8;
  }

  @media (max-width: 768px) {
    .reviews-section {
      padding: 48px 0;
    }

    .section-header h2 {
      font-size: 1.5rem;
    }

    .reviews-grid {
      grid-template-columns: 1fr;
    }

    .form-row {
      grid-template-columns: 1fr;
    }

    .review-form-block {
      padding: 24px;
    }
  }

  @media (min-width: 769px) and (max-width: 1024px) {
    .reviews-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

<script>
  const form = document.getElementById('review-form') as HTMLFormElement;
  const submitBtn = document.getElementById('review-submit') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const name = (document.getElementById('review-name') as HTMLInputElement).value;
    const city = (document.getElementById('review-city') as HTMLSelectElement).value;
    const text = (document.getElementById('review-text') as HTMLTextAreaElement).value;

    submitBtn.disabled = true;
    submitBtn.innerHTML = 'Отправка...';

    try {
      const response = await fetch('https://ujoxaraxvppnxulxjfwg.supabase.co/functions/v1/send-telegram', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': 'Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InVqb3hhcmF4dnBwbnh1bHhqZndnIiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzc3MDQ1OTMsImV4cCI6MjA5MzI4MDU5M30.UVegLPhJINlt9fm2drUkmnAJoT7mSlMgH5YVHgxfW7E',
        },
        body: JSON.stringify({ name, city, text, type: 'review' }),
      });

      if (response.ok) {
        submitBtn.innerHTML = 'Спасибо! Мастер свяжется с вами в течение 10 минут';
        submitBtn.style.background = '#16a34a';
        submitBtn.style.boxShadow = '0 4px 14px rgba(22, 163, 74, 0.35)';
        form.reset();
      } else {
        throw new Error('Ошибка отправки');
      }
    } catch {
      submitBtn.innerHTML = 'Ошибка. Попробуйте позже';
      submitBtn.style.background = '#dc2626';
    }

    setTimeout(() => {
      submitBtn.innerHTML = 'Отправить отзыв <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>';
      submitBtn.style.background = '';
      submitBtn.style.boxShadow = '';
      submitBtn.disabled = false;
    }, 4000);
  });
</script>
