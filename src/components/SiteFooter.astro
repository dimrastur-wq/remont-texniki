---
import { SITE, CITIES, SERVICES } from '../data/services';
const year = new Date().getFullYear();
const cityKeys = Object.keys(CITIES);
const serviceKeys = Object.keys(SERVICES);

const serviceZones = {
  miass: ['Автозавод', 'Машгородок', 'Центр', 'Ленинский район', 'Тургоякское шоссе', 'Северная часть'],
  zlatoust: ['пр. Гагарина', 'Район вокзала', 'Площадь Металлургов', 'Красная Горка', 'Бульвар Космонавтов', 'Железнодорожный район'],
  chebarkul: ['Центр', 'Военный городок', 'Район вокзала', 'Микрорайон Южный', 'Старый город'],
};
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          <svg width="28" height="28" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect width="32" height="32" rx="8" fill="#1d4ed8" />
            <path d="M8 10h16v2H8zM8 15h12v2H8zM8 20h14v2H8z" fill="#fff" />
            <circle cx="24" cy="21" r="3" fill="#60a5fa" />
          </svg>
          <span>Центр восстановления</span>
        </a>
        <p class="footer-about">Профессиональный ремонт бытовой техники в Миассе, Златоусте и Чебаркуле. Работаем с 2015 года. Три мастера, своя мастерская, гарантия на все работы.</p>
        <div class="footer-schedule">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
          </svg>
          <span>{SITE.workHours}</span>
        </div>
      </div>

      <div class="footer-links">
        <h4>Города</h4>
        {cityKeys.map(key => {
          const city = CITIES[key as keyof typeof CITIES];
          return <a href={`/${city.slug}/`}>{city.name}</a>;
        })}
      </div>

      <div class="footer-links">
        <h4>Услуги</h4>
        {serviceKeys.map(key => {
          const service = SERVICES[key as keyof typeof SERVICES];
          return <a href={`/miass/${service.slug}/`}>{service.name}</a>;
        })}
        <a href="/zapchasti/">Запчасти</a>
        <a href="/skupka/">Скупка техники</a>
      </div>

      <div class="footer-links">
        <h4>Сервис</h4>
        <a href="/kalkulator/">Расчёт стоимости ремонта</a>
        <a href="/status/">Статус ремонта</a>
        <a href="/baza-znanii/">База знаний</a>
        <a href="/b2b/">Для бизнеса</a>
        <a href="/blog/">Блог</a>
      </div>

      <div class="footer-contacts">
        <h4>Контакты</h4>
        <a href={`tel:+${SITE.phoneRaw}`} class="footer-phone">{SITE.phone}</a>
        <a href={SITE.telegram} target="_blank" class="footer-telegram">Telegram</a>
        <a href={SITE.whatsapp} target="_blank" class="footer-whatsapp">WhatsApp</a>
        <p>{SITE.address}</p>
        <p>{SITE.workHours}</p>
      </div>
    </div>

    <div class="footer-zones">
      <h4>Зоны выезда мастера</h4>
      <div class="zones-grid">
        <div class="zone-block">
          <span class="zone-city">Миасс:</span>
          <span class="zone-areas">{serviceZones.miass.join(', ')}</span>
        </div>
        <div class="zone-block">
          <span class="zone-city">Златоуст:</span>
          <span class="zone-areas">{serviceZones.zlatoust.join(', ')}</span>
        </div>
        <div class="zone-block">
          <span class="zone-city">Чебаркуль:</span>
          <span class="zone-areas">{serviceZones.chebarkul.join(', ')}</span>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {year} Центр восстановления бытовой техники. Все права защищены.</p>
      <p>Ремонт бытовой техники в Миассе, Златоусте, Чебаркуле</p>
      <a href="/admin/" style="font-size:0.75rem;color:#475569;">B2B Рассылка</a>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: #0f172a;
    color: #94a3b8;
    padding: 64px 0 0;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1.2fr;
    gap: 48px;
    padding-bottom: 48px;
    border-bottom: 1px solid #1e293b;
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-weight: 700;
    font-size: 1.1rem;
    color: #fff;
    margin-bottom: 16px;
  }

  .footer-about {
    font-size: 0.9rem;
    line-height: 1.7;
    color: #94a3b8;
    margin-bottom: 16px;
  }

  .footer-schedule {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.85rem;
    color: #94a3b8;
  }

  .footer-links h4,
  .footer-contacts h4 {
    font-size: 0.85rem;
    font-weight: 600;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 16px;
  }

  .footer-links a {
    display: block;
    font-size: 0.9rem;
    color: #94a3b8;
    margin-bottom: 10px;
    transition: color 0.2s;
  }

  .footer-links a:hover {
    color: #60a5fa;
  }

  .footer-phone {
    display: block;
    font-size: 1.1rem;
    font-weight: 600;
    color: #60a5fa;
    margin-bottom: 12px;
    transition: color 0.2s;
  }

  .footer-phone:hover {
    color: #93c5fd;
  }

  .footer-telegram {
    display: block;
    font-size: 0.9rem;
    color: #0088cc;
    margin-bottom: 8px;
    transition: color 0.2s;
  }

  .footer-telegram:hover {
    color: #29b6f6;
  }

  .footer-whatsapp {
    display: block;
    font-size: 0.9rem;
    color: #25d366;
    margin-bottom: 12px;
    transition: color 0.2s;
  }

  .footer-whatsapp:hover {
    color: #4ceb7f;
  }

  .footer-contacts p {
    font-size: 0.9rem;
    margin-bottom: 6px;
    color: #94a3b8;
  }

  .footer-zones {
    padding: 32px 0;
    border-bottom: 1px solid #1e293b;
  }

  .footer-zones h4 {
    font-size: 0.85rem;
    font-weight: 600;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 16px;
  }

  .zones-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .zone-block {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .zone-city {
    font-size: 0.85rem;
    font-weight: 600;
    color: #60a5fa;
    white-space: nowrap;
  }

  .zone-areas {
    font-size: 0.85rem;
    color: #64748b;
    line-height: 1.5;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 24px 0;
    font-size: 0.8rem;
    color: #64748b;
  }

  @media (max-width: 768px) {
    .footer {
      padding: 48px 0 0;
    }

    .footer-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .zones-grid {
      grid-template-columns: 1fr;
      gap: 12px;
    }

    .footer-bottom {
      flex-direction: column;
      gap: 8px;
      text-align: center;
    }
  }

  @media (min-width: 769px) and (max-width: 1024px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 32px;
    }
  }
</style>
