---
<header class="site-header">
  <div class="header-inner">
    <a href="/" class="site-logo">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#ea580c" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
      <span>Мастер Техники 74</span>
    </a>
    <nav class="site-nav">
      <a href="/" class="nav-link">Главная</a>
      <a href="/instrumenty/" class="nav-link nav-tools">Инструменты</a>
      <a href="/master/" class="nav-link nav-master">Кабинет</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    background: #fff;
    border-bottom: 1px solid #e5e7eb;
    position: sticky; top: 0; z-index: 50;
  }
  .header-inner {
    max-width: 1100px; margin: 0 auto; padding: 12px 16px;
    display: flex; align-items: center; justify-content: space-between; gap: 16px;
  }
  .site-logo {
    display: flex; align-items: center; gap: 8px;
    font-weight: 800; font-size: 1rem; color: #111827; text-decoration: none;
  }
  .site-logo:hover { color: #ea580c; }
  .site-nav { display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }
  .nav-link {
    padding: 6px 14px; border-radius: 8px; text-decoration: none;
    font-size: .875rem; font-weight: 500; color: #4b5563; transition: all .15s;
  }
  .nav-link:hover { background: #f3f4f6; color: #111827; }
  .nav-tools { background: #fff7ed; color: #c2410c; border: 1px solid #fed7aa; }
  .nav-tools:hover { background: #ea580c; color: #fff; border-color: #ea580c; }
  .nav-master { background: #111827; color: #fff; }
  .nav-master:hover { background: #374151; }
</style>
