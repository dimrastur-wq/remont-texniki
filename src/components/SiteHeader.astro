---
---
<header class="site-header">
  <div class="header-inner">
    <a href="/" class="site-logo">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#ea580c" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
      <span>Мастер Техники 74</span>
    </a>

    <nav class="site-nav" id="site-nav">
      <a href="/" class="nav-link">Главная</a>
      <a href="/#services" class="nav-link">Услуги</a>
      <a href="/zapchasti/" class="nav-link">Запчасти</a>
      <a href="/instrumenty/" class="nav-link nav-tools">Инструменты</a>
      <a href="/master/" class="nav-link nav-master">Кабинет</a>
    </nav>

    <button class="burger" id="site-burger" aria-label="Меню" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

  <nav class="mobile-nav" id="mobile-nav" aria-hidden="true">
    <a href="/" class="mob-link">Главная</a>
    <a href="/#services" class="mob-link">Услуги</a>
    <a href="/zapchasti/" class="mob-link">Запчасти</a>
    <a href="/instrumenty/" class="mob-link mob-tools">Инструменты мастера</a>
    <a href="/master/" class="mob-link mob-master">Кабинет мастера</a>
  </nav>
</header>

<style>
  .site-header {
    background: #fff;
    border-bottom: 1px solid #e5e7eb;
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .header-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 16px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  /* Logo */
  .site-logo {
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 800;
    font-size: .95rem;
    color: #111827;
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .site-logo:hover { color: #ea580c; }

  /* Desktop nav */
  .site-nav {
    display: flex;
    align-items: center;
    gap: 4px;
    flex-wrap: nowrap;
  }
  .nav-link {
    padding: 6px 12px;
    border-radius: 8px;
    text-decoration: none;
    font-size: .875rem;
    font-weight: 500;
    color: #4b5563;
    transition: all .15s;
    white-space: nowrap;
  }
  .nav-link:hover { background: #f3f4f6; color: #111827; }
  .nav-tools {
    background: #fff7ed;
    color: #c2410c;
    border: 1px solid #fed7aa;
  }
  .nav-tools:hover { background: #ea580c; color: #fff; border-color: #ea580c; }
  .nav-master {
    background: #111827;
    color: #fff;
    padding: 6px 14px;
  }
  .nav-master:hover { background: #374151; }

  /* Burger */
  .burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    flex-shrink: 0;
  }
  .burger span {
    display: block;
    width: 22px;
    height: 2px;
    background: #374151;
    border-radius: 2px;
    transition: transform .25s, opacity .25s;
  }
  .burger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .burger.open span:nth-child(2) { opacity: 0; }
  .burger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* Mobile nav */
  .mobile-nav {
    display: none;
    flex-direction: column;
    background: #fff;
    border-top: 1px solid #f1f5f9;
    border-bottom: 1px solid #e5e7eb;
  }
  .mobile-nav.open { display: flex; }
  .mob-link {
    padding: 14px 20px;
    font-size: .95rem;
    font-weight: 500;
    color: #374151;
    text-decoration: none;
    border-bottom: 1px solid #f1f5f9;
    transition: background .15s;
  }
  .mob-link:last-child { border-bottom: none; }
  .mob-link:hover { background: #f9fafb; color: #111827; }
  .mob-tools {
    color: #c2410c;
    background: #fff7ed;
  }
  .mob-tools:hover { background: #fed7aa; }
  .mob-master {
    background: #111827;
    color: #fff !important;
    font-weight: 700;
  }
  .mob-master:hover { background: #374151; }

  /* Responsive */
  @media (max-width: 700px) {
    .site-nav { display: none; }
    .burger { display: flex; }
  }
  @media (min-width: 701px) {
    .mobile-nav { display: none !important; }
    .burger { display: none; }
  }
</style>

<script>
  const burger = document.getElementById('site-burger');
  const mobileNav = document.getElementById('mobile-nav');

  burger?.addEventListener('click', () => {
    const isOpen = mobileNav?.classList.toggle('open');
    burger.classList.toggle('open', isOpen);
    burger.setAttribute('aria-expanded', String(isOpen));
    mobileNav?.setAttribute('aria-hidden', String(!isOpen));
  });

  mobileNav?.querySelectorAll('.mob-link').forEach(link => {
    link.addEventListener('click', () => {
      mobileNav.classList.remove('open');
      burger?.classList.remove('open');
      burger?.setAttribute('aria-expanded', 'false');
      mobileNav.setAttribute('aria-hidden', 'true');
    });
  });
</script>
